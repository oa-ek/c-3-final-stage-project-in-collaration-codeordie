@model TravelManager.UI.Models.ViewModels.TripActivityFormViewModel

@{
    ViewData["Title"] = "Додати активність";
}

<div class="container py-4">
    <h2 class="mb-4">Додати активність</h2>
    <hr />

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="TripId" class="form-label fw-bold">Поїздка</label>
                            <select asp-for="TripId" asp-items="Model.TripList" class="form-select">
                                <option disabled selected>-- Оберіть поїздку --</option>
                            </select>
                            <span asp-validation-for="TripId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Title" class="form-label fw-bold">Назва (Екскурсія, Музей тощо)</label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="BookingStatusId" class="form-label fw-bold">Статус бронювання</label>
                            <select asp-for="BookingStatusId" asp-items="Model.BookingStatusList" class="form-select"></select>
                            <span asp-validation-for="BookingStatusId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Address" class="form-label fw-bold">Локація / Адреса</label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="StartTime" class="form-label fw-bold">Час початку</label>
                                <input asp-for="StartTime" class="form-control" type="datetime-local" />
                                <span asp-validation-for="StartTime" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label asp-for="EndTime" class="form-label fw-bold">Час завершення (необов'язково)</label>
                                <input asp-for="EndTime" class="form-control" type="datetime-local" />
                                <span asp-validation-for="EndTime" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Notes" class="form-label fw-bold">Нотатки</label>
                            <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <div class="form-group d-flex justify-content-between">
                            <button type="submit" class="btn btn-success px-5 shadow-sm">Зберегти</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}