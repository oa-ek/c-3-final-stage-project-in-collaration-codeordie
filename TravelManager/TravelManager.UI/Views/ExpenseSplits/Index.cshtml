@model IEnumerable<TravelManager.UI.Models.ViewModels.ExpenseSplitListViewModel>

@{
    ViewData["Title"] = "Розподіл витрат";
}

<style>
    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes shimmer {
        0% {
            transform: translateX(-150%) skewX(-15deg);
        }

        100% {
            transform: translateX(150%) skewX(-15deg);
        }
    }

    .stagger-item {
        animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }

    @@keyframes blob {
        0% {
            transform: translate(0px, 0px) scale(1);
        }

        33% {
            transform: translate(30px, -50px) scale(1.1);
        }

        66% {
            transform: translate(-20px, 20px) scale(0.9);
        }

        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    .animate-blob {
        animation: blob 7s infinite alternate;
    }

    .animation-delay-2000 {
        animation-delay: 2s;
    }
</style>

<div class="relative w-full max-w-6xl mx-auto min-h-[80vh] py-10 z-10 px-4">

    <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-0">
        <div class="absolute top-10 right-20 w-[25rem] h-[25rem] bg-emerald-400/20 rounded-full mix-blend-multiply filter blur-[100px] animate-blob"></div>
        <div class="absolute bottom-10 left-10 w-[30rem] h-[30rem] bg-rose-400/10 rounded-full mix-blend-multiply filter blur-[120px] animate-blob animation-delay-2000"></div>
    </div>

    <div class="relative z-20 flex flex-col md:flex-row justify-between items-start md:items-end mb-12 stagger-item" style="animation-delay: 0.1s;">
        <div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur-md border border-white shadow-sm mb-4">
                <i class="bi bi-people-fill text-emerald-500 text-sm"></i>
                <span class="text-xs font-black text-slate-500 uppercase tracking-widest">Взаєморозрахунки</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-black text-slate-800 tracking-tighter drop-shadow-sm leading-none">
                Спільні борги
            </h1>
        </div>

        <a asp-action="Create" class="mt-8 md:mt-0 group relative inline-flex items-center justify-center px-8 py-4 font-black text-white transition-all duration-300 bg-slate-900 rounded-full shadow-xl hover:shadow-2xl hover:-translate-y-1 uppercase tracking-widest text-xs overflow-hidden">
            <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
            <span class="relative flex items-center gap-3">
                Додати борг
                <i class="bi bi-plus-lg text-lg group-hover:rotate-90 transition-transform duration-300"></i>
            </span>
        </a>
    </div>

    <div class="relative z-20 space-y-4">
        @if (!Model.Any())
        {
            <div class="bg-white/40 backdrop-blur-3xl border border-white/80 rounded-[3rem] p-16 text-center shadow-sm stagger-item max-w-2xl mx-auto" style="animation-delay: 0.2s;">
                <div class="w-24 h-24 bg-emerald-50 rounded-[2rem] flex items-center justify-center mx-auto mb-6 border border-emerald-100">
                    <i class="bi bi-emoji-smile text-5xl text-emerald-400"></i>
                </div>
                <h3 class="text-3xl font-black text-slate-700 tracking-tight mb-2">Ніхто нікому не винен!</h3>
                <p class="text-slate-500 text-lg font-medium">Усі фінансові питання вирішені.</p>
            </div>
        }
        else
        {
            var delay = 0.2m;
            foreach (var item in Model)
            {
                <div class="group bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2rem] p-6 shadow-[0_8px_30px_-10px_rgba(0,0,0,0.04)] hover:shadow-[0_15px_40px_-10px_rgba(16,185,129,0.15)] hover:bg-white/80 transition-all duration-300 hover:-translate-y-1 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 stagger-item" style="animation-delay: @(delay.ToString(System.Globalization.CultureInfo.InvariantCulture))s;">

                    <div class="flex items-center gap-5 w-full md:w-auto">
                        <div class="w-14 h-14 shrink-0 bg-gradient-to-br from-slate-100 to-slate-200 rounded-full border-2 border-white flex items-center justify-center shadow-md group-hover:scale-105 transition-transform">
                            <i class="bi bi-person-fill text-2xl text-slate-400"></i>
                        </div>

                        <div class="flex flex-col">
                            <span class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Боржник</span>
                            <span class="text-xl font-black text-slate-800 tracking-tight leading-none mb-2">@item.DebtorName</span>
                            <div class="flex items-center gap-2 text-xs font-bold text-slate-500">
                                <i class="bi bi-receipt text-amber-500"></i>
                                <span class="bg-white/60 px-2 py-0.5 rounded-md border border-slate-100">@item.ExpenseName</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center justify-between md:justify-end w-full md:w-auto gap-6 mt-4 md:mt-0 pt-4 md:pt-0 border-t md:border-t-0 border-slate-100">

                        <div class="flex flex-col items-start md:items-end">
                            <span class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Сума боргу</span>
                            <span class="text-3xl font-black tracking-tighter @(item.IsSettled ? "text-emerald-500" : "text-rose-500")">
                                @item.OwedAmount.ToString("N2") <span class="text-sm font-bold opacity-60">₴</span>
                            </span>
                        </div>

                        <div class="hidden sm:flex shrink-0">
                            @if (item.IsSettled)
                            {
                                <div class="px-4 py-2 rounded-xl bg-emerald-50 border border-emerald-100 flex items-center gap-2">
                                    <span class="relative flex h-2.5 w-2.5">
                                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                                        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-500"></span>
                                    </span>
                                    <span class="text-xs font-black text-emerald-600 uppercase tracking-widest">Оплачено</span>
                                </div>
                            }
                            else
                            {
                                <div class="px-4 py-2 rounded-xl bg-rose-50 border border-rose-100 flex items-center gap-2">
                                    <i class="bi bi-clock-history text-rose-500"></i>
                                    <span class="text-xs font-black text-rose-600 uppercase tracking-widest">Висить</span>
                                </div>
                            }
                        </div>

                        <div class="flex items-center gap-2">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-indigo-600 hover:border-indigo-200 transition-all shadow-sm hover:scale-105" title="Редагувати">
                                <i class="bi bi-pencil-fill text-sm"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0" onsubmit="return confirm('Видалити цей борг?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-rose-600 hover:bg-rose-50 hover:border-rose-200 transition-all shadow-sm hover:scale-105" title="Видалити">
                                    <i class="bi bi-trash3-fill text-sm"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                delay += 0.1m;
            }
        }
    </div>
</div>