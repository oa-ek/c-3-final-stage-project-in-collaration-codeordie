@model TravelManager.UI.Models.ViewModels.ExpenseSplitFormViewModel

@{
    ViewData["Title"] = "Додати борг";
}

<style>
    /* Анімації */
    @@keyframes fadeSlideUp {
        0% {
            opacity: 0;
            transform: translateY(40px) scale(0.95);
        }

        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .stagger-item {
        animation: fadeSlideUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        opacity: 0;
    }

    /* Драматичні плаваючі плями */
    @@keyframes blob {
        0% {
            transform: translate(0px, 0px) scale(1);
        }

        33% {
            transform: translate(30px, -50px) scale(1.1);
        }

        66% {
            transform: translate(-20px, 20px) scale(0.9);
        }

        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    .animate-blob {
        animation: blob 7s infinite alternate;
    }

    .animation-delay-2000 {
        animation-delay: 2s;
    }

    .animation-delay-4000 {
        animation-delay: 4s;
    }

    /* Блік кнопки */
    @@keyframes shimmer {
        0% {
            transform: translateX(-100%) skewX(-15deg);
        }

        100% {
            transform: translateX(200%) skewX(-15deg);
        }
    }

    /* Кастомний скролбар для списків */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(244, 63, 94, 0.4);
        border-radius: 10px;
    }

        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(225, 29, 72, 0.8);
        }

    /* Анімація для чекбокса-тумблера */
    .toggle-checkbox:checked {
        right: 0;
        border-color: #10B981;
    }

        .toggle-checkbox:checked + .toggle-label {
            background-color: #10B981;
        }
</style>

<div class="relative w-full max-w-4xl mx-auto min-h-[85vh] py-12 z-10 px-4 flex flex-col justify-center overflow-hidden">

    <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-0">
        <div class="absolute top-10 left-10 w-72 h-72 bg-rose-500/20 rounded-full mix-blend-multiply filter blur-3xl animate-blob"></div>
        <div class="absolute top-20 right-10 w-72 h-72 bg-violet-500/20 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-2000"></div>
        <div class="absolute -bottom-8 left-20 w-72 h-72 bg-indigo-500/20 rounded-full mix-blend-multiply filter blur-3xl animate-blob animation-delay-4000"></div>
    </div>

    <div class="relative z-20 mb-10 text-center stagger-item" style="animation-delay: 0.1s;">
        <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/70 backdrop-blur-xl border border-white/80 shadow-[0_8px_30px_rgb(0,0,0,0.04)] mb-6 hover:scale-105 transition-transform cursor-default">
            <i class="bi bi-incognito text-rose-500 text-lg"></i>
            <span class="text-xs font-black text-slate-600 uppercase tracking-widest">Фінансова поліція</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-slate-800 via-slate-700 to-rose-900 tracking-tighter drop-shadow-sm pb-2">
            Хто тут винен? 🎯
        </h1>
    </div>

    <div class="relative z-20 bg-white/40 backdrop-blur-[40px] border border-white/60 rounded-[3rem] p-8 md:p-14 shadow-[0_20px_60px_-15px_rgba(0,0,0,0.1)] hover:shadow-[0_30px_70px_-15px_rgba(225,29,72,0.15)] transition-shadow duration-700 stagger-item" style="animation-delay: 0.2s;">

        <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-white to-transparent opacity-80"></div>

        <form asp-action="Create" method="post" class="relative z-10" id="debtForm">
            <div asp-validation-summary="ModelOnly" class="text-rose-600 mb-8 text-sm font-bold text-center bg-rose-100/50 backdrop-blur-md py-4 rounded-2xl border border-rose-200/50 animate-pulse"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                <div class="flex flex-col group relative z-50 md:col-span-2">
                    <label class="text-[11px] font-black uppercase tracking-widest text-slate-500 mb-2 pl-4 flex items-center gap-2 group-focus-within:text-violet-600 transition-colors">
                        <i class="bi bi-receipt text-lg"></i> За що винні гроші? 🍔🚕
                    </label>

                    <select asp-for="ExpenseId" asp-items="Model.ExpenseList" class="sr-only real-select"></select>

                    <div class="relative custom-dropdown w-full">
                        <button type="button" class="w-full bg-white/50 border-2 border-white/60 rounded-3xl py-5 pl-6 pr-6 text-lg font-bold text-slate-700 outline-none hover:bg-white/80 transition-all shadow-[inset_0_2px_10px_rgba(0,0,0,0.02)] flex justify-between items-center" onclick="toggleDropdown(this)">
                            <span class="selected-text text-slate-400">-- Оберіть чек, який треба поділити --</span>
                            <i class="bi bi-chevron-down transition-transform duration-300 text-slate-400"></i>
                        </button>

                        <div class="dropdown-menu absolute left-0 right-0 mt-2 bg-white/90 backdrop-blur-[40px] border border-white/80 rounded-3xl shadow-[0_20px_50px_-10px_rgba(0,0,0,0.15)] opacity-0 invisible translate-y-4 transition-all duration-300 overflow-hidden">
                            <ul class="max-h-56 overflow-y-auto py-2 custom-scrollbar">
                                <li class="px-6 py-3 text-slate-400 text-sm font-bold cursor-pointer hover:bg-slate-100/50 transition-colors" onclick="selectItem(this, '')">-- Ні за що --</li>
                                @if (Model.ExpenseList != null)
                                {
                                    foreach (var item in Model.ExpenseList)
                                    {
                                        <li class="px-6 py-4 text-slate-700 font-bold cursor-pointer hover:bg-violet-50 hover:text-violet-600 transition-colors flex items-center gap-3 border-b border-slate-100 last:border-0" onclick="selectItem(this, '@item.Value')">
                                            <i class="bi bi-ticket-detailed-fill text-violet-300"></i> @item.Text
                                        </li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                    <span asp-validation-for="ExpenseId" class="text-xs text-rose-500 font-bold absolute -bottom-5 left-4"></span>
                </div>

                <div class="flex flex-col group relative z-40">
                    <label class="text-[11px] font-black uppercase tracking-widest text-slate-500 mb-2 pl-4 flex items-center gap-2 group-focus-within:text-rose-500 transition-colors">
                        <i class="bi bi-person-bounding-box text-lg"></i> Хто цей щасливчик?
                    </label>

                    <select asp-for="DebtorId" asp-items="Model.DebtorList" class="sr-only real-select"></select>

                    <div class="relative custom-dropdown w-full">
                        <button type="button" class="w-full bg-white/50 border-2 border-white/60 rounded-3xl py-5 pl-6 pr-6 text-base font-bold text-slate-700 outline-none hover:bg-white/80 transition-all shadow-[inset_0_2px_10px_rgba(0,0,0,0.02)] flex justify-between items-center" onclick="toggleDropdown(this)">
                            <span class="selected-text text-slate-400">-- Кого ставимо на лічильник? --</span>
                            <i class="bi bi-chevron-down transition-transform duration-300 text-slate-400"></i>
                        </button>

                        <div class="dropdown-menu absolute left-0 right-0 mt-2 bg-white/90 backdrop-blur-[40px] border border-white/80 rounded-3xl shadow-[0_20px_50px_-10px_rgba(0,0,0,0.15)] opacity-0 invisible translate-y-4 transition-all duration-300 overflow-hidden">
                            <ul class="max-h-56 overflow-y-auto py-2 custom-scrollbar">
                                <li class="px-6 py-3 text-slate-400 text-sm font-bold cursor-pointer hover:bg-slate-100/50 transition-colors" onclick="selectItem(this, '')">-- Не обрано --</li>
                                @if (Model.DebtorList != null)
                                {
                                    foreach (var item in Model.DebtorList)
                                    {
                                        <li class="px-6 py-3 text-slate-700 font-bold cursor-pointer hover:bg-rose-50 hover:text-rose-600 transition-colors flex items-center gap-3" onclick="selectItem(this, '@item.Value')">
                                            <i class="bi bi-person-circle text-rose-300"></i> @item.Text
                                        </li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                    <span asp-validation-for="DebtorId" class="text-xs text-rose-500 font-bold absolute -bottom-5 left-4"></span>
                </div>

                <div class="flex flex-col group relative z-30">
                    <label asp-for="OwedAmount" class="text-[11px] font-black uppercase tracking-widest text-slate-500 mb-2 pl-4 group-focus-within:text-emerald-500 transition-colors flex items-center gap-2">
                        <i class="bi bi-cash-stack text-lg"></i> Скільки здеремо? 💰
                    </label>
                    <input asp-for="OwedAmount" type="number" step="0.01" placeholder="0.00" class="w-full bg-white/50 border-2 border-white/60 rounded-3xl py-5 pl-6 pr-6 text-3xl font-black text-slate-800 outline-none focus:ring-4 focus:ring-emerald-400/30 focus:border-emerald-400 focus:bg-emerald-50 hover:bg-white/80 transition-all shadow-[inset_0_2px_10px_rgba(0,0,0,0.02)] placeholder:text-slate-300" />
                    <span asp-validation-for="OwedAmount" class="text-xs text-rose-500 font-bold absolute -bottom-5 left-4"></span>
                </div>

                <div class="md:col-span-2 mt-4">
                    <div class="bg-white/50 border-2 border-white/60 rounded-3xl p-6 flex items-center justify-between shadow-[inset_0_2px_10px_rgba(0,0,0,0.02)] hover:bg-white/70 transition-all cursor-pointer" onclick="document.getElementById('settleToggle').click()">
                        <div class="flex flex-col">
                            <span class="text-lg font-black text-slate-800">Вже відкупився? 🤝</span>
                            <span class="text-xs font-bold text-slate-400">Відмітьте, якщо борг вже було повернуто (переказ чи готівка).</span>
                        </div>

                        <div class="relative inline-block w-14 mr-2 align-middle select-none transition duration-200 ease-in">
                            <input type="checkbox" asp-for="IsSettled" id="settleToggle" class="toggle-checkbox absolute block w-7 h-7 rounded-full bg-white border-4 border-slate-200 appearance-none cursor-pointer transition-all duration-300 z-10 top-1 left-1" />
                            <label for="settleToggle" class="toggle-label block overflow-hidden h-9 rounded-full bg-slate-200 cursor-pointer transition-colors duration-300"></label>
                        </div>
                    </div>
                </div>

            </div>

            <div class="mt-14 flex flex-col sm:flex-row items-center justify-end gap-6 pt-8 border-t border-slate-200/50">
                <a asp-action="Index" class="w-full sm:w-auto px-8 py-5 rounded-full font-black text-slate-400 hover:text-slate-700 bg-transparent hover:bg-white/50 transition-all text-sm uppercase tracking-widest text-center flex items-center justify-center gap-2">
                    Пробачити всім 🕊️
                </a>

                <button type="submit" class="w-full sm:w-auto group relative inline-flex items-center justify-center px-12 py-5 font-black text-white transition-all duration-300 bg-slate-900 rounded-full shadow-[0_10px_20px_-5px_rgba(0,0,0,0.3)] hover:shadow-[0_15px_30px_-5px_rgba(225,29,72,0.5)] hover:-translate-y-1 hover:scale-105 uppercase tracking-widest text-sm overflow-hidden active:scale-95">
                    <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
                    <span class="relative flex items-center gap-3">
                        Записати в чорний зошит 📓
                    </span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Скрипт для кастомного тумблера
        const toggle = document.getElementById('settleToggle');
        toggle.addEventListener('change', function() {
            if(this.checked) {
                this.classList.replace('left-1', 'left-6');
                this.classList.replace('border-slate-200', 'border-emerald-500');
                this.nextElementSibling.classList.replace('bg-slate-200', 'bg-emerald-400');
            } else {
                this.classList.replace('left-6', 'left-1');
                this.classList.replace('border-emerald-500', 'border-slate-200');
                this.nextElementSibling.classList.replace('bg-emerald-400', 'bg-slate-200');
            }
        });

        // Ініціалізація тумблера при завантаженні
        if(toggle.checked) {
            toggle.classList.replace('left-1', 'left-6');
            toggle.classList.replace('border-slate-200', 'border-emerald-500');
            toggle.nextElementSibling.classList.replace('bg-slate-200', 'bg-emerald-400');
        }

        // ЛОГІКА ДЛЯ КАСТОМНИХ ВИПАДАЮЧИХ СПИСКІВ
        function toggleDropdown(button) {
            document.querySelectorAll('.dropdown-menu').forEach(menu => {
                if (menu !== button.nextElementSibling) {
                    menu.classList.add('opacity-0', 'invisible', 'translate-y-4');
                    menu.previousElementSibling.querySelector('.bi-chevron-down').classList.remove('rotate-180');
                    menu.parentElement.classList.remove('z-[60]');
                }
            });

            const menu = button.nextElementSibling;
            const icon = button.querySelector('.bi-chevron-down');
            const container = button.parentElement;

            const isOpening = menu.classList.contains('opacity-0');

            if (isOpening) {
                menu.classList.remove('opacity-0', 'invisible', 'translate-y-4');
                icon.classList.add('rotate-180');
                container.classList.add('z-[60]');
            } else {
                menu.classList.add('opacity-0', 'invisible', 'translate-y-4');
                icon.classList.remove('rotate-180');
                setTimeout(() => container.classList.remove('z-[60]'), 300);
            }
        }

        function selectItem(liElement, value) {
            const text = liElement.innerText.trim();
            const container = liElement.closest('.custom-dropdown');
            const triggerBtn = container.querySelector('.selected-text');
            const realSelect = container.parentElement.querySelector('.real-select');
            const menu = container.querySelector('.dropdown-menu');
            const icon = container.querySelector('.bi-chevron-down');

            triggerBtn.innerText = text;
            triggerBtn.classList.remove('text-slate-400');
            triggerBtn.classList.add('text-slate-800');

            realSelect.value = value;

            realSelect.dispatchEvent(new Event('change'));
            if (typeof $(realSelect).valid === "function") {
                $(realSelect).valid();
            }

            menu.classList.add('opacity-0', 'invisible', 'translate-y-4');
            icon.classList.remove('rotate-180');
            setTimeout(() => container.classList.remove('z-[60]'), 300);
        }

        document.addEventListener('click', (e) => {
            if (!e.target.closest('.custom-dropdown')) {
                document.querySelectorAll('.dropdown-menu').forEach(menu => {
                    menu.classList.add('opacity-0', 'invisible', 'translate-y-4');
                    menu.parentElement.classList.remove('z-[60]');
                });
                document.querySelectorAll('.bi-chevron-down').forEach(icon => {
                    icon.classList.remove('rotate-180');
                });
            }
        });
    </script>
}