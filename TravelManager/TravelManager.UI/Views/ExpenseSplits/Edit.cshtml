@model TravelManager.UI.Models.ViewModels.ExpenseSplitFormViewModel

@{
    ViewData["Title"] = "Редагувати борг";
}

<div class="container py-4">
    <h2 class="mb-4">Редагувати борг</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-3">
                            <label asp-for="ExpenseId" class="form-label fw-bold">Витрата</label>
                            <select asp-for="ExpenseId" asp-items="Model.ExpenseList" class="form-select"></select>
                            <span asp-validation-for="ExpenseId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="DebtorId" class="form-label fw-bold">Хто винен (Боржник)</label>
                            <select asp-for="DebtorId" asp-items="Model.DebtorList" class="form-select"></select>
                            <span asp-validation-for="DebtorId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="OwedAmount" class="form-label fw-bold">Сума боргу</label>
                            <input asp-for="OwedAmount" class="form-control" type="number" step="0.01" />
                            <span asp-validation-for="OwedAmount" class="text-danger small"></span>
                        </div>

                        <div class="form-group form-check mb-4">
                            <input class="form-check-input" type="checkbox" asp-for="IsSettled">
                            <label class="form-check-label fw-bold" asp-for="IsSettled">
                                Вже оплачено (Розрахувалися)
                            </label>
                        </div>

                        <div class="form-group d-flex justify-content-between">
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">Оновити</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}