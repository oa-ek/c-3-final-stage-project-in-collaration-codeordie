@model IEnumerable<TravelManager.UI.Models.ViewModels.TransitListViewModel>

@{
    ViewData["Title"] = "Транспорт";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="display-6">Транспорт та переїзди</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">Додати квиток/трансфер</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Поїздка</th>
                    <th>Маршрут</th>
                    <th>Тип</th>
                    <th>Відправлення</th>
                    <th>Прибуття</th>
                    <th>Статус</th>
                    <th class="text-end pe-4">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.TripTitle</td>
                        <td>@item.DepartureLocation &rarr; @item.ArrivalLocation</td>
                        <td><span class="badge bg-secondary">@item.TransitTypeName</span></td>
                        <td>@item.DepartureTime.ToString("g")</td>
                        <td>@item.ArrivalTime.ToString("g")</td>
                        <td>
                            <span class="badge @(item.BookingStatusName == "Підтверджено" ? "bg-success" : "bg-warning text-dark")">
                                @item.BookingStatusName
                            </span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning text-dark">Редагувати</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Ви впевнені?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger ms-1">Видалити</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>