@model TravelManager.UI.Models.ViewModels.Account.ProfileViewModel
@{
    ViewData["Title"] = "Мій профіль";
}

<div class="container mt-4">
    <div class="row">
        <!-- Бокове меню -->
        <div class="col-md-3 mb-4">
            <div class="list-group shadow-sm">
                <!-- ВАЖЛИВО: Вказуємо asp-controller="Account" -->
                <a asp-controller="Account" asp-action="Profile" class="list-group-item list-group-item-action active" aria-current="true">
                    <i class="bi bi-person-circle me-2"></i> Особисті дані
                </a>
                <a asp-controller="Account" asp-action="ChangePassword" class="list-group-item list-group-item-action">
                    <i class="bi bi-shield-lock me-2"></i> Зміна пароля
                </a>
            </div>
        </div>

        <!-- Основний контент -->
        <div class="col-md-9">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h3 class="mb-4">Особисті дані</h3>

                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["StatusMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="Profile" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label class="form-label text-muted">Email (Логін)</label>
                            <input asp-for="Email" class="form-control bg-light" disabled />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label">Ім'я</label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label">Прізвище</label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PhoneNumber" class="form-label">Номер телефону</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+380..." />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i> Зберегти зміни
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}