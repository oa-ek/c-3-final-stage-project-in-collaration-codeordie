@model TravelManager.UI.Models.ViewModels.Account.ProfileViewModel
@{
    ViewData["Title"] = "Мій профіль";
    var hasPicture = Model.CurrentProfilePicture != null;
    var imgSrc = hasPicture ? $"data:image/jpeg;base64,{Convert.ToBase64String(Model.CurrentProfilePicture!)}" : "";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.css" />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    .profile-root {
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
        padding: 2rem 1rem 4rem;
        position: relative;
    }

        /* Живий фон */
        .profile-root::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse 80% 60% at 10% 20%, rgba(99,102,241,0.12) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 90% 80%, rgba(236,72,153,0.10) 0%, transparent 60%), radial-gradient(ellipse 50% 50% at 50% 50%, rgba(16,185,129,0.06) 0%, transparent 70%);
            z-index: -1;
            animation: bgShift 12s ease-in-out infinite alternate;
        }

    @@keyframes bgShift {
        0% {
            filter: hue-rotate(0deg) brightness(1);
        }

        100% {
            filter: hue-rotate(25deg) brightness(1.03);
        }
    }

    /* Плаваючі blob-и */
    .blob {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.18;
        z-index: -1;
        animation: blobFloat linear infinite;
        pointer-events: none;
    }

    .blob-1 {
        width: 500px;
        height: 500px;
        background: #6366f1;
        top: -100px;
        left: -100px;
        animation-duration: 20s;
    }

    .blob-2 {
        width: 400px;
        height: 400px;
        background: #ec4899;
        bottom: -80px;
        right: -80px;
        animation-duration: 25s;
        animation-direction: reverse;
    }

    .blob-3 {
        width: 300px;
        height: 300px;
        background: #10b981;
        top: 40%;
        left: 60%;
        animation-duration: 18s;
    }

    @@keyframes blobFloat {
        0% {
            transform: translate(0,0) scale(1);
        }

        33% {
            transform: translate(40px,-30px) scale(1.05);
        }

        66% {
            transform: translate(-20px,40px) scale(0.95);
        }

        100% {
            transform: translate(0,0) scale(1);
        }
    }

    .reveal {
        opacity: 0;
        transform: translateY(24px);
        animation: revealUp 0.65s cubic-bezier(.16,1,.3,1) forwards;
    }

    @@keyframes revealUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .delay-1 {
        animation-delay: 0.05s;
    }

    .delay-2 {
        animation-delay: 0.15s;
    }

    .delay-3 {
        animation-delay: 0.25s;
    }

    .delay-4 {
        animation-delay: 0.35s;
    }

    .delay-5 {
        animation-delay: 0.45s;
    }

    /* Сайдбар */
    .sidebar {
        background: rgba(255,255,255,0.55);
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,0.9);
        border-radius: 2rem;
        padding: 1.5rem 1rem;
        box-shadow: 0 8px 40px rgba(99,102,241,0.08);
        transition: box-shadow 0.3s ease;
    }

        .sidebar:hover {
            box-shadow: 0 12px 50px rgba(99,102,241,0.13);
        }

    .sidebar-label {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #94a3b8;
        padding: 0 0.75rem;
        margin-bottom: 0.5rem;
    }

    .s-link {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.8rem 1rem;
        border-radius: 1.2rem;
        font-weight: 600;
        font-size: 0.875rem;
        color: #64748b;
        text-decoration: none;
        transition: all 0.25s cubic-bezier(.4,0,.2,1);
        position: relative;
        overflow: hidden;
    }

        .s-link::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            opacity: 0;
            transition: opacity 0.25s ease;
            border-radius: 1.2rem;
        }

        .s-link span, .s-link i {
            position: relative;
            z-index: 1;
        }

        .s-link:hover {
            color: #4f46e5;
            transform: translateX(5px);
        }

            .s-link:hover::before {
                opacity: 0.08;
            }

        .s-link.active {
            color: white;
            box-shadow: 0 4px 20px rgba(99,102,241,0.4);
        }

            .s-link.active::before {
                opacity: 1;
            }

    /* Головна картка */
    .main-card {
        background: rgba(255,255,255,0.60);
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,0.9);
        border-radius: 2.5rem;
        box-shadow: 0 8px 50px rgba(99,102,241,0.08);
        overflow: hidden;
        transition: box-shadow 0.4s ease;
    }

        .main-card:hover {
            box-shadow: 0 16px 60px rgba(99,102,241,0.13);
        }

    .card-hero {
        background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 50%, #ec4899 100%);
        background-size: 200% 200%;
        animation: heroGradient 6s ease infinite;
        padding: 2.5rem 2.5rem 5rem;
        position: relative;
        overflow: hidden;
    }

    @@keyframes heroGradient {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    .card-hero::after {
        content: '';
        position: absolute;
        bottom: -2px;
        left: 0;
        right: 0;
        height: 3rem;
        background: rgba(255,255,255,0.60);
        backdrop-filter: blur(30px);
        border-radius: 2.5rem 2.5rem 0 0;
    }

    .hero-pattern {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.12) 1px, transparent 1px), radial-gradient(circle at 80% 20%, rgba(255,255,255,0.12) 1px, transparent 1px), radial-gradient(circle at 60% 80%, rgba(255,255,255,0.08) 1px, transparent 1px);
        background-size: 40px 40px, 35px 35px, 50px 50px;
        animation: patternDrift 20s linear infinite;
    }

    @@keyframes patternDrift {
        from {
            background-position: 0 0, 0 0, 0 0;
        }

        to {
            background-position: 40px 40px, -35px 35px, 50px -50px;
        }
    }

    .hero-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.6rem;
        font-weight: 900;
        color: white;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 20px rgba(0,0,0,0.15);
    }

    .hero-sub {
        color: rgba(255,255,255,0.78);
        font-size: 0.85rem;
        font-weight: 500;
        position: relative;
        z-index: 1;
        margin-top: 0.25rem;
    }

    /* Аватар */
    .avatar-wrap {
        position: relative;
        margin-top: -5.5rem;
        margin-left: 2rem;
        margin-bottom: 1.5rem;
        display: inline-block;
        z-index: 10;
    }

    .avatar-ring {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #ec4899, #10b981);
        background-size: 200% 200%;
        animation: avatarGradient 4s ease infinite, avatarPop 0.8s cubic-bezier(.34,1.56,.64,1) 0.4s both;
        padding: 3px;
        cursor: pointer;
        box-shadow: 0 8px 30px rgba(99,102,241,0.35);
        transition: transform 0.4s cubic-bezier(.34,1.56,.64,1), box-shadow 0.3s ease;
    }

    @@keyframes avatarGradient {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    @@keyframes avatarPop {
        from {
            transform: scale(0.4) rotate(-15deg);
            opacity: 0;
        }

        to {
            transform: scale(1) rotate(0deg);
            opacity: 1;
        }
    }

    .avatar-ring:hover {
        transform: scale(1.08) rotate(4deg);
        box-shadow: 0 14px 45px rgba(99,102,241,0.55);
    }

    .avatar-pulse {
        position: absolute;
        inset: -6px;
        border-radius: 50%;
        background: linear-gradient(135deg, #6366f1, #ec4899);
        opacity: 0;
        animation: pulseRing 3s ease-out infinite;
        z-index: -1;
    }

    @@keyframes pulseRing {
        0% {
            transform: scale(0.95);
            opacity: 0.5;
        }

        70% {
            transform: scale(1.15);
            opacity: 0;
        }

        100% {
            transform: scale(1.15);
            opacity: 0;
        }
    }

    .avatar-inner {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        overflow: hidden;
        background: #f1f5f9;
        border: 4px solid white;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .avatar-edit-badge {
        position: absolute;
        bottom: 4px;
        right: 4px;
        width: 34px;
        height: 34px;
        background: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 12px rgba(0,0,0,0.18);
        cursor: pointer;
        color: #6366f1;
        font-size: 0.9rem;
        transition: transform 0.3s cubic-bezier(.34,1.56,.64,1), box-shadow 0.2s ease;
    }

        .avatar-edit-badge:hover {
            transform: scale(1.25) rotate(-10deg);
            box-shadow: 0 4px 18px rgba(99,102,241,0.4);
        }

    /* Поля форми */
    .form-body {
        padding: 0 2rem 2.5rem;
    }

    .fields-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    @@media (max-width: 600px) {
        .fields-grid {
            grid-template-columns: 1fr;
        }
    }

    .field-wrap {
        background: rgba(248,250,252,0.9);
        border: 1.5px solid rgba(226,232,240,0.8);
        border-radius: 1.2rem;
        padding: 0.9rem 1.1rem;
        transition: all 0.3s cubic-bezier(.4,0,.2,1);
        position: relative;
        overflow: hidden;
    }

        .field-wrap::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(180deg, #6366f1, #ec4899);
            opacity: 0;
            transition: opacity 0.3s ease;
            border-radius: 3px 0 0 3px;
        }

        .field-wrap::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(105deg, transparent 40%, rgba(99,102,241,0.04) 50%, transparent 60%);
            background-size: 200% 100%;
            opacity: 0;
            transition: opacity 0.3s ease;
            animation: fieldShimmer 2s linear infinite;
            background-position: 200% 0;
        }

    @@keyframes fieldShimmer {
        from {
            background-position: 200% 0;
        }

        to {
            background-position: -200% 0;
        }
    }

    .field-wrap:focus-within {
        background: white;
        border-color: rgba(99,102,241,0.4);
        box-shadow: 0 0 0 4px rgba(99,102,241,0.09), 0 4px 20px rgba(99,102,241,0.08);
        transform: translateY(-3px);
    }

        .field-wrap:focus-within::before, .field-wrap:focus-within::after {
            opacity: 1;
        }

    .field-label {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.3rem;
        display: block;
        transition: color 0.2s ease;
    }

    .field-wrap:focus-within .field-label {
        color: #6366f1;
    }

    .field-input {
        border: none !important;
        background: transparent !important;
        padding: 0 !important;
        font-weight: 600;
        color: #1e293b;
        font-size: 0.95rem;
        width: 100%;
        outline: none !important;
        box-shadow: none !important;
        font-family: 'DM Sans', sans-serif;
        transition: color 0.2s ease;
    }

        .field-input:disabled {
            color: #94a3b8;
            cursor: not-allowed;
        }

    /* Кнопка зберегти */
    .save-btn {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        background-size: 200% 200%;
        color: white;
        border: none;
        border-radius: 1.2rem;
        padding: 0.9rem 2.5rem;
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 0.95rem;
        letter-spacing: 0.02em;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
        box-shadow: 0 4px 20px rgba(99,102,241,0.4);
        position: relative;
        overflow: hidden;
        animation: btnGradient 4s ease infinite;
    }

    @@keyframes btnGradient {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    .save-btn::after {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 60%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
        transition: left 0s;
        animation: btnShimmer 3s ease-in-out infinite;
    }

    @@keyframes btnShimmer {
        0% {
            left: -100%;
        }

        50% {
            left: 150%;
        }

        100% {
            left: 150%;
        }
    }

    .save-btn:hover {
        transform: translateY(-4px) scale(1.04);
        box-shadow: 0 10px 35px rgba(99,102,241,0.55);
        color: white;
    }

    .save-btn:active {
        transform: scale(0.96);
        box-shadow: 0 2px 10px rgba(99,102,241,0.3);
    }

    .success-toast {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(5,150,105,0.07));
        border: 1px solid rgba(16,185,129,0.25);
        border-radius: 1rem;
        padding: 0.9rem 1.2rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
        color: #065f46;
        font-size: 0.875rem;
        animation: toastIn 0.6s cubic-bezier(.34,1.56,.64,1);
    }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateY(-12px) scale(0.95);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .toast-icon {
        font-size: 1.2rem;
        color: #10b981;
        animation: checkPop 0.5s cubic-bezier(.34,1.56,.64,1) 0.2s both;
    }

    @@keyframes checkPop {
        from {
            transform: scale(0) rotate(-30deg);
        }

        to {
            transform: scale(1) rotate(0deg);
        }
    }

    /* Модалка */
    .crop-modal .modal-content {
        border: none;
        border-radius: 2rem;
        overflow: hidden;
        box-shadow: 0 30px 100px rgba(0,0,0,0.25);
        background: rgba(255,255,255,0.96);
        backdrop-filter: blur(30px);
        animation: modalPop 0.4s cubic-bezier(.34,1.56,.64,1);
    }

    @@keyframes modalPop {
        from {
            transform: scale(0.85) translateY(30px);
            opacity: 0;
        }

        to {
            transform: scale(1) translateY(0);
            opacity: 1;
        }
    }

    .crop-header {
        background: linear-gradient(135deg, #6366f1, #8b5cf6, #ec4899);
        background-size: 200% 200%;
        animation: heroGradient 5s ease infinite;
        padding: 1.5rem 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .crop-title {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 1.1rem;
        color: white;
    }

    .crop-close {
        background: rgba(255,255,255,0.2);
        border: none;
        color: white;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(.34,1.56,.64,1);
        font-size: 1rem;
    }

        .crop-close:hover {
            background: rgba(255,255,255,0.35);
            transform: rotate(90deg) scale(1.1);
        }

    #imageToCrop {
        display: block;
        max-width: 100%;
    }

    .page-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 900;
        color: #0f172a;
        line-height: 1;
        letter-spacing: -0.03em;
    }

        .page-title span {
            background: linear-gradient(135deg, #6366f1, #ec4899);
            background-size: 200% 200%;
            animation: heroGradient 5s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
</style>

<div class="blob blob-1"></div><div class="blob blob-2"></div><div class="blob blob-3"></div>

<div class="profile-root">
    <div style="max-width: 1000px; margin: 0 auto;">

        <div class="reveal delay-1" style="margin-bottom: 2.5rem;">
            <h1 class="page-title">Мій <span>профіль</span></h1>
            <p style="color:#64748b; font-weight:500; margin-top:0.5rem;">Керуй особистими даними та налаштуваннями акаунту</p>
        </div>

        <div style="display:flex; gap:1.5rem; align-items:flex-start; flex-wrap:wrap;">

            <div class="sidebar reveal delay-2" style="width:200px; flex-shrink:0;">
                <p class="sidebar-label">Акаунт</p>
                <a asp-controller="Account" asp-action="Profile" class="s-link active"><i class="bi bi-person-fill"></i><span>Особисті дані</span></a>
                <a asp-controller="Account" asp-action="ChangePassword" class="s-link"><i class="bi bi-shield-lock-fill"></i><span>Пароль</span></a>
            </div>

            <div class="main-card reveal delay-3" style="flex:1; min-width:300px;">
                <div class="card-hero">
                    <div class="hero-pattern"></div>
                    <div class="hero-title">Особисті дані</div>
                    <div class="hero-sub">Оновлюй інформацію про себе</div>
                </div>

                <div class="avatar-wrap">
                    <div class="avatar-pulse"></div>
                    <div class="avatar-ring" onclick="document.getElementById('ProfileImageInput').click()" title="Змінити фото">
                        <div class="avatar-inner">
                            @if (hasPicture)
                            {
                                <img id="profilePreview" src="@imgSrc" alt="Аватар" style="width:100%;height:100%;object-fit:cover;" />
                                <i id="profilePlaceholder" class="bi bi-person-fill" style="font-size:3rem;color:#cbd5e1;display:none;"></i>
                            }
                            else
                            {
                                <img id="profilePreview" src="" alt="" style="width:100%;height:100%;object-fit:cover;display:none;" />
                                <i id="profilePlaceholder" class="bi bi-person-fill" style="font-size:3rem;color:#cbd5e1;"></i>
                            }
                        </div>
                    </div>
                    <div class="avatar-edit-badge" onclick="document.getElementById('ProfileImageInput').click()">
                        <i class="bi bi-camera-fill"></i>
                    </div>
                </div>

                <div class="form-body">
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="success-toast">
                            <i class="bi bi-check-circle-fill toast-icon"></i>
                            @TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-action="Profile" method="post" enctype="multipart/form-data" id="profileForm">
                        <div asp-validation-summary="ModelOnly" style="color:#ef4444;font-size:0.85rem;font-weight:600;margin-bottom:1rem;"></div>

                        <input asp-for="ProfileImage" id="ProfileImageInput" type="file" style="display:none;" accept="image/png,image/jpeg,image/jpg" />

                        <div class="fields-grid">
                            <div class="field-wrap reveal delay-3" style="grid-column:1/-1;">
                                <label class="field-label">Email (Логін)</label>
                                <input asp-for="Email" class="field-input" disabled />
                            </div>
                            <div class="field-wrap reveal delay-4">
                                <label class="field-label">Ім'я</label>
                                <input asp-for="FirstName" class="field-input" />
                                <span asp-validation-for="FirstName" style="color:#ef4444;font-size:0.75rem;font-weight:600;"></span>
                            </div>
                            <div class="field-wrap reveal delay-4">
                                <label class="field-label">Прізвище</label>
                                <input asp-for="LastName" class="field-input" />
                                <span asp-validation-for="LastName" style="color:#ef4444;font-size:0.75rem;font-weight:600;"></span>
                            </div>
                            <div class="field-wrap reveal delay-5" style="grid-column:1/-1;">
                                <label class="field-label">Номер телефону</label>
                                <input asp-for="PhoneNumber" class="field-input" placeholder="+380..." />
                                <span asp-validation-for="PhoneNumber" style="color:#ef4444;font-size:0.75rem;font-weight:600;"></span>
                            </div>
                        </div>

                        <div style="display:flex;justify-content:flex-end;margin-top:1.75rem;" class="reveal delay-5">
                            <button type="submit" class="save-btn" id="mainSubmitBtn">
                                <i class="bi bi-save2-fill" style="margin-right:0.5rem;"></i> Зберегти зміни
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@* Модалка кропера *@
<div class="modal fade crop-modal" id="cropModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="crop-header">
                <div class="crop-title"><i class="bi bi-crop me-2"></i>Обрізати фото</div>
                <button type="button" class="crop-close" data-bs-dismiss="modal"><i class="bi bi-x-lg"></i></button>
            </div>
            <div class="modal-body p-4">
                <div style="max-height:450px;overflow:hidden;border-radius:1rem;">
                    <img id="imageToCrop" src="" alt="Picture">
                </div>
            </div>
            <div class="modal-footer border-0 px-4 pb-4 gap-3">
                <button type="button" class="btn btn-light rounded-3 fw-bold px-4" data-bs-dismiss="modal">Скасувати</button>
                <button type="button" id="btnCropAndSave" class="save-btn" style="padding:0.7rem 2rem;">
                    <i class="bi bi-check2-circle me-2"></i>Підтвердити обрізання
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            let cropper;
            const imageInput   = document.getElementById('ProfileImageInput');
            const imageToCrop  = document.getElementById('imageToCrop');
            const previewImage = document.getElementById('profilePreview');
            const placeholder  = document.getElementById('profilePlaceholder');
            const cropModalEl  = document.getElementById('cropModal');
            const btnCrop      = document.getElementById('btnCropAndSave');

            // Надійне створення інстансу
            const cropModal = new bootstrap.Modal(cropModalEl);

            imageInput.addEventListener('change', function (e) {
                const file = e.target.files[0];
                if (!file) return;
                const reader = new FileReader();
                reader.onload = ev => {
                    imageToCrop.src = ev.target.result;
                    cropModal.show();
                };
                reader.readAsDataURL(file);
            });

            cropModalEl.addEventListener('shown.bs.modal', () => {
                if (cropper) { cropper.destroy(); }
                // viewMode: 1 краще адаптує зображення під екран
                cropper = new Cropper(imageToCrop, { aspectRatio: 1, viewMode: 1, autoCropArea: 1 });
            });

            cropModalEl.addEventListener('hidden.bs.modal', () => {
                if (cropper) { cropper.destroy(); cropper = null; }
            });

            btnCrop.addEventListener('click', () => {
                if (!cropper) return;

                // Зміна стану кнопки, щоб показати, що йде обробка
                const originalHtml = btnCrop.innerHTML;
                btnCrop.innerHTML = '<i class="bi bi-hourglass-split me-2"></i>Обробляємо...';
                btnCrop.disabled = true;

                try {
                    cropper.getCroppedCanvas({ width: 400, height: 400 }).toBlob(blob => {
                        if(blob) {
                            previewImage.src = URL.createObjectURL(blob);
                            previewImage.style.display = 'block';
                            if (placeholder) placeholder.style.display = 'none';

                            const dt = new DataTransfer();
                            dt.items.add(new File([blob], 'avatar.jpg', { type: 'image/jpeg' }));
                            imageInput.files = dt.files;
                        }

                        // Гарантоване закриття через глобальний інстанс
                        bootstrap.Modal.getInstance(cropModalEl).hide();

                        // Повертаємо кнопку в нормальний стан
                        btnCrop.innerHTML = originalHtml;
                        btnCrop.disabled = false;

                        // Невеличка підказка (щоб юзер не забув зберегти)
                        const submitBtn = document.getElementById('mainSubmitBtn');
                        submitBtn.classList.add('pulse-alert');
                        submitBtn.innerHTML = '<i class="bi bi-save2-fill" style="margin-right:0.5rem;"></i> Тепер збережіть зміни!';

                    }, 'image/jpeg', 0.95);
                } catch (err) {
                    console.error("Помилка при обрізанні: ", err);
                    btnCrop.innerHTML = originalHtml;
                    btnCrop.disabled = false;
                }
            });
        });
    </script>

    <style>
        .pulse-alert {
            animation: pulseSubmit 1.5s infinite;
            background: linear-gradient(135deg, #10b981, #059669) !important;
        }

        @@keyframes pulseSubmit {
            0% {
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7);
            }

            50% {
                transform: scale(1.05);
                box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
            }

            100% {
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
            }
        }
    </style>
}