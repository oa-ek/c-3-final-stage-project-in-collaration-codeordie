@model TravelManager.UI.Models.ViewModels.Account.ProfileViewModel
@{
    ViewData["Title"] = "Мій профіль";
}

<div class="container mt-4">
    <div class="row">
        <!-- Бокове меню -->
        <div class="col-md-3 mb-4">
            <div class="list-group shadow-sm">
                <a asp-controller="Account" asp-action="Profile" class="list-group-item list-group-item-action active" aria-current="true">
                    <i class="bi bi-person-circle me-2"></i> Особисті дані
                </a>
                <a asp-controller="Account" asp-action="ChangePassword" class="list-group-item list-group-item-action">
                    <i class="bi bi-shield-lock me-2"></i> Зміна пароля
                </a>
            </div>
        </div>

        <!-- Основний контент -->
        <div class="col-md-9">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h3 class="mb-4">Особисті дані</h3>

                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["StatusMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <!-- ДОДАНО: enctype="multipart/form-data" ОБОВ'ЯЗКОВО ДЛЯ ФАЙЛІВ -->
                    <form asp-action="Profile" method="post" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- БЛОК ФОТО ПРОФІЛЮ -->
                        <div class="row mb-4 align-items-center">
                            <div class="col-auto">
                                @if (Model.CurrentProfilePicture != null)
                                {
                                    var base64 = Convert.ToBase64String(Model.CurrentProfilePicture);
                                    var imgSrc = String.Format("data:image/jpeg;base64,{0}", base64);
                                    <img src="@imgSrc" alt="Profile" class="rounded-circle shadow-sm" style="width:100px; height:100px; object-fit:cover;" />
                                }
                                else
                                {
                                    <i class="bi bi-person-circle text-muted" style="font-size: 100px; line-height: 1;"></i>
                                }
                            </div>
                            <div class="col">
                                <label asp-for="ProfileImage" class="form-label text-muted">Оновити фото профілю</label>
                                <input asp-for="ProfileImage" type="file" class="form-control" accept="image/*" />
                                <small class="text-muted">Рекомендований розмір: 200x200 px. Формати: JPG, PNG.</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted">Email (Логін)</label>
                            <input asp-for="Email" class="form-control bg-light" disabled />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="FirstName" class="form-label">Ім'я</label>
                                <input asp-for="FirstName" class="form-control" />
                                <span asp-validation-for="FirstName" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label asp-for="LastName" class="form-label">Прізвище</label>
                                <input asp-for="LastName" class="form-control" />
                                <span asp-validation-for="LastName" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="PhoneNumber" class="form-label">Номер телефону</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+380..." />
                            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i> Зберегти зміни
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}