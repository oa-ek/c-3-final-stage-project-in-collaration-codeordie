@model TravelManager.UI.Models.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Забули пароль?";
}

<style>
    @@keyframes slideUpFade {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .animate-slide-up {
        animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>

<div class="relative w-full flex flex-col items-center justify-center min-h-[80vh] py-10 z-10 overflow-hidden">
    <div class="absolute top-10 right-1/4 w-[30rem] h-[30rem] bg-indigo-400/10 rounded-full blur-[100px] animate-pulse pointer-events-none translate-x-1/2"></div>
    <div class="absolute bottom-10 left-1/4 w-[35rem] h-[35rem] bg-blue-500/10 rounded-full blur-[120px] animate-pulse pointer-events-none -translate-x-1/4" style="animation-delay: 2s;"></div>

    <div class="w-full max-w-md animate-slide-up z-20 px-4">
        <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2.5rem] p-8 md:p-10 shadow-[0_15px_40px_-10px_rgba(0,0,0,0.1)]">

            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-gradient-to-br from-indigo-100 to-white rounded-2xl border border-indigo-100 flex items-center justify-center mx-auto mb-5 shadow-sm">
                    <i class="bi bi-key-fill text-3xl text-indigo-600 drop-shadow-sm"></i>
                </div>
                <h2 class="text-3xl font-black text-slate-800 tracking-tight">Відновлення пароля</h2>
                <p class="text-slate-500 font-medium mt-3 text-sm leading-relaxed">
                    Введіть ваш Email, і ми надішлемо посилання для створення нового безпечного пароля.
                </p>
            </div>

            <form asp-action="ForgotPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-rose-500 mb-5 p-4 bg-rose-50/80 backdrop-blur-sm rounded-2xl text-sm font-medium border border-rose-100"></div>

                <div class="mb-6">
                    <label asp-for="Email" class="block text-sm font-bold text-slate-700 mb-2 pl-1">Ваш Email</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none">
                            <i class="bi bi-envelope text-slate-400"></i>
                        </div>
                        <input asp-for="Email" class="w-full bg-white/70 border border-slate-200 text-slate-800 text-sm rounded-2xl focus:ring-4 focus:ring-indigo-500/20 focus:border-indigo-500 block pl-11 pr-4 py-3.5 transition-all outline-none shadow-sm placeholder:text-slate-400" type="email" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-rose-500 text-xs font-medium mt-1.5 pl-1 block"></span>
                </div>

                <div class="mb-6">
                    <button type="submit" class="w-full group relative inline-flex items-center justify-center px-8 py-4 font-black text-white transition-all duration-500 bg-gradient-to-r from-indigo-600 to-blue-600 rounded-full shadow-[0_10px_20px_-10px_rgba(79,70,229,0.5)] hover:shadow-[0_15px_25px_-10px_rgba(79,70,229,0.6)] hover:-translate-y-0.5 uppercase tracking-widest text-xs overflow-hidden">
                        <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
                        <span class="relative flex items-center gap-2">
                            Відправити посилання <i class="bi bi-send-fill text-sm"></i>
                        </span>
                    </button>
                </div>
            </form>

            <div class="text-center mt-6">
                <a asp-action="Login" class="inline-flex items-center justify-center gap-2 text-sm font-bold text-slate-500 hover:text-indigo-600 transition-colors group">
                    <div class="w-8 h-8 rounded-full bg-slate-100 group-hover:bg-indigo-50 flex items-center justify-center transition-colors">
                        <i class="bi bi-arrow-left text-lg transition-transform group-hover:-translate-x-1"></i>
                    </div>
                    Повернутися до входу
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}