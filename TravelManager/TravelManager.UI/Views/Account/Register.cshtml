@model TravelManager.UI.Models.ViewModels.Account.RegisterViewModel

@{
    ViewData["Title"] = "Реєстрація";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm mt-5">
            <div class="card-body p-5">
                <h2 class="text-center mb-4">Створити акаунт</h2>

                <form asp-action="Register" method="post">
                    <!-- Загальні помилки форми (наприклад, якщо такий email вже є) -->
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="FirstName" class="form-label">Ім'я</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Іван" />
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="LastName" class="form-label">Прізвище</label>
                            <input asp-for="LastName" class="form-control" placeholder="Франко" />
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="example@mail.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <!-- Пароль з Оком -->
                    <div class="form-group mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="Password" type="password" id="passInput" class="form-control" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePass('passInput', 'passIcon')">
                                <i class="bi bi-eye-slash" id="passIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="ConfirmPassword" type="password" id="confirmInput" class="form-control" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePass('confirmInput', 'confirmIcon')">
                                <i class="bi bi-eye-slash" id="confirmIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-primary btn-lg">Створити акаунт</button>
                    </div>
                </form>
                <div class="text-center mt-4">
                    <p class="text-muted">Вже маєте акаунт? <a asp-action="Login" class="text-decoration-none fw-bold">Увійти</a></p>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            }
        }
    </script>
}