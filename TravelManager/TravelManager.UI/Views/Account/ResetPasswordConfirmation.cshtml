@{
    ViewData["Title"] = "Готово!";
}

<div class="row justify-content-center">
    <div class="col-md-5 text-center mt-5">
        <div class="card shadow-sm border-0 p-5">
            <i class="bi bi-check-circle text-success" style="font-size: 4rem;"></i>
            <h2 class="mt-3">Пароль оновлено!</h2>
            <p class="text-muted mt-2">Ваш пароль було успішно змінено. Тепер ви можете увійти в систему з новим паролем.</p>

            <a asp-action="Login" class="btn btn-primary mt-4">Увійти в систему</a>
        </div>
    </div>
</div>