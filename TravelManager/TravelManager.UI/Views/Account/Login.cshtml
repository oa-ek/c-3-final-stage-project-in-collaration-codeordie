@model TravelManager.UI.Models.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Вхід";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<style>
    @@keyframes slideUpFade {
        from

    {
        opacity: 0;
        transform: translateY(30px) scale(0.98);
    }

    to {
        opacity: 1;
        transform: translateY(0) scale(1);
    }

    }

    .animate-slide-up {
        animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>

<div class="relative w-full flex flex-col items-center justify-center min-h-[80vh] py-10 z-10 overflow-hidden">
    <div class="absolute top-10 left-1/4 w-[30rem] h-[30rem] bg-blue-500/10 rounded-full blur-[100px] animate-pulse pointer-events-none -translate-x-1/2"></div>
    <div class="absolute bottom-10 right-1/4 w-[35rem] h-[35rem] bg-indigo-400/10 rounded-full blur-[120px] animate-pulse pointer-events-none translate-x-1/4" style="animation-delay: 2s;"></div>

    <div class="w-full max-w-md animate-slide-up z-20 px-4">
        <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2.5rem] p-8 md:p-10 shadow-[0_15px_40px_-10px_rgba(0,0,0,0.1)]">

            <div class="text-center mb-8">
                <div class="w-16 h-16 bg-gradient-to-br from-blue-100 to-white rounded-2xl border border-blue-100 flex items-center justify-center mx-auto mb-5 shadow-sm">
                    <i class="bi bi-airplane-fill text-3xl text-blue-600 drop-shadow-sm"></i>
                </div>
                <h2 class="text-3xl font-black text-slate-800 tracking-tight">З поверненням!</h2>
                <p class="text-slate-500 font-medium mt-2 text-sm">Увійдіть, щоб продовжити свої подорожі</p>
            </div>

            <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-rose-500 mb-5 p-4 bg-rose-50/80 backdrop-blur-sm rounded-2xl text-sm font-medium border border-rose-100" style="display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>

                <div class="mb-5">
                    <label asp-for="Email" class="block text-sm font-bold text-slate-700 mb-2 pl-1">Email адреса</label>
                    <input asp-for="Email" class="w-full bg-white/70 border border-slate-200 text-slate-800 text-sm rounded-2xl focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 block px-4 py-3.5 transition-all outline-none shadow-sm placeholder:text-slate-400" type="email" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-rose-500 text-xs font-medium mt-1.5 pl-1 block"></span>
                </div>

                <div class="mb-6">
                    <div class="flex justify-between items-center mb-2 pl-1 pr-1">
                        <label asp-for="Password" class="block text-sm font-bold text-slate-700">Пароль</label>
                        <a asp-action="ForgotPassword" class="text-xs font-bold text-blue-600 hover:text-indigo-600 transition-colors">Забули пароль?</a>
                    </div>
                    <div class="relative">
                        <input asp-for="Password" id="passInput" class="w-full bg-white/70 border border-slate-200 text-slate-800 text-sm rounded-2xl focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 block px-4 py-3.5 transition-all outline-none shadow-sm placeholder:text-slate-400" type="password" placeholder="••••••••" />
                        <button class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 hover:text-blue-600 transition-colors" type="button" onclick="togglePass('passInput', 'passIcon')">
                            <i class="bi bi-eye-slash text-lg" id="passIcon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="text-rose-500 text-xs font-medium mt-1.5 pl-1 block"></span>
                </div>

                <div class="flex items-center mb-8 pl-1">
                    <div class="flex items-center h-5">
                        <input asp-for="RememberMe" class="w-4 h-4 border border-slate-300 rounded bg-white/70 focus:ring-3 focus:ring-blue-300 accent-blue-600 cursor-pointer" />
                    </div>
                    <label asp-for="RememberMe" class="ml-2 text-sm font-medium text-slate-600 cursor-pointer">Запам'ятати мене</label>
                </div>

                <div class="mb-4">
                    <button type="submit" class="w-full group relative inline-flex items-center justify-center px-8 py-4 font-black text-white transition-all duration-500 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-full shadow-[0_10px_20px_-10px_rgba(59,130,246,0.5)] hover:shadow-[0_15px_25px_-10px_rgba(59,130,246,0.6)] hover:-translate-y-0.5 uppercase tracking-widest text-xs overflow-hidden">
                        <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
                        <span class="relative">Увійти</span>
                    </button>
                </div>
            </form>

            <div class="flex items-center my-6">
                <div class="flex-1 border-t border-slate-200/60"></div>
                <span class="px-4 text-[10px] text-slate-400 font-black uppercase tracking-widest">Або</span>
                <div class="flex-1 border-t border-slate-200/60"></div>
            </div>

            <form asp-controller="Account" asp-action="ExternalLogin" method="post" class="form-horizontal">
                <button type="submit" name="provider" value="Google" class="w-full text-slate-700 bg-white/80 hover:bg-white border border-slate-200 focus:ring-4 focus:outline-none focus:ring-slate-100 font-bold rounded-full text-sm px-5 py-3.5 text-center shadow-sm hover:shadow transition-all flex items-center justify-center gap-3">
                    <img src="https://www.svgrepo.com/show/475656/google-color.svg" alt="Google" class="w-5 h-5" />
                    Увійти через Google
                </button>
            </form>

            <div class="text-center mt-8">
                <p class="text-sm font-medium text-slate-500">
                    Ще не зареєстровані? <a asp-action="Register" class="text-blue-600 hover:text-indigo-600 font-black tracking-wide transition-colors decoration-2 hover:underline underline-offset-4">Створити акаунт</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            }
        }
    </script>
}