@{
    ViewData["Title"] = "Перевірте пошту";
}

<style>
    @@keyframes slideUpFade {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    @@keyframes popIn {
        0% {
            transform: scale(0.5);
            opacity: 0;
        }

        70% {
            transform: scale(1.1);
            opacity: 1;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .animate-slide-up {
        animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .icon-pop {
        animation: popIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) 0.2s forwards;
        opacity: 0;
    }
</style>

<div class="relative w-full flex flex-col items-center justify-center min-h-[80vh] py-10 z-10 overflow-hidden">
    <div class="absolute top-10 right-1/4 w-[30rem] h-[30rem] bg-emerald-400/15 rounded-full blur-[100px] animate-pulse pointer-events-none translate-x-1/2"></div>
    <div class="absolute bottom-10 left-1/4 w-[35rem] h-[35rem] bg-blue-500/10 rounded-full blur-[120px] animate-pulse pointer-events-none -translate-x-1/4" style="animation-delay: 2s;"></div>

    <div class="w-full max-w-lg animate-slide-up z-20 px-4">
        <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[3rem] p-10 md:p-12 shadow-[0_20px_50px_-10px_rgba(0,0,0,0.1)] text-center relative overflow-hidden">

            <div class="absolute top-0 left-0 w-full h-32 bg-gradient-to-b from-emerald-50/50 to-transparent -z-10"></div>

            <div class="icon-pop relative inline-block mb-6">
                <div class="absolute inset-0 bg-emerald-400 rounded-full blur-xl opacity-20 animate-pulse"></div>
                <div class="relative w-24 h-24 bg-gradient-to-br from-emerald-100 to-white rounded-full border-4 border-white shadow-lg flex items-center justify-center mx-auto">
                    <i class="bi bi-envelope-check-fill text-5xl text-emerald-500 drop-shadow-sm" style="transform: translateY(2px);"></i>
                </div>
            </div>

            <h2 class="text-4xl font-black text-slate-800 tracking-tight mb-4">Лист відправлено!</h2>

            <div class="bg-white/50 border border-slate-100 rounded-2xl p-5 mb-8 shadow-inner">
                <p class="text-slate-500 font-medium text-[15px] leading-relaxed">
                    Будь ласка, перевірте вашу електронну пошту. Ми надіслали вам безпечне посилання для скидання пароля.
                </p>
                <div class="flex items-center justify-center gap-2 mt-3 text-xs font-bold text-amber-600 bg-amber-50 py-2 px-3 rounded-lg w-max mx-auto">
                    <i class="bi bi-info-circle-fill"></i> Не забудьте перевірити папку "Спам"
                </div>
            </div>

            <a asp-action="Login" class="inline-flex items-center justify-center px-8 py-3.5 bg-white hover:bg-slate-50 text-slate-700 font-bold rounded-full shadow-sm hover:shadow transition-all border border-slate-200 group">
                <i class="bi bi-arrow-left me-2 transition-transform group-hover:-translate-x-1 text-lg"></i>
                Повернутися до входу
            </a>

        </div>
    </div>
</div>