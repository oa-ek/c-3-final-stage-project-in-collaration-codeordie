@{
    ViewData["Title"] = "Перевірте пошту";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center mt-5">
        <div class="card shadow-sm border-0 p-5">
            <i class="bi bi-envelope-check text-success" style="font-size: 4rem;"></i>
            <h2 class="mt-3">Лист відправлено!</h2>
            <p class="text-muted mt-2">Будь ласка, перевірте вашу електронну пошту (включаючи папку Спам). Ми надіслали вам посилання для скидання пароля.</p>

            <a asp-action="Login" class="btn btn-outline-primary mt-4">Повернутися до входу</a>
        </div>
    </div>
</div>