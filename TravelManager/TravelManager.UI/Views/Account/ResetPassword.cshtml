@model TravelManager.UI.Models.ViewModels.Account.ResetPasswordViewModel
@{
    ViewData["Title"] = "Скидання пароля";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm mt-5">
            <div class="card-body p-5">
                <h3 class="text-center mb-4">Створення нового пароля</h3>

                <form asp-action="ResetPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <!-- Приховані поля для Токена та Email (дуже важливо, без них скидання не спрацює!) -->
                    <input asp-for="Token" type="hidden" />
                    <input asp-for="Email" type="hidden" />

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <!-- Показуємо Email, але не даємо його змінити -->
                        <input class="form-control bg-light" value="@Model.Email" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Новий пароль</label>
                        <div class="input-group">
                            <input asp-for="Password" id="passInput" class="form-control" type="password" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePass('passInput', 'passIcon')">
                                <i class="bi bi-eye-slash" id="passIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label">Підтвердіть пароль</label>
                        <div class="input-group">
                            <input asp-for="ConfirmPassword" id="confirmInput" class="form-control" type="password" />
                            <button class="btn btn-outline-secondary" type="button" onclick="togglePass('confirmInput', 'confirmIcon')">
                                <i class="bi bi-eye-slash" id="confirmIcon"></i>
                            </button>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>

                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-success btn-lg">Зберегти пароль</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            }
        }
    </script>
}