@model TravelManager.UI.Models.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "Зміна пароля";
}

<div class="container mt-4">
    <div class="row">
        <!-- Бокове меню -->
        <div class="col-md-3 mb-4">
            <div class="list-group shadow-sm">
                <!-- ВАЖЛИВО: Вказуємо asp-controller="Account" -->
                <a asp-controller="Account" asp-action="Profile" class="list-group-item list-group-item-action">
                    <i class="bi bi-person-circle me-2"></i> Особисті дані
                </a>
                <a asp-controller="Account" asp-action="ChangePassword" class="list-group-item list-group-item-action active" aria-current="true">
                    <i class="bi bi-shield-lock me-2"></i> Зміна пароля
                </a>
            </div>
        </div>

        <!-- Основний контент -->
        <div class="col-md-9">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h3 class="mb-4">Зміна пароля</h3>

                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill me-2"></i> @TempData["StatusMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label">Поточний пароль</label>
                            <div class="input-group">
                                <input asp-for="CurrentPassword" id="currentPass" type="password" class="form-control" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePass('currentPass', 'iconCurrent')">
                                    <i class="bi bi-eye-slash" id="iconCurrent"></i>
                                </button>
                            </div>
                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">Новий пароль</label>
                            <div class="input-group">
                                <input asp-for="NewPassword" id="newPass" type="password" class="form-control" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePass('newPass', 'iconNew')">
                                    <i class="bi bi-eye-slash" id="iconNew"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmNewPassword" class="form-label">Підтвердіть новий пароль</label>
                            <div class="input-group">
                                <input asp-for="ConfirmNewPassword" id="confirmPass" type="password" class="form-control" />
                                <button class="btn btn-outline-secondary" type="button" onclick="togglePass('confirmPass', 'iconConfirm')">
                                    <i class="bi bi-eye-slash" id="iconConfirm"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-key me-1"></i> Оновити пароль
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            }
        }
    </script>
}