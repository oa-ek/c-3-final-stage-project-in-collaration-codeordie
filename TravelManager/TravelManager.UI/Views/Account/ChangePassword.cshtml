@model TravelManager.UI.Models.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "Зміна пароля";
}

<style>
    @@keyframes slideUpFade {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .animate-slide-up {
        animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }
</style>

<div class="relative w-full min-h-[80vh] py-10 z-10 overflow-hidden">
    <!-- Розмиті фонові плями (Blobs) -->
    <div class="absolute top-10 left-1/4 w-[30rem] h-[30rem] bg-indigo-400/10 rounded-full blur-[100px] animate-pulse pointer-events-none -translate-x-1/2"></div>
    <div class="absolute bottom-10 right-1/4 w-[35rem] h-[35rem] bg-blue-500/10 rounded-full blur-[120px] animate-pulse pointer-events-none translate-x-1/4" style="animation-delay: 2s;"></div>

    <div class="max-w-6xl mx-auto px-4 z-20 relative animate-slide-up">

        <div class="flex flex-col md:flex-row gap-6 md:gap-8">

            <!-- Бокове меню (Sidebar) -->
            <div class="w-full md:w-1/3 lg:w-1/4">
                <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2rem] p-4 shadow-[0_15px_40px_-10px_rgba(0,0,0,0.05)] flex flex-col gap-2">
                    <a asp-controller="Account" asp-action="Profile" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-600 hover:bg-white hover:text-blue-600 transition-all font-bold text-sm">
                        <i class="bi bi-person-circle text-lg"></i> Особисті дані
                    </a>
                    <a asp-controller="Account" asp-action="ChangePassword" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-blue-600 text-white shadow-md transition-all font-bold text-sm">
                        <i class="bi bi-shield-lock text-lg"></i> Зміна пароля
                    </a>
                </div>
            </div>

            <!-- Основний контент -->
            <div class="w-full md:w-2/3 lg:w-3/4">
                <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2.5rem] p-8 shadow-[0_15px_40px_-10px_rgba(0,0,0,0.05)]">

                    <div class="flex items-center gap-4 mb-8">
                        <div class="w-12 h-12 bg-gradient-to-br from-blue-100 to-white rounded-2xl border border-blue-100 flex items-center justify-center shadow-sm">
                            <i class="bi bi-shield-lock-fill text-2xl text-blue-600 drop-shadow-sm"></i>
                        </div>
                        <h3 class="text-3xl font-black text-slate-800 tracking-tight m-0">Зміна пароля</h3>
                    </div>

                    <!-- Сповіщення про успіх -->
                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="alert alert-dismissible fade show text-emerald-600 mb-6 p-4 bg-emerald-50/80 backdrop-blur-sm rounded-2xl text-sm font-medium border border-emerald-100 shadow-sm flex items-center" role="alert">
                            <i class="bi bi-check-circle-fill text-lg me-3"></i>
                            <div>@TempData["StatusMessage"]</div>
                            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-action="ChangePassword" method="post">
                        <!-- Загальні помилки форми -->
                        <div asp-validation-summary="ModelOnly" class="text-rose-500 mb-5 p-4 bg-rose-50/80 backdrop-blur-sm rounded-2xl text-sm font-medium border border-rose-100"></div>

                        <!-- ЛОГІКА ПЕРЕВІРКИ: ЧИ Є ВЖЕ ПАРОЛЬ? -->
                        @if (ViewBag.HasPassword == true)
                        {
                            <div class="mb-5">
                                <label asp-for="CurrentPassword" class="block text-sm font-bold text-slate-700 mb-2 pl-1">Поточний пароль</label>
                                <div class="relative">
                                    <input asp-for="CurrentPassword" id="currentPass" type="password" class="w-full bg-white/70 border border-slate-200 text-slate-800 text-sm rounded-2xl focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 block px-4 py-3.5 transition-all outline-none shadow-sm placeholder:text-slate-400" />
                                    <button class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 hover:text-blue-600 transition-colors" type="button" onclick="togglePass('currentPass', 'iconCurrent')">
                                        <i class="bi bi-eye-slash text-lg" id="iconCurrent"></i>
                                    </button>
                                </div>
                                <span asp-validation-for="CurrentPassword" class="text-rose-500 text-xs font-medium mt-1.5 pl-1 block"></span>
                            </div>
                        }
                        else
                        {
                            <div class="text-indigo-700 mb-6 p-5 bg-indigo-50/80 backdrop-blur-sm rounded-2xl text-sm font-medium border border-indigo-100 shadow-sm flex items-start">
                                <i class="bi bi-info-circle-fill text-xl me-3 mt-0.5"></i>
                                <div>
                                    <strong class="block mb-1 text-base">Ви увійшли через Google!</strong>
                                    У вас ще немає локального пароля. Встановіть його нижче, щоб мати можливість входити як через Google, так і традиційно — за допомогою Email та Пароля.
                                </div>
                            </div>
                        }

                        <div class="mb-5">
                            <label asp-for="NewPassword" class="block text-sm font-bold text-slate-700 mb-2 pl-1">Новий пароль</label>
                            <div class="relative">
                                <input asp-for="NewPassword" id="newPass" type="password" class="w-full bg-white/70 border border-slate-200 text-slate-800 text-sm rounded-2xl focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 block px-4 py-3.5 transition-all outline-none shadow-sm placeholder:text-slate-400" />
                                <button class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 hover:text-blue-600 transition-colors" type="button" onclick="togglePass('newPass', 'iconNew')">
                                    <i class="bi bi-eye-slash text-lg" id="iconNew"></i>
                                </button>
                            </div>
                            <span asp-validation-for="NewPassword" class="text-rose-500 text-xs font-medium mt-1.5 pl-1 block"></span>
                        </div>

                        <div class="mb-8">
                            <label asp-for="ConfirmNewPassword" class="block text-sm font-bold text-slate-700 mb-2 pl-1">Підтвердіть новий пароль</label>
                            <div class="relative">
                                <input asp-for="ConfirmNewPassword" id="confirmPass" type="password" class="w-full bg-white/70 border border-slate-200 text-slate-800 text-sm rounded-2xl focus:ring-4 focus:ring-blue-500/20 focus:border-blue-500 block px-4 py-3.5 transition-all outline-none shadow-sm placeholder:text-slate-400" />
                                <button class="absolute inset-y-0 right-0 flex items-center pr-4 text-slate-400 hover:text-blue-600 transition-colors" type="button" onclick="togglePass('confirmPass', 'iconConfirm')">
                                    <i class="bi bi-eye-slash text-lg" id="iconConfirm"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmNewPassword" class="text-rose-500 text-xs font-medium mt-1.5 pl-1 block"></span>
                        </div>

                        <div>
                            <button type="submit" class="group relative inline-flex items-center justify-center px-8 py-3.5 font-black text-white transition-all duration-500 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl shadow-[0_10px_20px_-10px_rgba(59,130,246,0.5)] hover:shadow-[0_15px_25px_-10px_rgba(59,130,246,0.6)] hover:-translate-y-0.5 uppercase tracking-widest text-xs overflow-hidden">
                                <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
                                <span class="relative flex items-center gap-2">
                                    <i class="bi bi-key-fill text-sm"></i> @(ViewBag.HasPassword == true ? "Оновити пароль" : "Встановити пароль")
                                </span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.replace("bi-eye-slash", "bi-eye");
            } else {
                input.type = "password";
                icon.classList.replace("bi-eye", "bi-eye-slash");
            }
        }
    </script>
}