

@model TravelManager.UI.Models.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "Зміна пароля";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    .profile-root {
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
        padding: 2rem 1rem 4rem;
        position: relative;
    }

        /* Живий фон */
        .profile-root::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse 80% 60% at 10% 20%, rgba(99,102,241,0.12) 0%, transparent 60%), radial-gradient(ellipse 60% 80% at 90% 80%, rgba(236,72,153,0.10) 0%, transparent 60%), radial-gradient(ellipse 50% 50% at 50% 50%, rgba(16,185,129,0.06) 0%, transparent 70%);
            z-index: -1;
            animation: bgShift 12s ease-in-out infinite alternate;
        }

    @@keyframes bgShift {
        0% {
            filter: hue-rotate(0deg) brightness(1);
        }

        100% {
            filter: hue-rotate(25deg) brightness(1.03);
        }
    }

    /* Blob-и */
    .blob {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.18;
        z-index: -1;
        animation: blobFloat linear infinite;
        pointer-events: none;
    }

    .blob-1 {
        width: 500px;
        height: 500px;
        background: #6366f1;
        top: -100px;
        left: -100px;
        animation-duration: 20s;
    }

    .blob-2 {
        width: 400px;
        height: 400px;
        background: #ec4899;
        bottom: -80px;
        right: -80px;
        animation-duration: 25s;
        animation-direction: reverse;
    }

    .blob-3 {
        width: 300px;
        height: 300px;
        background: #10b981;
        top: 40%;
        left: 60%;
        animation-duration: 18s;
    }

    @@keyframes blobFloat {
        0% {
            transform: translate(0,0) scale(1);
        }

        33% {
            transform: translate(40px,-30px) scale(1.05);
        }

        66% {
            transform: translate(-20px,40px) scale(0.95);
        }

        100% {
            transform: translate(0,0) scale(1);
        }
    }

    /* Stagger-появи */
    .reveal {
        opacity: 0;
        transform: translateY(24px);
        animation: revealUp 0.65s cubic-bezier(.16,1,.3,1) forwards;
    }

    @@keyframes revealUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .delay-1 {
        animation-delay: 0.05s;
    }

    .delay-2 {
        animation-delay: 0.15s;
    }

    .delay-3 {
        animation-delay: 0.25s;
    }

    .delay-4 {
        animation-delay: 0.35s;
    }

    .delay-5 {
        animation-delay: 0.45s;
    }

    .delay-6 {
        animation-delay: 0.55s;
    }

    /* Сайдбар */
    .sidebar {
        background: rgba(255,255,255,0.55);
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,0.9);
        border-radius: 2rem;
        padding: 1.5rem 1rem;
        box-shadow: 0 8px 40px rgba(99,102,241,0.08);
        transition: box-shadow 0.3s ease;
    }

        .sidebar:hover {
            box-shadow: 0 12px 50px rgba(99,102,241,0.13);
        }

    .sidebar-label {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #94a3b8;
        padding: 0 0.75rem;
        margin-bottom: 0.5rem;
    }

    .s-link {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.8rem 1rem;
        border-radius: 1.2rem;
        font-weight: 600;
        font-size: 0.875rem;
        color: #64748b;
        text-decoration: none;
        transition: all 0.25s cubic-bezier(.4,0,.2,1);
        position: relative;
        overflow: hidden;
    }

        .s-link::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            opacity: 0;
            transition: opacity 0.25s ease;
            border-radius: 1.2rem;
        }

        .s-link span, .s-link i {
            position: relative;
            z-index: 1;
        }

        .s-link:hover {
            color: #4f46e5;
            transform: translateX(5px);
        }

            .s-link:hover::before {
                opacity: 0.08;
            }

        .s-link.active {
            color: white;
            box-shadow: 0 4px 20px rgba(99,102,241,0.4);
        }

            .s-link.active::before {
                opacity: 1;
            }

    /* Головна картка */
    .main-card {
        background: rgba(255,255,255,0.60);
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,0.9);
        border-radius: 2.5rem;
        box-shadow: 0 8px 50px rgba(99,102,241,0.08);
        overflow: hidden;
        transition: box-shadow 0.4s ease;
    }

        .main-card:hover {
            box-shadow: 0 16px 60px rgba(99,102,241,0.13);
        }

    /* Hero — червоно-фіолетовий для пароля */
    .card-hero {
        background: linear-gradient(135deg, #7c3aed 0%, #6366f1 40%, #0ea5e9 100%);
        background-size: 200% 200%;
        animation: heroGradient 6s ease infinite;
        padding: 2.5rem 2.5rem 3rem;
        position: relative;
        overflow: hidden;
    }

    @@keyframes heroGradient {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    .hero-pattern {
        position: absolute;
        inset: 0;
        background-image: radial-gradient(circle at 20% 50%, rgba(255,255,255,0.12) 1px, transparent 1px), radial-gradient(circle at 80% 20%, rgba(255,255,255,0.12) 1px, transparent 1px), radial-gradient(circle at 60% 80%, rgba(255,255,255,0.08) 1px, transparent 1px);
        background-size: 40px 40px, 35px 35px, 50px 50px;
        animation: patternDrift 20s linear infinite;
    }

    @@keyframes patternDrift {
        from {
            background-position: 0 0, 0 0, 0 0;
        }

        to {
            background-position: 40px 40px, -35px 35px, 50px -50px;
        }
    }

    /* Іконка замка у hero */
    .hero-lock {
        width: 64px;
        height: 64px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(10px);
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 1.2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.8rem;
        color: white;
        margin-bottom: 1rem;
        position: relative;
        z-index: 1;
        animation: lockBounce 0.7s cubic-bezier(.34,1.56,.64,1) 0.3s both;
        transition: transform 0.3s cubic-bezier(.34,1.56,.64,1);
    }

        .hero-lock:hover {
            transform: rotate(-8deg) scale(1.1);
        }

    @@keyframes lockBounce {
        from {
            transform: scale(0.3) rotate(-20deg);
            opacity: 0;
        }

        to {
            transform: scale(1) rotate(0deg);
            opacity: 1;
        }
    }

    .hero-title {
        font-family: 'Syne', sans-serif;
        font-size: 1.6rem;
        font-weight: 900;
        color: white;
        position: relative;
        z-index: 1;
        text-shadow: 0 2px 20px rgba(0,0,0,0.15);
    }

    .hero-sub {
        color: rgba(255,255,255,0.78);
        font-size: 0.85rem;
        font-weight: 500;
        position: relative;
        z-index: 1;
        margin-top: 0.25rem;
    }

    /* Форма */
    .form-body {
        padding: 2rem 2rem 2.5rem;
    }

    /* Поля пароля */
    .field-wrap {
        background: rgba(248,250,252,0.9);
        border: 1.5px solid rgba(226,232,240,0.8);
        border-radius: 1.2rem;
        padding: 0.9rem 1.1rem;
        transition: all 0.3s cubic-bezier(.4,0,.2,1);
        position: relative;
        overflow: hidden;
        margin-bottom: 1rem;
    }

        .field-wrap::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 3px;
            background: linear-gradient(180deg, #7c3aed, #0ea5e9);
            opacity: 0;
            transition: opacity 0.3s ease;
            border-radius: 3px 0 0 3px;
        }

        .field-wrap:focus-within {
            background: white;
            border-color: rgba(124,58,237,0.4);
            box-shadow: 0 0 0 4px rgba(124,58,237,0.09), 0 4px 20px rgba(124,58,237,0.08);
            transform: translateY(-3px);
        }

            .field-wrap:focus-within::before {
                opacity: 1;
            }

    .field-label {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.4rem;
        display: block;
        transition: color 0.2s ease;
    }

    .field-wrap:focus-within .field-label {
        color: #7c3aed;
    }

    .field-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .field-input {
        border: none !important;
        background: transparent !important;
        padding: 0 !important;
        font-weight: 600;
        color: #1e293b;
        font-size: 0.95rem;
        width: 100%;
        outline: none !important;
        box-shadow: none !important;
        font-family: 'DM Sans', sans-serif;
    }

    /* Кнопка показати/сховати пароль */
    .toggle-pass {
        background: none;
        border: none;
        cursor: pointer;
        color: #94a3b8;
        font-size: 1rem;
        padding: 0;
        line-height: 1;
        transition: all 0.25s cubic-bezier(.34,1.56,.64,1);
        flex-shrink: 0;
    }

        .toggle-pass:hover {
            color: #7c3aed;
            transform: scale(1.2);
        }

    /* Індикатор сили пароля */
    .strength-bar-wrap {
        margin-top: 0.6rem;
    }

    .strength-bars {
        display: flex;
        gap: 4px;
        margin-bottom: 0.3rem;
    }

    .strength-bar {
        height: 4px;
        flex: 1;
        border-radius: 2px;
        background: #e2e8f0;
        transition: background 0.4s ease, transform 0.3s ease;
    }

        .strength-bar.active {
            transform: scaleY(1.5);
        }

        .strength-bar.weak {
            background: #ef4444;
        }

        .strength-bar.medium {
            background: #f59e0b;
        }

        .strength-bar.strong {
            background: #10b981;
        }

    .strength-label {
        font-size: 0.7rem;
        font-weight: 700;
        color: #94a3b8;
        transition: color 0.3s ease;
    }

    /* Кнопка */
    .save-btn {
        background: linear-gradient(135deg, #7c3aed, #6366f1, #0ea5e9);
        background-size: 200% 200%;
        color: white;
        border: none;
        border-radius: 1.2rem;
        padding: 0.9rem 2.5rem;
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 0.95rem;
        letter-spacing: 0.02em;
        cursor: pointer;
        transition: all 0.35s cubic-bezier(.34,1.56,.64,1);
        box-shadow: 0 4px 20px rgba(124,58,237,0.4);
        position: relative;
        overflow: hidden;
        animation: heroGradient 4s ease infinite;
    }

        .save-btn::after {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 60%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
            animation: btnShimmer 3s ease-in-out infinite;
        }

    @@keyframes btnShimmer {
        0% {
            left: -100%;
        }

        50% {
            left: 150%;
        }

        100% {
            left: 150%;
        }
    }

    .save-btn:hover {
        transform: translateY(-4px) scale(1.04);
        box-shadow: 0 10px 35px rgba(124,58,237,0.55);
        color: white;
    }

    .save-btn:active {
        transform: scale(0.96);
    }

    /* Toast успіху */
    .success-toast {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        background: linear-gradient(135deg, rgba(16,185,129,0.1), rgba(5,150,105,0.07));
        border: 1px solid rgba(16,185,129,0.25);
        border-radius: 1rem;
        padding: 0.9rem 1.2rem;
        margin-bottom: 1.5rem;
        font-weight: 600;
        color: #065f46;
        font-size: 0.875rem;
        animation: toastIn 0.6s cubic-bezier(.34,1.56,.64,1);
    }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateY(-12px) scale(0.95);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .toast-icon {
        font-size: 1.2rem;
        color: #10b981;
        animation: checkPop 0.5s cubic-bezier(.34,1.56,.64,1) 0.2s both;
    }

    @@keyframes checkPop {
        from {
            transform: scale(0) rotate(-30deg);
        }

        to {
            transform: scale(1) rotate(0deg);
        }
    }

    /* Заголовок сторінки */
    .page-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2rem, 5vw, 3.5rem);
        font-weight: 900;
        color: #0f172a;
        line-height: 1;
        letter-spacing: -0.03em;
    }

        .page-title span {
            background: linear-gradient(135deg, #7c3aed, #0ea5e9);
            background-size: 200% 200%;
            animation: heroGradient 5s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
</style>

<div class="blob blob-1"></div>
<div class="blob blob-2"></div>
<div class="blob blob-3"></div>

<div class="profile-root">
    <div style="max-width:1000px; margin:0 auto;">

        @* Заголовок *@
        <div class="reveal delay-1" style="margin-bottom:2.5rem;">
            <h1 class="page-title">Зміна <span>пароля</span></h1>
            <p style="color:#64748b;font-weight:500;margin-top:0.5rem;">Оновлюй пароль регулярно для захисту акаунту</p>
        </div>

        <div style="display:flex;gap:1.5rem;align-items:flex-start;flex-wrap:wrap;">

            @* Сайдбар *@
            <div class="sidebar reveal delay-2" style="width:200px;flex-shrink:0;">
                <p class="sidebar-label">Акаунт</p>
                <a asp-controller="Account" asp-action="Profile" class="s-link">
                    <i class="bi bi-person-fill"></i><span>Особисті дані</span>
                </a>
                <a asp-controller="Account" asp-action="ChangePassword" class="s-link active">
                    <i class="bi bi-shield-lock-fill"></i><span>Пароль</span>
                </a>
            </div>

            @* Головна картка *@
            <div class="main-card reveal delay-3" style="flex:1;min-width:300px;">

                <div class="card-hero">
                    <div class="hero-pattern"></div>
                    <div class="hero-lock"><i class="bi bi-shield-lock-fill"></i></div>
                    <div class="hero-title">Зміна пароля</div>
                    <div class="hero-sub">Використовуй надійний пароль для захисту акаунту</div>
                </div>

                <div class="form-body">

                    @if (TempData["StatusMessage"] != null)
                    {
                        <div class="success-toast">
                            <i class="bi bi-check-circle-fill toast-icon"></i>
                            @TempData["StatusMessage"]
                        </div>
                    }

                    <form asp-action="ChangePassword" method="post">
                        <div asp-validation-summary="ModelOnly" style="color:#ef4444;font-size:0.85rem;font-weight:600;margin-bottom:1rem;"></div>

                        @* Поточний пароль *@
                        <div class="field-wrap reveal delay-3">
                            <label class="field-label">Поточний пароль</label>
                            <div class="field-row">
                                <input asp-for="CurrentPassword" id="currentPass" type="password" class="field-input" placeholder="••••••••" />
                                <button type="button" class="toggle-pass" onclick="togglePass('currentPass', 'iconCurrent')">
                                    <i class="bi bi-eye-slash" id="iconCurrent"></i>
                                </button>
                            </div>
                            <span asp-validation-for="CurrentPassword" style="color:#ef4444;font-size:0.75rem;font-weight:600;"></span>
                        </div>

                        @* Новий пароль + індикатор сили *@
                        <div class="field-wrap reveal delay-4">
                            <label class="field-label">Новий пароль</label>
                            <div class="field-row">
                                <input asp-for="NewPassword" id="newPass" type="password" class="field-input"
                                       placeholder="••••••••" oninput="checkStrength(this.value)" />
                                <button type="button" class="toggle-pass" onclick="togglePass('newPass', 'iconNew')">
                                    <i class="bi bi-eye-slash" id="iconNew"></i>
                                </button>
                            </div>
                            <div class="strength-bar-wrap">
                                <div class="strength-bars">
                                    <div class="strength-bar" id="bar1"></div>
                                    <div class="strength-bar" id="bar2"></div>
                                    <div class="strength-bar" id="bar3"></div>
                                    <div class="strength-bar" id="bar4"></div>
                                </div>
                                <span class="strength-label" id="strengthLabel">Введи пароль</span>
                            </div>
                            <span asp-validation-for="NewPassword" style="color:#ef4444;font-size:0.75rem;font-weight:600;"></span>
                        </div>

                        @* Підтвердження *@
                        <div class="field-wrap reveal delay-5">
                            <label class="field-label">Підтвердіть новий пароль</label>
                            <div class="field-row">
                                <input asp-for="ConfirmNewPassword" id="confirmPass" type="password" class="field-input" placeholder="••••••••" />
                                <button type="button" class="toggle-pass" onclick="togglePass('confirmPass', 'iconConfirm')">
                                    <i class="bi bi-eye-slash" id="iconConfirm"></i>
                                </button>
                            </div>
                            <span asp-validation-for="ConfirmNewPassword" style="color:#ef4444;font-size:0.75rem;font-weight:600;"></span>
                        </div>

                        <div style="display:flex;justify-content:flex-end;margin-top:1.75rem;" class="reveal delay-6">
                            <button type="submit" class="save-btn">
                                <i class="bi bi-key-fill" style="margin-right:0.5rem;"></i> Оновити пароль
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.classList.replace('bi-eye-slash', 'bi-eye');
            } else {
                input.type = 'password';
                icon.classList.replace('bi-eye', 'bi-eye-slash');
            }
        }

        function checkStrength(val) {
            const bars   = [1,2,3,4].map(i => document.getElementById('bar' + i));
            const label  = document.getElementById('strengthLabel');
            const levels = ['weak','medium','medium','strong'];
            const colors = { weak: '#ef4444', medium: '#f59e0b', strong: '#10b981' };

            let score = 0;
            if (val.length >= 6)  score++;
            if (val.length >= 10) score++;
            if (/[A-Z]/.test(val) && /[0-9]/.test(val)) score++;
            if (/[^A-Za-z0-9]/.test(val)) score++;

            const texts  = ['', 'Слабкий', 'Середній', 'Добрий', 'Надійний'];
            const lvl    = score === 0 ? 'weak' : score <= 1 ? 'weak' : score <= 2 ? 'medium' : 'strong';

            bars.forEach((b, i) => {
                b.className = 'strength-bar';
                if (i < score) { b.classList.add(levels[i] || 'strong', 'active'); }
            });

            label.textContent = val.length === 0 ? 'Введи пароль' : texts[score] || 'Надійний';
            label.style.color = val.length === 0 ? '#94a3b8' : colors[lvl];
        }
    </script>
}