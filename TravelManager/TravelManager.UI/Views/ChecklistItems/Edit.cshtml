@model TravelManager.UI.Models.ViewModels.ChecklistItemFormViewModel

@{
    ViewData["Title"] = "Редагувати річ";
}

<div class="container py-4">
    <h2 class="mb-4">Редагувати річ у списку</h2>
    <hr />

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-3">
                            <label asp-for="ChecklistId" class="form-label fw-bold"></label>
                            <select asp-for="ChecklistId" asp-items="Model.ChecklistList" class="form-select"></select>
                            <span asp-validation-for="ChecklistId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Content" class="form-label fw-bold"></label>
                            <input asp-for="Content" class="form-control" />
                            <span asp-validation-for="Content" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IsChecked" class="form-check-input" type="checkbox" />
                            <label asp-for="IsChecked" class="form-check-label fw-bold"></label>
                        </div>

                        <div class="form-group d-flex justify-content-between">
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">Оновити</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}