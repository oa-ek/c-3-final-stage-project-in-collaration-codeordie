@model IEnumerable<TravelManager.UI.Models.ViewModels.ChecklistItemListViewModel>

@{
    ViewData["Title"] = "Вміст списків";
}

<style>
    @@keyframes fadeSlideUp {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .stagger-item {
        animation: fadeSlideUp 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }

    @@keyframes shimmer {
        0% {
            transform: translateX(-100%) skewX(-15deg);
        }

        100% {
            transform: translateX(200%) skewX(-15deg);
        }
    }
</style>

<div class="relative w-full max-w-6xl mx-auto min-h-[85vh] py-12 z-10 px-4">

    <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-0">
        <div class="absolute top-0 right-10 w-[20rem] h-[20rem] bg-cyan-300/20 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-20 left-10 w-[25rem] h-[25rem] bg-blue-300/20 rounded-full blur-[120px]"></div>
    </div>

    <div class="relative z-20 flex flex-col md:flex-row justify-between items-start md:items-end mb-12 stagger-item" style="animation-delay: 0.1s;">
        <div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur-md border border-white shadow-sm mb-4">
                <i class="bi bi-box-seam-fill text-cyan-500 text-sm"></i>
                <span class="text-xs font-black text-slate-500 uppercase tracking-widest">Глобальний багаж</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-black text-slate-800 tracking-tighter drop-shadow-sm leading-none">
                Усі речі
            </h1>
        </div>

        <a asp-action="Create" class="mt-8 md:mt-0 group relative inline-flex items-center justify-center px-8 py-4 font-black text-white transition-all duration-300 bg-slate-900 rounded-full shadow-[0_10px_20px_-5px_rgba(0,0,0,0.3)] hover:-translate-y-1 uppercase tracking-widest text-xs overflow-hidden">
            <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
            <span class="relative flex items-center gap-3">
                Додати річ <i class="bi bi-plus-lg text-lg group-hover:rotate-90 transition-transform duration-300"></i>
            </span>
        </a>
    </div>

    <div class="relative z-20 space-y-4">
        @if (!Model.Any())
        {
            <div class="bg-white/40 backdrop-blur-3xl border border-white/80 rounded-[3rem] p-16 text-center shadow-sm stagger-item max-w-2xl mx-auto" style="animation-delay: 0.2s;">
                <div class="w-24 h-24 bg-slate-50 rounded-[2rem] flex items-center justify-center mx-auto mb-6 border border-white shadow-inner">
                    <i class="bi bi-wind text-5xl text-slate-300"></i>
                </div>
                <h3 class="text-3xl font-black text-slate-700 tracking-tight mb-2">Пусто...</h3>
                <p class="text-slate-500 text-lg font-medium">Ваші списки ще не мають жодної речі.</p>
            </div>
        }
        else
        {
            var delay = 0.2m;
            foreach (var item in Model)
            {
                <div class="group bg-white/60 backdrop-blur-2xl border border-white/80 rounded-2xl p-4 shadow-sm hover:shadow-[0_10px_30px_-10px_rgba(6,182,212,0.2)] hover:bg-white/90 transition-all duration-300 hover:-translate-y-1 flex flex-col md:flex-row items-start md:items-center justify-between gap-4 stagger-item" style="animation-delay: @(delay.ToString(System.Globalization.CultureInfo.InvariantCulture))s;">

                    <div class="flex items-center gap-4 w-full md:w-auto">
                        @if (item.IsChecked)
                        {
                            <div class="w-12 h-12 shrink-0 bg-emerald-100 rounded-xl flex items-center justify-center border border-emerald-200 shadow-inner">
                                <i class="bi bi-check-lg text-emerald-500 text-xl font-black"></i>
                            </div>
                        }
                        else
                        {
                            <div class="w-12 h-12 shrink-0 bg-blue-50 rounded-xl flex items-center justify-center border border-blue-100 shadow-inner group-hover:bg-blue-100 transition-colors">
                                <i class="bi bi-circle text-blue-300 text-lg"></i>
                            </div>
                        }

                        <div class="flex flex-col">
                            <span class="text-lg font-black @(item.IsChecked ? "text-slate-400 line-through decoration-emerald-500/50 decoration-2" : "text-slate-800") tracking-tight leading-tight">
                                @item.Content
                            </span>
                            <div class="flex items-center gap-2 mt-1">
                                <span class="bg-white/60 px-2.5 py-1 rounded-md border border-slate-100 text-[10px] font-bold text-slate-500 uppercase tracking-widest flex items-center gap-1.5">
                                    <i class="bi bi-list-check text-cyan-500"></i> @item.ChecklistName
                                </span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-2 mt-2 md:mt-0 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-blue-600 hover:border-blue-200 transition-all shadow-sm hover:scale-105" title="Редагувати">
                            <i class="bi bi-pencil-fill text-sm"></i>
                        </a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0" onsubmit="return confirm('Видалити цю річ?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="w-10 h-10 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-rose-600 hover:bg-rose-50 hover:border-rose-200 transition-all shadow-sm hover:scale-105" title="Видалити">
                                <i class="bi bi-trash3-fill text-sm"></i>
                            </button>
                        </form>
                    </div>
                </div>
                delay += 0.05m;
            }
        }
    </div>
</div>