@model TravelManager.UI.Models.ViewModels.ChecklistItemFormViewModel

@{
    ViewData["Title"] = "Додати річ";
}

<style>
    @@keyframes fadeSlideUp {
        0% {
            opacity: 0;
            transform: translateY(40px) scale(0.95);
        }

        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .stagger-item {
        animation: fadeSlideUp 0.8s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        opacity: 0;
    }

    @@keyframes blob {
        0% {
            transform: translate(0px, 0px) scale(1);
        }

        50% {
            transform: translate(30px, -50px) scale(1.1);
        }

        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    .animate-blob {
        animation: blob 8s infinite alternate;
    }

    @@keyframes shimmer {
        0% {
            transform: translateX(-100%) skewX(-15deg);
        }

        100% {
            transform: translateX(200%) skewX(-15deg);
        }
    }

    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(6, 182, 212, 0.4);
        border-radius: 10px;
    }
</style>

<div class="relative w-full max-w-4xl mx-auto min-h-[85vh] py-12 z-10 px-4 flex flex-col justify-center overflow-hidden">
    <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-0">
        <div class="absolute top-10 left-10 w-72 h-72 bg-cyan-400/20 rounded-full mix-blend-multiply blur-3xl animate-blob"></div>
        <div class="absolute bottom-10 right-10 w-72 h-72 bg-blue-400/20 rounded-full mix-blend-multiply blur-3xl animate-blob" style="animation-delay: 2s;"></div>
    </div>

    <div class="relative z-20 mb-10 text-center stagger-item" style="animation-delay: 0.1s;">
        <div class="inline-flex items-center gap-3 px-5 py-2.5 rounded-full bg-white/70 backdrop-blur-xl border border-white/80 shadow-[0_8px_30px_rgb(0,0,0,0.04)] mb-6">
            <i class="bi bi-bag-plus text-cyan-500 text-lg"></i>
            <span class="text-xs font-black text-slate-600 uppercase tracking-widest">Збираємо валізу</span>
        </div>
        <h1 class="text-5xl md:text-7xl font-black text-transparent bg-clip-text bg-gradient-to-r from-slate-800 via-cyan-800 to-blue-900 tracking-tighter pb-2">Що беремо з собою? 🧦</h1>
    </div>

    <div class="relative z-20 bg-white/40 backdrop-blur-[40px] border border-white/60 rounded-[3rem] p-8 md:p-14 shadow-2xl stagger-item" style="animation-delay: 0.2s;">
        <form asp-action="Create" method="post" class="relative z-10">
            <div asp-validation-summary="ModelOnly" class="text-rose-600 mb-8 text-sm font-bold text-center bg-rose-100/50 rounded-2xl py-4"></div>

            <div class="grid grid-cols-1 gap-8">
                <div class="flex flex-col group relative z-50">
                    <label class="text-[11px] font-black uppercase tracking-widest text-slate-500 mb-2 pl-4 flex items-center gap-2 group-focus-within:text-cyan-600 transition-colors"><i class="bi bi-card-checklist text-lg"></i> До якого списку додаємо?</label>

                    <select asp-for="ChecklistId" asp-items="Model.ChecklistList" class="sr-only pointer-events-none real-select" tabindex="-1"></select>

                    <div class="relative custom-dropdown w-full">
                        <button type="button" class="w-full bg-white/50 border-2 border-white/60 rounded-3xl py-5 pl-6 pr-6 text-lg font-bold text-slate-700 outline-none hover:bg-white/80 transition-all shadow-inner flex justify-between items-center" onclick="toggleDropdown(this)">
                            <span class="selected-text text-slate-400">-- Оберіть список --</span>
                            <i class="bi bi-chevron-down transition-transform duration-300 text-slate-400"></i>
                        </button>
                        <div class="dropdown-menu absolute left-0 right-0 mt-2 bg-white/90 backdrop-blur-[40px] border border-white/80 rounded-3xl shadow-xl opacity-0 invisible translate-y-4 transition-all duration-300 overflow-hidden">
                            <ul class="max-h-56 overflow-y-auto py-2 custom-scrollbar">
                                <li class="px-6 py-3 text-slate-400 text-sm font-bold cursor-pointer hover:bg-slate-100/50" onclick="selectItem(this, '')">-- Не обрано --</li>
                                @if (Model.ChecklistList != null)
                                {
                                    foreach (var item in Model.ChecklistList)
                                    {
                                        <li class="px-6 py-4 text-slate-700 font-bold cursor-pointer hover:bg-cyan-50 hover:text-cyan-600 transition-colors border-b border-slate-100 last:border-0" onclick="selectItem(this, '@item.Value')"><i class="bi bi-check2-square text-cyan-300 mr-2"></i> @item.Text</li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                    <span asp-validation-for="ChecklistId" class="text-xs text-rose-500 font-bold absolute -bottom-5 left-4"></span>
                </div>

                <div class="flex flex-col group relative z-30">
                    <label asp-for="Content" class="text-[11px] font-black uppercase tracking-widest text-slate-500 mb-2 pl-4 group-focus-within:text-blue-500 transition-colors flex items-center gap-2"><i class="bi bi-chat-square-text text-lg"></i> Що взяти / зробити</label>
                    <input asp-for="Content" placeholder="Наприклад: Паспорт, Зарядка 🔌" class="w-full bg-white/50 border-2 border-white/60 rounded-3xl py-5 pl-6 pr-6 text-xl font-black text-slate-800 outline-none focus:ring-4 focus:ring-blue-400/30 focus:border-blue-400 focus:bg-white/90 hover:bg-white/80 transition-all shadow-inner placeholder:text-slate-300" />
                    <span asp-validation-for="Content" class="text-xs text-rose-500 font-bold absolute -bottom-5 left-4"></span>
                </div>

                <div class="mt-2">
                    <label class="bg-white/50 border-2 border-white/60 rounded-3xl p-6 flex items-center justify-between shadow-inner hover:bg-white/70 transition-all cursor-pointer w-full mb-0">
                        <div class="flex flex-col">
                            <span class="text-lg font-black text-slate-800">Вже в сумці? 🧳</span>
                            <span class="text-xs font-bold text-slate-400">Відмітьте, якщо ви вже спакували цю річ.</span>
                        </div>
                        <div class="relative inline-flex items-center">
                            <input type="checkbox" asp-for="IsChecked" class="sr-only peer">
                            <div class="w-14 h-8 bg-slate-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-[150%] peer-checked:after:border-white after:content-[''] after:absolute after:top-[4px] after:left-[4px] after:bg-white after:border-slate-300 after:border after:rounded-full after:h-6 after:w-6 after:transition-all peer-checked:bg-cyan-500"></div>
                        </div>
                    </label>
                </div>
            </div>

            <div class="mt-14 flex flex-col sm:flex-row items-center justify-end gap-6 pt-8 border-t border-slate-200/50">
                <a href="javascript:history.back()" class="w-full sm:w-auto px-8 py-5 rounded-full font-black text-slate-400 hover:text-slate-700 bg-transparent hover:bg-white/50 transition-all text-sm uppercase tracking-widest text-center">Скасувати</a>
                <button type="submit" class="w-full sm:w-auto group relative inline-flex items-center justify-center px-12 py-5 font-black text-white transition-all duration-300 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-full shadow-lg hover:-translate-y-1 uppercase tracking-widest text-sm overflow-hidden">
                    <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
                    <span class="relative flex items-center gap-3">Додати річ <i class="bi bi-plus-lg text-lg"></i></span>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            document.querySelectorAll('.real-select').forEach(select => {
                if(select.value) {
                    let opt = select.options[select.selectedIndex];
                    let btn = select.nextElementSibling.querySelector('.selected-text');
                    if(opt && btn) { btn.innerText = opt.text; btn.classList.replace('text-slate-400', 'text-slate-800'); }
                }
            });
        });
        function toggleDropdown(btn) {
            const menu = btn.nextElementSibling; const icon = btn.querySelector('.bi-chevron-down'); const container = btn.parentElement;
            if (menu.classList.contains('opacity-0')) {
                document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.add('opacity-0', 'invisible', 'translate-y-4'));
                menu.classList.remove('opacity-0', 'invisible', 'translate-y-4'); icon.classList.add('rotate-180'); container.classList.add('z-[60]');
            } else {
                menu.classList.add('opacity-0', 'invisible', 'translate-y-4'); icon.classList.remove('rotate-180'); setTimeout(() => container.classList.remove('z-[60]'), 300);
            }
        }
        function selectItem(li, val) {
            const container = li.closest('.custom-dropdown'); container.querySelector('.selected-text').innerText = li.innerText.trim();
            container.querySelector('.selected-text').classList.replace('text-slate-400', 'text-slate-800');
            const realSelect = container.parentElement.querySelector('.real-select'); realSelect.value = val;
            if (typeof $(realSelect).valid === "function") $(realSelect).valid();
            toggleDropdown(container.querySelector('button'));
        }
        document.addEventListener('click', (e) => {
            if (!e.target.closest('.custom-dropdown')) {
                document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.add('opacity-0', 'invisible', 'translate-y-4'));
                document.querySelectorAll('.bi-chevron-down').forEach(i => i.classList.remove('rotate-180'));
            }
        });
    </script>
}