@model IEnumerable<TravelManager.UI.Models.ViewModels.TripListViewModel>

@{
    ViewData["Title"] = "Мої поїздки";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="display-6">Мої поїздки</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">Створити нову поїздку</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Назва</th>
                    <th>Звідки</th>
                    <th>Дати</th>
                    <th>Статус</th>
                    <th class="text-end pe-4">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.Title</td>
                        <td>@item.DepartureLocation</td>
                        <td>@item.StartDate.ToShortDateString() - @item.EndDate.ToShortDateString()</td>
                        <td>
                            <span class="badge bg-info text-dark">@item.StatusName</span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
<a asp-action="Details" asp-route-id="@item.Id">Деталі</a>
<a asp-action="Edit" asp-route-id="@item.Id">Редагувати</a> 
<form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Ви впевнені, що хочете видалити цю поїздку?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger ms-1">Видалити</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>