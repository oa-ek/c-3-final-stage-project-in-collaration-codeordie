@model IEnumerable<TravelManager.UI.Models.ViewModels.TripListViewModel>

@{
    ViewData["Title"] = "Мої поїздки";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-4 fw-bold text-dark">Мої поїздки</h1>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">Створити нову поїздку</a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4 py-3">Назва</th>
                            <th>Звідки</th>
                            <th>Дати</th>
                            <th>Статус</th>
                            <th class="text-end pe-4">Дії</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <a asp-action="Details" asp-route-id="@item.Id" class="fw-bold text-decoration-none text-primary fs-5">
                                        @item.Title
                                    </a>
                                </td>
                                <td>@item.DepartureLocation</td>
                                <td class="small text-muted">
                                    @item.StartDate.ToShortDateString() — @item.EndDate.ToShortDateString()
                                </td>
                                <td>
                                    <span class="badge bg-info text-dark">@item.StatusName</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Переглянути</a>

                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Редагувати</a>

                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Ви впевнені, що хочете видалити цю поїздку?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>