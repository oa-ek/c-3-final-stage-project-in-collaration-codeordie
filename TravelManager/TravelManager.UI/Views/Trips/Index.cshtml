@model IEnumerable<TravelManager.UI.Models.ViewModels.TripListViewModel>

@{
    ViewData["Title"] = "Мої поїздки";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Мої поїздки</h2>
    <a asp-action="Create" class="btn btn-primary">Створити нову поїздку</a>
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Назва</th>
            <th>Звідки</th>
            <th>Дата початку</th>
            <th>Дата завершення</th>
            <th>Статус</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.DepartureLocation</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>
                    <span class="badge bg-info text-dark">@item.StatusName</span>
                </td>
            </tr>
        }
    </tbody>
</table>