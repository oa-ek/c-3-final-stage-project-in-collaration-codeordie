@model TravelManager.UI.Models.ViewModels.TripDetailsViewModel

@{
    ViewData["Title"] = "План: " + Model.Trip.Title;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<div class="container py-4">
    <div class="card shadow-sm border-0 mb-4 bg-primary text-white overflow-hidden">
        <div class="card-body p-4">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h1 class="display-5 fw-bold mb-1">@Model.Trip.Title</h1>
                    <p class="lead opacity-75 mb-3">@Model.Trip.Description</p>
                    <div class="d-flex flex-wrap gap-3 small mt-3">
                        <span class="badge bg-white text-primary px-3 py-2 border-0">Статус: @Model.Trip.Status?.Name</span>
                        @{
                            var daysLeft = (Model.Trip.StartDate - DateTime.Today).Days;
                            if (daysLeft > 0)
                            {
                                <span class="badge bg-warning text-dark px-3 py-2 border-0">⏳ До поїздки: @daysLeft днів</span>
                            }
                            else if (daysLeft == 0)
                            {
                                <span class="badge bg-danger px-3 py-2 border-0">🚀 Поїздка сьогодні!</span>
                            }
                        }
                        <span class="bg-light text-dark px-2 py-1 rounded"><i class="bi bi-calendar"></i> @Model.Trip.StartDate.ToShortDateString() — @Model.Trip.EndDate.ToShortDateString()</span>
                        <span class="bg-light text-dark px-2 py-1 rounded"><i class="bi bi-geo-alt"></i> @Model.Trip.DepartureLocation → @Model.Trip.ReturnLocation</span>
                    </div>
                </div>
                <div class="col-md-4 text-md-end mt-3 mt-md-0">
                    <div class="btn-group">
                        <a asp-action="Edit" asp-route-id="@Model.Trip.Id" class="btn btn-light shadow-sm">Редагувати</a>
                        <a asp-action="Index" class="btn btn-outline-light">Усі поїздки</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-primary">📍 Маршрут</h5>
                    <a asp-controller="TripDestinations" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn btn-sm btn-outline-primary">+ Додати місто</a>
                </div>
                <div class="card-body p-0">
                    @if (!Model.Destinations.Any())
                    {
                        <div class="text-center py-4 text-muted fst-italic">Міста ще не додані.</div>
                    }
                    else
                    {
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-4">Місто</th>
                                    <th>Прибуття</th>
                                    <th>Відбуття</th>
                                    <th class="text-end pe-4">Дії</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in Model.Destinations)
                                {
                                    <tr>
                                        <td class="ps-4 fw-bold">@d.CityName, @d.Country</td>
                                        <td>@d.ArrivalDate.ToShortDateString()</td>
                                        <td>@d.DepartureDate.ToShortDateString()</td>
                                        <td class="text-end pe-4">
                                            <a asp-controller="TripDestinations" asp-action="Edit" asp-route-id="@d.Id" class="btn btn-sm btn-link">⚙️</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-success">🏠 Житло</h5>
                    <a asp-controller="Accommodations" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn btn-sm btn-outline-success">+ Забронювати</a>
                </div>
                <div class="card-body">
                    @if (!Model.Accommodations.Any())
                    {
                        <p class="text-muted fst-italic mb-0">Дані про житло відсутні.</p>
                    }
                    else
                    {
                        <div class="row row-cols-1 row-cols-md-2 g-3">
                            @foreach (var a in Model.Accommodations)
                            {
                                <div class="col">
                                    <div class="p-3 border rounded h-100 bg-light shadow-sm">
                                        <h6 class="fw-bold mb-1">@a.Name</h6>
                                        <p class="small text-muted mb-2">@a.Address</p>
                                        <div class="d-flex justify-content-between mt-2">
                                            <span class="small fw-bold">Заїзд: @a.CheckInTime.ToShortDateString()</span>
                                            <a asp-controller="Accommodations" asp-action="Edit" asp-route-id="@a.Id" class="small text-decoration-none">Редагувати</a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 mb-4 overflow-hidden">
                <div class="card-header bg-white py-3">
                    <h5 class="mb-0 fw-bold text-danger"><i class="bi bi-map"></i> Карта подорожі</h5>
                </div>
                <div class="card-body p-0">
                    <div id="map" style="height: 350px; width: 100%; z-index: 1;"></div>
                </div>
            </div>

            @{
                // ВИПРАВЛЕНО НА DECIMAL
                decimal totalBudget = 0;
                decimal usdRate = 43.83m;
                decimal eurRate = 50.88m;
                decimal plnRate = 11.10m;
                decimal gbpRate = 59.50m;

                string baseCurr = Model.Trip.BaseCurrency ?? "UAH";

                foreach (var exp in Model.Expenses)
                {
                    decimal amount = exp.TotalAmount;

                    if (exp.Currency != baseCurr)
                    {
                        if (baseCurr == "UAH")
                        {
                            if (exp.Currency == "USD") amount *= usdRate;
                            else if (exp.Currency == "EUR") amount *= eurRate;
                            else if (exp.Currency == "PLN") amount *= plnRate;
                            else if (exp.Currency == "GBP") amount *= gbpRate;
                        }
                        else if (baseCurr == "USD")
                        {
                            if (exp.Currency == "UAH") amount /= usdRate;
                            else if (exp.Currency == "EUR") amount *= (eurRate / usdRate);
                        }
                        else if (baseCurr == "EUR")
                        {
                            if (exp.Currency == "UAH") amount /= eurRate;
                            else if (exp.Currency == "USD") amount *= (usdRate / eurRate);
                        }
                    }
                    totalBudget += amount;
                }
            }

            <div class="card shadow-sm border-0 mb-4 bg-light border-start border-4 border-danger">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="mb-0 fw-bold text-dark"><i class="bi bi-wallet2"></i> Бюджет</h5>
                        <a asp-controller="Expenses" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn btn-sm btn-outline-danger">+ Витрата</a>
                    </div>
                    <h3 class="fw-bold mb-0 text-danger">
                        @totalBudget.ToString("N2") @baseCurr
                    </h3>
                    <small class="text-muted">Загальна сума (з конвертацією)</small>
                </div>
            </div>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold text-info">✈️ Транспорт</h5>
                    <a asp-controller="Transits" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn btn-sm btn-outline-info">+ Квиток</a>
                </div>
                <div class="card-body p-0">
                    @if (!Model.Transits.Any())
                    {
                        <p class="text-muted small p-3 mb-0">Квитки відсутні.</p>
                    }
                    else
                    {
                        <ul class="list-group list-group-flush">
                            @foreach (var t in Model.Transits)
                            {
                                <li class="list-group-item py-3">
                                    <div class="fw-bold">@t.DepartureLocation → @t.ArrivalLocation</div>
                                    <div class="small text-muted">@t.TransitType?.Name | @t.DepartureTime.ToShortDateString()</div>
                                    <div class="badge bg-light text-dark border mt-1">🎫 @t.BookingReference</div>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 bg-light">
                <div class="card-header bg-dark text-white py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 fw-bold">📝 Списки речей</h5>
                    <a asp-controller="Checklists" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn btn-sm btn-outline-light">+ Новий</a>
                </div>
                <div class="card-body">
                    @if (!Model.Checklists.Any())
                    {
                        <p class="text-muted small mb-0 fst-italic">Списків ще немає.</p>
                    }
                    else
                    {
                        @foreach (var c in Model.Checklists)
                        {
                            int totalItems = c.Items?.Count() ?? 0;
                            int checkedItems = c.Items?.Count(i => i.IsChecked) ?? 0;
                            int percent = totalItems > 0 ? (int)Math.Round((double)checkedItems / totalItems * 100) : 0;

                            <a asp-controller="Checklists" asp-action="Details" asp-route-id="@c.Id" class="text-decoration-none d-block border rounded shadow-sm mb-3 p-3 text-dark bg-white custom-hover">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fw-bold">@c.Title</span>
                                    <span class="badge bg-secondary">@checkedItems / @totalItems</span>
                                </div>
                                <div class="progress" style="height: 6px;">
                                    <div class="progress-bar bg-success" role="progressbar" style="width: @percent%;" aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var map = L.map('map').setView([48.3794, 31.1656], 5);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        var allPoints = [];
        var routePoints = [];

        const delay = ms => new Promise(res => setTimeout(res, ms));

        async function geocodeAddress(address) {
            if (!address) return null;
            try {
                await delay(1000);
                let response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`);
                let data = await response.json();
                if (data && data.length > 0) {
                    return [parseFloat(data[0].lat), parseFloat(data[0].lon)];
                }
            } catch (e) {}
            return null;
        }

        async function buildFullRoute() {
            let departureText = '@Html.Raw(Model.Trip.DepartureLocation)';
            let returnText = '@Html.Raw(Model.Trip.ReturnLocation)';

            let startLatLng = await geocodeAddress(departureText);
            if (startLatLng) {
                L.marker(startLatLng, {
                    icon: L.divIcon({ html: "🟢", className: 'fs-4 border-0 bg-transparent', iconSize: [24,24], iconAnchor: [12,12] })
                }).addTo(map).bindPopup("<b>Старт:</b><br>" + departureText);
                allPoints.push(startLatLng);
            }

            var destinations = [
                @foreach (var d in Model.Destinations)
                {
                        <text>
                        {
                            name: '@Html.Raw(d.CityName), @Html.Raw(d.Country)',
                            hasCoords: @((d.Latitude.HasValue && d.Longitude.HasValue).ToString().ToLower()),
                            lat: @(d.Latitude.HasValue? d.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0"),
                            lng: @(d.Longitude.HasValue? d.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0")
                        },
                        </text>
                }
            ];

            for (let dest of destinations) {
                let latlng = null;
                if (dest.hasCoords) {
                    latlng = [dest.lat, dest.lng];
                } else {
                    latlng = await geocodeAddress(dest.name);
                }

                if (latlng) {
                    L.marker(latlng).addTo(map).bindPopup("<b>" + dest.name + "</b><br>Зупинка маршруту");
                    routePoints.push(latlng);
                    allPoints.push(latlng);
                }
            }

            let endLatLng = await geocodeAddress(returnText);
            if (endLatLng) {
                L.marker(endLatLng, {
                    icon: L.divIcon({ html: "🏁", className: 'fs-4 border-0 bg-transparent', iconSize: [24,24], iconAnchor: [12,12] })
                }).addTo(map).bindPopup("<b>Фініш:</b><br>" + returnText);
                allPoints.push(endLatLng);
            }

            let fullPath = [];
            if (startLatLng) fullPath.push(startLatLng);
            fullPath = fullPath.concat(routePoints);
            if (endLatLng) fullPath.push(endLatLng);

            if (fullPath.length > 1) {
                L.polyline(fullPath, { color: '#dc3545', weight: 3, opacity: 0.8, dashArray: '8, 8' }).addTo(map);
            }

            var accommodations = [
                @foreach (var a in Model.Accommodations)
                {
                        <text>
                        {
                            name: '@Html.Raw(a.Name)',
                            address: '@Html.Raw(a.Address)',
                            hasCoords: @((a.Latitude.HasValue && a.Longitude.HasValue).ToString().ToLower()),
                            lat: @(a.Latitude.HasValue? a.Latitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0"),
                            lng: @(a.Longitude.HasValue? a.Longitude.Value.ToString(System.Globalization.CultureInfo.InvariantCulture) : "0")
                        },
                        </text>
                }
            ];

            for (let acc of accommodations) {
                let latlng = null;
                if (acc.hasCoords) {
                    latlng = [acc.lat, acc.lng];
                } else {
                    latlng = await geocodeAddress(acc.address ? acc.address : acc.name);
                }

                if (latlng) {
                    L.marker(latlng, {
                        icon: L.divIcon({
                            className: 'custom-div-icon',
                            html: "<div style='background-color:#198754; color:white; border-radius:50%; width:30px; height:30px; display:flex; align-items:center; justify-content:center; border:2px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.3);'>🏠</div>",
                            iconSize: [30, 30],
                            iconAnchor: [15, 30]
                        })
                    }).addTo(map).bindPopup("<b>" + acc.name + "</b><br>" + acc.address);
                    allPoints.push(latlng);
                }
            }

            if (allPoints.length > 0) {
                var bounds = new L.LatLngBounds(allPoints);
                map.fitBounds(bounds, { padding: [30, 30] });
            }
        }

        buildFullRoute();
    </script>
}