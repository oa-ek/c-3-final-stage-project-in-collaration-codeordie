@* TravelManager/TravelManager.UI/Views/Trips/Details.cshtml *@

@model TravelManager.UI.Models.ViewModels.TripDetailsViewModel

@{
    ViewData["Title"] = "План: " + Model.Trip.Title;
    var currentUserRole = Model.CurrentUserRole;
    bool canManage = currentUserRole == "Organizer";
    bool isOrganizer = currentUserRole == "Organizer";

    var duration = (Model.Trip.EndDate - Model.Trip.StartDate).Days;
    var daysLeft = (Model.Trip.StartDate - DateTime.Today).Days;
    var isActive = DateTime.Today >= Model.Trip.StartDate && DateTime.Today <= Model.Trip.EndDate;
    var isPast = DateTime.Today > Model.Trip.EndDate;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
    * {
        box-sizing: border-box;
    }

    .td-root {
        font-family: 'DM Sans', sans-serif;
        min-height: 100vh;
        padding: 0 0 5rem;
        position: relative;
        overflow-x: hidden;
    }

    .blob {
        position: fixed;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.16;
        z-index: -1;
        pointer-events: none;
        animation: blobFloat linear infinite;
    }

    .blob-1 {
        width: 600px;
        height: 600px;
        background: #6366f1;
        top: -150px;
        left: -150px;
        animation-duration: 22s;
    }

    .blob-2 {
        width: 500px;
        height: 500px;
        background: #ec4899;
        bottom: -100px;
        right: -100px;
        animation-duration: 28s;
        animation-direction: reverse;
    }

    .blob-3 {
        width: 350px;
        height: 350px;
        background: #10b981;
        top: 40%;
        left: 55%;
        animation-duration: 19s;
    }

    @@keyframes blobFloat {
        0% {
            transform: translate(0,0) scale(1);
        }

        33% {
            transform: translate(40px,-30px) scale(1.05);
        }

        66% {
            transform: translate(-25px,40px) scale(0.95);
        }

        100% {
            transform: translate(0,0) scale(1);
        }
    }

    /* ═══════ HERO ═══════ */
    .trip-hero {
        background: linear-gradient(135deg,#0f172a 0%,#1e1b4b 40%,#312e81 70%,#4c1d95 100%);
        padding: 3.5rem 2rem 8rem;
        position: relative;
        overflow: hidden;
    }

        .trip-hero::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 60% 80% at 80% 50%,rgba(139,92,246,.35) 0%,transparent 60%), radial-gradient(ellipse 40% 60% at 20% 80%,rgba(236,72,153,.25) 0%,transparent 50%);
            animation: heroGlow 8s ease-in-out infinite alternate;
        }

    @@keyframes heroGlow {
        0% {
            opacity: .6;
        }

        100% {
            opacity: 1;
        }
    }

    .hero-pattern {
        position: absolute;
        inset: 0;
        opacity: .04;
        background-image: radial-gradient(circle,#fff 1px,transparent 1px);
        background-size: 30px 30px;
    }

    .stars {
        position: absolute;
        inset: 0;
        overflow: hidden;
        pointer-events: none;
    }

    .star {
        position: absolute;
        width: 2px;
        height: 2px;
        background: white;
        border-radius: 50%;
        animation: twinkle linear infinite;
    }

    @@keyframes twinkle {
        0%, 100% {
            opacity: .2;
            transform: scale(1);
        }

        50% {
            opacity: 1;
            transform: scale(1.5);
        }
    }

    .hero-content {
        position: relative;
        z-index: 1;
        max-width: 1100px;
        margin: 0 auto;
    }

    .hero-back {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        color: rgba(255,255,255,.6);
        font-weight: 600;
        font-size: .85rem;
        text-decoration: none;
        margin-bottom: 1.5rem;
        transition: color .2s;
    }

        .hero-back:hover {
            color: white;
        }

    .hero-trip-title {
        font-family: 'Syne',sans-serif;
        font-size: clamp(2.5rem,6vw,4.5rem);
        font-weight: 900;
        color: white;
        line-height: 1;
        letter-spacing: -.03em;
        margin-bottom: 1.2rem;
    }

        .hero-trip-title .accent {
            background: linear-gradient(135deg,#a78bfa,#f472b6,#fb923c);
            background-size: 200% 200%;
            animation: accentGrad 5s ease infinite;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

    @@keyframes accentGrad {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    .hero-meta {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        margin-bottom: 2rem;
    }

    .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        background: rgba(255,255,255,.12);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,.2);
        border-radius: 999px;
        padding: .45rem 1rem;
        font-size: .82rem;
        font-weight: 600;
        color: white;
    }

        .hero-pill.active {
            background: rgba(16,185,129,.3);
            border-color: rgba(16,185,129,.5);
            animation: activePulse 2s ease-in-out infinite;
        }

    @@keyframes activePulse {
        0%, 100% {
            box-shadow: 0 0 0 0 rgba(16,185,129,.4);
        }

        50% {
            box-shadow: 0 0 0 8px rgba(16,185,129,0);
        }
    }

    .hero-pill.past {
        background: rgba(148,163,184,.2);
        border-color: rgba(148,163,184,.3);
    }

    .hero-pill.future {
        background: rgba(99,102,241,.3);
        border-color: rgba(99,102,241,.5);
    }

    .hero-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit,minmax(110px,1fr));
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .hstat {
        background: rgba(255,255,255,.08);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,.15);
        border-radius: 1.2rem;
        padding: 1rem 1.2rem;
        text-align: center;
        transition: all .3s ease;
    }

        .hstat:hover {
            background: rgba(255,255,255,.14);
            transform: translateY(-3px);
        }

    .hstat-num {
        font-family: 'Syne',sans-serif;
        font-size: 2rem;
        font-weight: 900;
        color: white;
        line-height: 1;
    }

    .hstat-lbl {
        font-size: .72rem;
        font-weight: 600;
        color: rgba(255,255,255,.55);
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-top: .3rem;
    }

    .hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
    }

    .btn-hero {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        border-radius: 1rem;
        padding: .75rem 1.5rem;
        font-family: 'Syne',sans-serif;
        font-weight: 800;
        font-size: .875rem;
        text-decoration: none;
        cursor: pointer;
        border: none;
        transition: all .3s cubic-bezier(.34,1.56,.64,1);
        position: relative;
        overflow: hidden;
    }

        .btn-hero.primary {
            background: linear-gradient(135deg,#6366f1,#8b5cf6);
            color: white;
            box-shadow: 0 4px 20px rgba(99,102,241,.5);
        }

            .btn-hero.primary:hover {
                transform: translateY(-3px) scale(1.04);
                box-shadow: 0 8px 30px rgba(99,102,241,.65);
                color: white;
            }

        .btn-hero.success {
            background: linear-gradient(135deg,#10b981,#059669);
            color: white;
            box-shadow: 0 4px 20px rgba(16,185,129,.4);
        }

            .btn-hero.success:hover {
                transform: translateY(-3px) scale(1.04);
                box-shadow: 0 8px 30px rgba(16,185,129,.55);
                color: white;
            }

        .btn-hero.ghost {
            background: rgba(255,255,255,.1);
            border: 1px solid rgba(255,255,255,.2);
            color: rgba(255,255,255,.8);
        }

            .btn-hero.ghost:hover {
                background: rgba(255,255,255,.18);
                color: white;
                transform: translateY(-2px);
            }

        .btn-hero.danger {
            background: rgba(239,68,68,.15);
            border: 1px solid rgba(239,68,68,.35);
            color: #fca5a5;
        }

            .btn-hero.danger:hover {
                background: rgba(239,68,68,.3);
                transform: translateY(-2px);
                color: white;
            }

    /* ═══════ BODY ═══════ */
    .td-body {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 1.5rem;
        margin-top: -4rem;
        position: relative;
        z-index: 10;
    }

    .reveal {
        opacity: 0;
        transform: translateY(28px);
        animation: revealUp .65s cubic-bezier(.16,1,.3,1) forwards;
    }

    @@keyframes revealUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .d1 {
        animation-delay: .1s
    }

    .d2 {
        animation-delay: .2s
    }

    .d3 {
        animation-delay: .3s
    }

    .d4 {
        animation-delay: .4s
    }

    .d5 {
        animation-delay: .5s
    }

    .d6 {
        animation-delay: .6s
    }

    .toast-success, .toast-error {
        border-radius: 1rem;
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: .75rem;
        font-weight: 600;
        font-size: .875rem;
        margin-bottom: 1.5rem;
        animation: toastIn .5s cubic-bezier(.34,1.56,.64,1);
    }

    @@keyframes toastIn {
        from {
            opacity: 0;
            transform: translateY(-12px) scale(.95);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .toast-success {
        background: rgba(16,185,129,.1);
        border: 1px solid rgba(16,185,129,.25);
        color: #065f46;
    }

    .toast-error {
        background: rgba(239,68,68,.08);
        border: 1px solid rgba(239,68,68,.2);
        color: #991b1b;
    }

    /* Glass cards */
    .glass-card {
        background: rgba(255,255,255,.6);
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,.9);
        border-radius: 2rem;
        box-shadow: 0 8px 40px rgba(99,102,241,.08);
        overflow: hidden;
        transition: box-shadow .3s ease;
    }

        .glass-card:hover {
            box-shadow: 0 12px 50px rgba(99,102,241,.13);
        }

    .card-head {
        padding: 1.4rem 1.8rem;
        border-bottom: 1px solid rgba(99,102,241,.08);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .card-head-title {
        font-family: 'Syne',sans-serif;
        font-size: 1rem;
        font-weight: 800;
        color: #0f172a;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .card-head-icon {
        width: 32px;
        height: 32px;
        background: linear-gradient(135deg,#6366f1,#8b5cf6);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: .85rem;
        box-shadow: 0 3px 10px rgba(99,102,241,.3);
    }

    .card-body-pad {
        padding: 1.8rem;
    }

    /* Учасники */
    .participant-item {
        display: flex;
        align-items: center;
        gap: .75rem;
        padding: .9rem 1.2rem;
        border-bottom: 1px solid rgba(99,102,241,.07);
        transition: background .2s;
    }

        .participant-item:last-child {
            border-bottom: none;
        }

        .participant-item:hover {
            background: rgba(99,102,241,.03);
        }

    .avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        flex-shrink: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: 'Syne',sans-serif;
        font-weight: 800;
        font-size: .9rem;
        color: white;
    }

    .avatar-org {
        background: linear-gradient(135deg,#f59e0b,#f97316);
        box-shadow: 0 3px 12px rgba(245,158,11,.4);
    }

    .avatar-mem {
        background: linear-gradient(135deg,#6366f1,#8b5cf6);
        box-shadow: 0 3px 12px rgba(99,102,241,.3);
    }

    .avatar-vie {
        background: linear-gradient(135deg,#94a3b8,#64748b);
    }

    .participant-name {
        font-weight: 700;
        color: #0f172a;
        font-size: .9rem;
    }

    .participant-role-badge {
        font-size: .72rem;
        font-weight: 700;
        border-radius: 999px;
        padding: .2rem .6rem;
    }

    .prb-org {
        background: rgba(245,158,11,.12);
        color: #92400e;
    }

    .prb-mem {
        background: rgba(99,102,241,.1);
        color: #3730a3;
    }

    .prb-vie {
        background: rgba(148,163,184,.12);
        color: #475569;
    }

    .participant-actions {
        margin-left: auto;
        display: flex;
        align-items: center;
        gap: .5rem;
    }

    .role-select-wrap select {
        border: 1.5px solid rgba(99,102,241,.2) !important;
        background: rgba(255,255,255,.8) !important;
        border-radius: .6rem !important;
        font-size: .78rem !important;
        font-weight: 600 !important;
        color: #4f46e5 !important;
        padding: .3rem .6rem !important;
        outline: none !important;
        cursor: pointer;
    }

    .icon-btn-sm {
        width: 30px;
        height: 30px;
        border-radius: 8px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: .8rem;
        cursor: pointer;
        transition: all .25s cubic-bezier(.34,1.56,.64,1);
    }

        .icon-btn-sm.del {
            background: rgba(239,68,68,.08);
            color: #dc2626;
            border: 1px solid rgba(239,68,68,.15);
        }

            .icon-btn-sm.del:hover {
                background: #ef4444;
                color: white;
                transform: scale(1.15);
                box-shadow: 0 3px 10px rgba(239,68,68,.4);
            }

    /* Запрошення */
    .invite-form-wrap {
        padding: 1.4rem;
        background: rgba(99,102,241,.04);
        border-top: 1px solid rgba(99,102,241,.1);
    }

    .invite-title {
        font-family: 'Syne',sans-serif;
        font-weight: 800;
        font-size: .875rem;
        color: #0f172a;
        margin-bottom: .9rem;
        display: flex;
        align-items: center;
        gap: .4rem;
    }

    .invite-field {
        background: rgba(255,255,255,.8);
        border: 1.5px solid rgba(99,102,241,.15);
        border-radius: .75rem;
        padding: .6rem .9rem;
        font-size: .875rem;
        font-weight: 600;
        color: #1e293b;
        width: 100%;
        outline: none;
        font-family: 'DM Sans',sans-serif;
        transition: border-color .2s,box-shadow .2s;
        margin-bottom: .6rem;
    }

        .invite-field:focus {
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,.08);
        }

    .invite-row {
        display: flex;
        gap: .5rem;
    }

    .invite-select {
        flex: 1;
        background: rgba(255,255,255,.8);
        border: 1.5px solid rgba(99,102,241,.15) !important;
        border-radius: .75rem !important;
        padding: .6rem .9rem !important;
        font-size: .82rem;
        font-weight: 600;
        color: #4f46e5;
        outline: none;
        cursor: pointer;
    }

    .invite-btn {
        background: linear-gradient(135deg,#6366f1,#8b5cf6);
        color: white;
        border: none;
        border-radius: .75rem;
        padding: .6rem 1.2rem;
        font-family: 'Syne',sans-serif;
        font-weight: 800;
        font-size: .82rem;
        cursor: pointer;
        box-shadow: 0 3px 12px rgba(99,102,241,.35);
        transition: all .3s cubic-bezier(.34,1.56,.64,1);
        display: inline-flex;
        align-items: center;
        gap: .3rem;
    }

        .invite-btn:hover {
            transform: translateY(-2px) scale(1.04);
            box-shadow: 0 6px 20px rgba(99,102,241,.5);
        }

    /* Модалки */
    .modal-bd {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(15,23,42,.5);
        backdrop-filter: blur(8px);
        z-index: 9999;
        align-items: center;
        justify-content: center;
    }

        .modal-bd.show {
            display: flex;
        }

    .modal-box {
        background: rgba(255,255,255,.92);
        backdrop-filter: blur(30px);
        border: 1px solid rgba(255,255,255,.9);
        border-radius: 2rem;
        padding: 2.5rem 2rem;
        max-width: 380px;
        width: 90%;
        text-align: center;
        box-shadow: 0 30px 80px rgba(0,0,0,.2);
        animation: modalPop .4s cubic-bezier(.34,1.56,.64,1);
    }

    @@keyframes modalPop {
        from {
            transform: scale(.82) translateY(32px);
            opacity: 0;
        }

        to {
            transform: scale(1) translateY(0);
            opacity: 1;
        }
    }

    .modal-icon {
        width: 64px;
        height: 64px;
        border-radius: 50%;
        background: rgba(239,68,68,.1);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.2rem;
        font-size: 1.6rem;
        color: #dc2626;
    }

    .modal-title {
        font-family: 'Syne',sans-serif;
        font-size: 1.2rem;
        font-weight: 800;
        color: #0f172a;
        margin-bottom: .4rem;
    }

    .modal-sub {
        color: #64748b;
        font-size: .875rem;
        font-weight: 500;
        margin-bottom: 1.75rem;
    }

    .modal-actions {
        display: flex;
        gap: .75rem;
        justify-content: center;
    }

    .modal-cancel {
        background: rgba(100,116,139,.1);
        border: 1px solid rgba(100,116,139,.2);
        color: #475569;
        border-radius: 1rem;
        padding: .7rem 1.4rem;
        font-weight: 700;
        font-size: .875rem;
        cursor: pointer;
        transition: all .2s;
    }

        .modal-cancel:hover {
            background: rgba(100,116,139,.18);
            transform: translateY(-2px);
        }

    .modal-confirm-del {
        background: linear-gradient(135deg,#ef4444,#dc2626);
        border: none;
        color: white;
        border-radius: 1rem;
        padding: .7rem 1.4rem;
        font-weight: 700;
        font-size: .875rem;
        cursor: pointer;
        font-family: 'Syne',sans-serif;
        box-shadow: 0 4px 14px rgba(239,68,68,.35);
        transition: all .3s cubic-bezier(.34,1.56,.64,1);
    }

        .modal-confirm-del:hover {
            transform: translateY(-3px) scale(1.04);
            box-shadow: 0 8px 22px rgba(239,68,68,.5);
        }

    /* Карта */
    #map {
        height: 350px;
        width: 100%;
        z-index: 1;
        border-radius: 0 0 1.5rem 1.5rem;
    }

    /* Таблиця destinations */
    .dest-table {
        width: 100%;
        border-collapse: collapse;
    }

        .dest-table th {
            padding: .75rem 1rem;
            text-align: left;
            font-size: .78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .06em;
            color: #64748b;
            border-bottom: 1px solid rgba(99,102,241,.1);
        }

        .dest-table td {
            padding: .85rem 1rem;
            border-bottom: 1px solid rgba(99,102,241,.05);
            font-size: .9rem;
        }

        .dest-table tr:last-child td {
            border-bottom: none;
        }

        .dest-table tr:hover td {
            background: rgba(99,102,241,.03);
        }

    @@media(max-width:900px) {
        .main-grid {
            grid-template-columns: 1fr !important;
        }
    }

    @@media(max-width:768px) {
        .trip-hero {
            padding: 2.5rem 1.2rem 7rem;
        }

        .hero-stats {
            grid-template-columns: repeat(2,1fr);
        }

        .td-body {
            padding: 0 1rem;
        }
    }
</style>

<!-- Blobs -->
<div class="blob blob-1"></div>
<div class="blob blob-2"></div>
<div class="blob blob-3"></div>

<!-- Модалка: видалити поїздку -->
<div class="modal-bd" id="deleteTripModal">
    <div class="modal-box">
        <div class="modal-icon"><i class="bi bi-trash3-fill"></i></div>
        <div class="modal-title">Видалити поїздку?</div>
        <div class="modal-sub">«@Model.Trip.Title» — всі дані буде втрачено назавжди.</div>
        <div class="modal-actions">
            <button class="modal-cancel" onclick="document.getElementById('deleteTripModal').classList.remove('show')">Скасувати</button>
            <button class="modal-confirm-del" onclick="document.getElementById('deleteTripForm').submit()">
                <i class="bi bi-trash3-fill"></i> Видалити
            </button>
        </div>
    </div>
</div>
<form id="deleteTripForm" asp-action="Delete" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Trip.Id" />
</form>

<!-- Модалка: видалити учасника -->
<div class="modal-bd" id="deleteParticipantModal">
    <div class="modal-box">
        <div class="modal-icon"><i class="bi bi-person-x-fill"></i></div>
        <div class="modal-title">Видалити учасника?</div>
        <div class="modal-sub" id="deleteParticipantSub">Цю дію неможливо скасувати.</div>
        <div class="modal-actions">
            <button class="modal-cancel" onclick="document.getElementById('deleteParticipantModal').classList.remove('show')">Скасувати</button>
            <button class="modal-confirm-del" onclick="document.getElementById('deleteParticipantForm').submit()">
                <i class="bi bi-person-x-fill"></i> Видалити
            </button>
        </div>
    </div>
</div>
<form id="deleteParticipantForm" asp-action="RemoveParticipant" method="post" style="display:none;">
    @Html.AntiForgeryToken()
    <input type="hidden" name="tripId" value="@Model.Trip.Id" />
    <input type="hidden" name="userId" id="deleteParticipantUserId" />
</form>

<div class="td-root">

    <!-- ══════ HERO ══════ -->
    <div class="trip-hero">
        <div class="hero-pattern"></div>
        <div class="stars" id="starsContainer"></div>
        <div class="hero-content">
            <a asp-action="Index" class="hero-back"><i class="bi bi-arrow-left"></i> Мої поїздки</a>

            <div class="hero-trip-title"><span class="accent">@Model.Trip.Title</span></div>

            <div class="hero-meta">
                @if (isActive)
                {
                    <span class="hero-pill active"><i class="bi bi-circle-fill" style="font-size:.5rem;"></i> В процесі</span>
                }
                else if (isPast)
                {
                    <span class="hero-pill past"><i class="bi bi-check-circle"></i> Завершено</span>
                }
                else
                {
                    <span class="hero-pill future">
                        <i class="bi bi-clock"></i>
                        @if (daysLeft > 0)
                        {
                            @($"Через {daysLeft} днів")
                        }
                        else
                        {

                            <text>Сьогодні!</text>
                        }
                    </span>
                }
                <span class="hero-pill"><i class="bi bi-calendar3"></i> @Model.Trip.StartDate.ToString("dd MMM") — @Model.Trip.EndDate.ToString("dd MMM yyyy")</span>
                <span class="hero-pill"><i class="bi bi-person-badge"></i> @currentUserRole</span>
                @if (!string.IsNullOrEmpty(Model.Trip.DepartureLocation))
                {
                    <span class="hero-pill"><i class="bi bi-geo-alt"></i> @Model.Trip.DepartureLocation → @Model.Trip.ReturnLocation</span>
                }
            </div>

            <div class="hero-stats">
                <div class="hstat"><div class="hstat-num">@duration</div><div class="hstat-lbl">Днів</div></div>
                <div class="hstat"><div class="hstat-num">@Model.Participants.Count()</div><div class="hstat-lbl">Учасників</div></div>
                <div class="hstat"><div class="hstat-num">@Model.Destinations.Count()</div><div class="hstat-lbl">Міст</div></div>
                <div class="hstat"><div class="hstat-num">@Model.Expenses.Count()</div><div class="hstat-lbl">Витрат</div></div>
            </div>

            <div class="hero-actions">
                <a asp-controller="Expenses" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn-hero success"><i class="bi bi-cash-coin"></i> Витрата</a>
                <a asp-controller="Accommodations" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn-hero primary"><i class="bi bi-building"></i> Житло</a>
                <a asp-controller="Transits" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn-hero primary"><i class="bi bi-airplane"></i> Транзит</a>
                <a asp-controller="TripActivities" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn-hero primary"><i class="bi bi-lightning"></i> Активність</a>
                <a asp-controller="TripDestinations" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn-hero primary"><i class="bi bi-geo-alt"></i> Місто</a>
                <a asp-controller="Checklists" asp-action="Create" asp-route-tripId="@Model.Trip.Id" class="btn-hero primary"><i class="bi bi-check2-square"></i> Чекліст</a>
                @if (canManage)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Trip.Id" class="btn-hero ghost"><i class="bi bi-pencil"></i> Редагувати</a>
                }
                @if (isOrganizer)
                {
                    <button type="button" class="btn-hero danger" onclick="document.getElementById('deleteTripModal').classList.add('show')">
                        <i class="bi bi-trash3"></i> Видалити
                    </button>
                }
            </div>
        </div>
    </div>

    <!-- ══════ BODY ══════ -->
    <div class="td-body">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast-success reveal d1"><i class="bi bi-check-circle-fill" style="color:#10b981;font-size:1.1rem;"></i> @TempData["SuccessMessage"]</div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="toast-error reveal d1"><i class="bi bi-exclamation-circle-fill" style="color:#ef4444;font-size:1.1rem;"></i> @TempData["ErrorMessage"]</div>
        }

        <!-- Головна сітка -->
        <div style="display:grid; grid-template-columns:1fr 380px; gap:1.5rem; align-items:start;" class="main-grid">

            <!-- ══ ЛІВА КОЛОНКА ══ -->
            <div>

                <!-- Маршрут -->
                <div class="glass-card reveal d2" style="margin-bottom:1.5rem;">
                    <div class="card-head">
                        <div class="card-head-title">
                            <div class="card-head-icon" style="background:linear-gradient(135deg,#3b82f6,#06b6d4);"><i class="bi bi-geo-alt"></i></div>
                            📍 Маршрут
                        </div>
                        <a asp-controller="TripDestinations" asp-action="Create" asp-route-tripId="@Model.Trip.Id"
                           style="font-size:.8rem;font-weight:700;color:#6366f1;text-decoration:none;border:1px solid rgba(99,102,241,.3);border-radius:.75rem;padding:.4rem .9rem;transition:all .2s;"
                           onmouseover="this.style.background='rgba(99,102,241,.08)'" onmouseout="this.style.background='transparent'">
                            + Додати місто
                        </a>
                    </div>
                    <div>
                        @if (!Model.Destinations.Any())
                        {
                            <div style="text-align:center;padding:2rem;color:#94a3b8;font-style:italic;">Міста ще не додані.</div>
                        }
                        else
                        {
                            <table class="dest-table">
                                <thead>
                                    <tr>
                                        <th>Місто</th>
                                        <th>Прибуття</th>
                                        <th>Відбуття</th>
                                        <th style="text-align:right;padding-right:1.5rem;">Дії</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var d in Model.Destinations)
                                    {
                                        <tr>
                                            <td style="font-weight:700;">@d.CityName@(string.IsNullOrEmpty(d.Country) ? "" : $", {d.Country}")</td>
                                            <td>@d.ArrivalDate.ToShortDateString()</td>
                                            <td>@d.DepartureDate.ToShortDateString()</td>
                                            <td style="text-align:right;padding-right:1.5rem;">
                                                <a asp-controller="TripDestinations" asp-action="Edit" asp-route-id="@d.Id"
                                                   style="color:#6366f1;font-size:.8rem;font-weight:700;text-decoration:none;">⚙️ Ред.</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </div>

                <!-- Карта -->
                <div class="glass-card reveal d3" style="margin-bottom:1.5rem;">
                    <div class="card-head">
                        <div class="card-head-title">
                            <div class="card-head-icon" style="background:linear-gradient(135deg,#ef4444,#f97316);"><i class="bi bi-map"></i></div>
                            🗺️ Карта подорожі
                        </div>
                    </div>
                    <div id="map"></div>
                </div>

                <!-- Житло -->
                <div class="glass-card reveal d4" style="margin-bottom:1.5rem;">
                    <div class="card-head">
                        <div class="card-head-title">
                            <div class="card-head-icon" style="background:linear-gradient(135deg,#10b981,#059669);"><i class="bi bi-building"></i></div>
                            🏠 Житло
                        </div>
                        <a asp-controller="Accommodations" asp-action="Create" asp-route-tripId="@Model.Trip.Id"
                           style="font-size:.8rem;font-weight:700;color:#10b981;text-decoration:none;border:1px solid rgba(16,185,129,.3);border-radius:.75rem;padding:.4rem .9rem;transition:all .2s;"
                           onmouseover="this.style.background='rgba(16,185,129,.08)'" onmouseout="this.style.background='transparent'">
                            + Забронювати
                        </a>
                    </div>
                    <div class="card-body-pad">
                        @if (!Model.Accommodations.Any())
                        {
                            <p style="color:#94a3b8;font-style:italic;margin:0;">Дані про житло відсутні.</p>
                        }
                        else
                        {
                            <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;">
                                @foreach (var a in Model.Accommodations)
                                {
                                    <div style="padding:1rem;border-radius:1rem;background:rgba(16,185,129,.05);border:1px solid rgba(16,185,129,.15);">
                                        <div style="font-weight:700;margin-bottom:.3rem;">@a.Name</div>
                                        <div style="font-size:.83rem;color:#64748b;margin-bottom:.5rem;">@a.Address</div>
                                        <div style="display:flex;justify-content:space-between;align-items:center;font-size:.8rem;">
                                            <span style="font-weight:600;">Заїзд: @a.CheckInTime.ToShortDateString()</span>
                                            <a asp-controller="Accommodations" asp-action="Edit" asp-route-id="@a.Id" style="color:#10b981;text-decoration:none;font-weight:700;">Ред.</a>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Транспорт -->
                <div class="glass-card reveal d5" style="margin-bottom:1.5rem;">
                    <div class="card-head">
                        <div class="card-head-title">
                            <div class="card-head-icon" style="background:linear-gradient(135deg,#f59e0b,#ef4444);"><i class="bi bi-airplane"></i></div>
                            ✈️ Транспорт
                        </div>
                        <a asp-controller="Transits" asp-action="Create" asp-route-tripId="@Model.Trip.Id"
                           style="font-size:.8rem;font-weight:700;color:#f59e0b;text-decoration:none;border:1px solid rgba(245,158,11,.3);border-radius:.75rem;padding:.4rem .9rem;transition:all .2s;"
                           onmouseover="this.style.background='rgba(245,158,11,.08)'" onmouseout="this.style.background='transparent'">
                            + Квиток
                        </a>
                    </div>
                    <div>
                        @if (!Model.Transits.Any())
                        {
                            <div style="padding:1.5rem;color:#94a3b8;font-style:italic;">Квитки відсутні.</div>
                        }
                        else
                        {
                            @foreach (var t in Model.Transits)
                            {
                                <div style="padding:1rem 1.5rem;border-bottom:1px solid rgba(99,102,241,.06);">
                                    <div style="font-weight:700;">@t.DepartureLocation → @t.ArrivalLocation</div>
                                    <div style="font-size:.82rem;color:#64748b;margin-top:.2rem;">@t.TransitType?.Name | @t.DepartureTime.ToShortDateString()</div>
                                    @if (!string.IsNullOrEmpty(t.BookingReference))
                                    {
                                        <span style="display:inline-block;margin-top:.3rem;font-size:.78rem;background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.2);border-radius:.5rem;padding:.15rem .5rem;color:#4f46e5;font-weight:600;">🎫 @t.BookingReference</span>
                                    }
                                </div>
                            }
                        }
                    </div>
                </div>

                <!-- Бюджет -->
                <div class="glass-card reveal d6" style="margin-bottom:1.5rem;">
                    <div class="card-head">
                        <div class="card-head-title">
                            <div class="card-head-icon" style="background:linear-gradient(135deg,#8b5cf6,#ec4899);"><i class="bi bi-wallet2"></i></div>
                            💰 Бюджет
                        </div>
                        <a asp-controller="Expenses" asp-action="Create" asp-route-tripId="@Model.Trip.Id"
                           style="font-size:.8rem;font-weight:700;color:#8b5cf6;text-decoration:none;border:1px solid rgba(139,92,246,.3);border-radius:.75rem;padding:.4rem .9rem;transition:all .2s;"
                           onmouseover="this.style.background='rgba(139,92,246,.08)'" onmouseout="this.style.background='transparent'">
                            + Витрата
                        </a>
                    </div>
                    <div class="card-body-pad">
                        @{
                            decimal totalBudget = 0;
                            decimal usdRate = 43.83m; decimal eurRate = 50.88m;
                            decimal plnRate = 11.10m; decimal gbpRate = 59.50m;
                            string baseCurr = Model.Trip.BaseCurrency ?? "UAH";

                            foreach (var exp in Model.Expenses)
                            {
                                decimal amount = exp.TotalAmount;
                                if (exp.Currency != baseCurr)
                                {
                                    if (baseCurr == "UAH")
                                    {
                                        if (exp.Currency == "USD") amount *= usdRate;
                                        else if (exp.Currency == "EUR") amount *= eurRate;
                                        else if (exp.Currency == "PLN") amount *= plnRate;
                                        else if (exp.Currency == "GBP") amount *= gbpRate;
                                    }
                                    else if (baseCurr == "USD")
                                    {
                                        if (exp.Currency == "UAH") amount /= usdRate;
                                        else if (exp.Currency == "EUR") amount *= (eurRate / usdRate);
                                    }
                                    else if (baseCurr == "EUR")
                                    {
                                        if (exp.Currency == "UAH") amount /= eurRate;
                                        else if (exp.Currency == "USD") amount *= (usdRate / eurRate);
                                    }
                                }
                                totalBudget += amount;
                            }
                        }
                        <div style="font-family:'Syne',sans-serif;font-size:2.5rem;font-weight:900;color:#6366f1;">
                            @totalBudget.ToString("N2") <span style="font-size:1.2rem;color:#94a3b8;">@baseCurr</span>
                        </div>
                        <div style="font-size:.8rem;color:#94a3b8;margin-top:.3rem;">Загальна сума (з конвертацією)</div>
                        @if (Model.Expenses.Any())
                        {
                            <div style="margin-top:1rem;display:flex;flex-direction:column;gap:.5rem;">
                                @foreach (var exp in Model.Expenses.Take(5))
                                {
                                    <div style="display:flex;justify-content:space-between;font-size:.85rem;">
                                        <span>@exp.Title</span>
                                        <span style="font-weight:700;">@exp.TotalAmount.ToString("N2") @exp.Currency</span>
                                    </div>
                                }
                                @if (Model.Expenses.Count() > 5)
                                {
                                    <a asp-controller="Expenses" asp-action="Index" style="font-size:.8rem;color:#6366f1;font-weight:700;text-decoration:none;">+ ще @(Model.Expenses.Count() - 5) витрат</a>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Чеклісти -->
                <div class="glass-card reveal d6">
                    <div class="card-head">
                        <div class="card-head-title">
                            <div class="card-head-icon" style="background:linear-gradient(135deg,#1e293b,#334155);"><i class="bi bi-check2-square"></i></div>
                            📝 Списки речей
                        </div>
                        <a asp-controller="Checklists" asp-action="Create" asp-route-tripId="@Model.Trip.Id"
                           style="font-size:.8rem;font-weight:700;color:#334155;text-decoration:none;border:1px solid rgba(51,65,85,.3);border-radius:.75rem;padding:.4rem .9rem;">
                            + Новий
                        </a>
                    </div>
                    <div class="card-body-pad">
                        @if (!Model.Checklists.Any())
                        {
                            <p style="color:#94a3b8;font-style:italic;margin:0;">Списків ще немає.</p>
                        }
                        else
                        {
                            @foreach (var c in Model.Checklists)
                            {
                                int totalItems = c.Items?.Count() ?? 0;
                                int checkedItems = c.Items?.Count(i => i.IsChecked) ?? 0;
                                int percent = totalItems > 0 ? (int)Math.Round((double)checkedItems / totalItems * 100) : 0;
                                <a asp-controller="Checklists" asp-action="Details" asp-route-id="@c.Id"
                                   style="display:block;text-decoration:none;padding:1rem;border-radius:1rem;background:rgba(255,255,255,.6);border:1px solid rgba(99,102,241,.1);margin-bottom:.75rem;transition:all .2s;"
                                   onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 20px rgba(0,0,0,.08)'"
                                   onmouseout="this.style.transform='';this.style.boxShadow=''">
                                    <div style="display:flex;justify-content:space-between;margin-bottom:.6rem;">
                                        <span style="font-weight:700;color:#0f172a;">@c.Title</span>
                                        <span style="font-size:.78rem;background:rgba(99,102,241,.1);color:#4f46e5;border-radius:999px;padding:.15rem .6rem;font-weight:700;">@checkedItems / @totalItems</span>
                                    </div>
                                    <div style="height:6px;background:rgba(99,102,241,.1);border-radius:999px;">
                                        <div style="height:100%;width:@percent%;background:linear-gradient(90deg,#10b981,#059669);border-radius:999px;transition:width .3s;"></div>
                                    </div>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>

            <!-- ══ ПРАВА КОЛОНКА: Учасники ══ -->
            <div>
                <div class="glass-card reveal d2">
                    <div class="card-head">
                        <div class="card-head-title">
                            <div class="card-head-icon" style="background:linear-gradient(135deg,#ec4899,#f97316);"><i class="bi bi-people"></i></div>
                            Учасники
                        </div>
                        <span style="background:rgba(99,102,241,.1);border:1px solid rgba(99,102,241,.2);border-radius:999px;padding:.25rem .75rem;font-size:.78rem;font-weight:700;color:#4f46e5;">
                            @Model.Participants.Count()
                        </span>
                    </div>

                    @{
                        int pi = 0;
                    }
                    @foreach (var p in Model.Participants)
                    {
                        var initials = string.IsNullOrEmpty(p.UserName) ? "?" : p.UserName.Substring(0, 1).ToUpper();
                        var isOrg = p.Role == "Organizer";
                        var isVie = p.Role == "Viewer";
                        pi++;
                        <div class="participant-item">
                            <div class="avatar @(isOrg ? "avatar-org" : isVie ? "avatar-vie" : "avatar-mem")">@initials</div>
                            <div style="flex:1;min-width:0;">
                                <div class="participant-name" style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@p.UserName</div>
                                <div style="margin-top:.2rem;">
                                    @if (!canManage || isOrg)
                                    {
                                        <span class="participant-role-badge @(isOrg ? "prb-org" : isVie ? "prb-vie" : "prb-mem")">
                                            @if (isOrg)
                                            {
                                                <i class="bi bi-star-fill"></i>
                                            }
                                            @p.Role
                                        </span>
                                    }
                                    else
                                    {
                                        <div class="role-select-wrap">
                                            <form asp-action="UpdateParticipantRole" method="post">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="tripId" value="@Model.Trip.Id" />
                                                <input type="hidden" name="userId" value="@p.UserId" />
                                                <select name="roleId" onchange="this.form.submit()">
                                                    @foreach (var role in ViewBag.AvailableRoles)
                                                    {
                                                        if (role.Text == p.Role)
                                                        {
                                                            <option value="@role.Value" selected>@role.Text</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@role.Value">@role.Text</option>
                                                        }
                                                    }
                                                </select>
                                            </form>
                                        </div>
                                    }
                                </div>
                            </div>
                            @if (canManage && !isOrg)
                            {
                                <button type="button" class="icon-btn-sm del" title="Видалити учасника"
                                        onclick="openRemoveModal('@p.UserId', '@p.UserName')">
                                    <i class="bi bi-person-x"></i>
                                </button>
                            }
                        </div>
                    }

                    @if (canManage)
                    {
                        <div class="invite-form-wrap">
                            <div class="invite-title"><i class="bi bi-person-plus-fill" style="color:#6366f1;"></i> Запросити учасника</div>
                            <form asp-action="InviteParticipant" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="tripId" value="@Model.Trip.Id" />
                                <input type="email" name="email" class="invite-field" placeholder="email@example.com" required />
                                <div class="invite-row">
                                    <select name="roleId" class="invite-select">
                                        @foreach (var role in ViewBag.AvailableRoles)
                                        {
                                            if (role.Text != "Organizer")
                                            {
                                                <option value="@role.Value">@role.Text</option>
                                            }
                                        }
                                    </select>
                                    <button type="submit" class="invite-btn"><i class="bi bi-plus-lg"></i> Додати</button>
                                </div>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Зірки в hero
        (function() {
            const c = document.getElementById('starsContainer');
            for (let i = 0; i < 60; i++) {
                const s = document.createElement('div');
                s.className = 'star';
                s.style.cssText = `left:${Math.random()*100}%;top:${Math.random()*100}%;animation-duration:${2+Math.random()*4}s;animation-delay:${Math.random()*5}s;width:${1+Math.random()*2}px;height:${1+Math.random()*2}px;opacity:${0.2+Math.random()*0.6};`;
                c.appendChild(s);
            }
        })();

        // Модалки
        function openRemoveModal(userId, userName) {
            document.getElementById('deleteParticipantUserId').value = userId;
            document.getElementById('deleteParticipantSub').textContent = `«${userName}» буде видалено з поїздки. Цю дію неможливо скасувати.`;
            document.getElementById('deleteParticipantModal').classList.add('show');
        }
        document.querySelectorAll('.modal-bd').forEach(m => {
            m.addEventListener('click', e => { if (e.target === m) m.classList.remove('show'); });
        });

        // ═══════════════ LEAFLET КАРТА ═══════════════
        var map = L.map('map').setView([48.3794, 31.1656], 5);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        var allPoints = [];
        var routePoints = [];
        const delay = ms => new Promise(res => setTimeout(res, ms));

        async function geocodeAddress(address) {
            if (!address) return null;
            try {
                await delay(1000);
                let response = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`);
                let data = await response.json();
                if (data && data.length > 0) {
                    return [parseFloat(data[0].lat), parseFloat(data[0].lon)];
                }
            } catch(e) {}
            return null;
        }

        async function buildFullRoute() {
            let departureText = '@Html.Raw(Model.Trip.DepartureLocation)';
            let returnText    = '@Html.Raw(Model.Trip.ReturnLocation)';

            let startLatLng = await geocodeAddress(departureText);
            if (startLatLng) {
                L.marker(startLatLng, {
                    icon: L.divIcon({ html:"🟢", className:'fs-4 border-0 bg-transparent', iconSize:[24,24], iconAnchor:[12,12] })
                }).addTo(map).bindPopup("<b>Старт:</b><br>" + departureText);
                allPoints.push(startLatLng);
            }

            var destinations = [
                @foreach (var d in Model.Destinations)
                {
                        <text>{ name: '@Html.Raw(d.CityName)@(!string.IsNullOrEmpty(d.Country) ? $", {Html.Raw(d.Country)}" : "")' },</text>
                }
            ];

            for (let dest of destinations) {
                let latlng = await geocodeAddress(dest.name);
                if (latlng) {
                    L.marker(latlng).addTo(map).bindPopup("<b>" + dest.name + "</b><br>Зупинка маршруту");
                    routePoints.push(latlng);
                    allPoints.push(latlng);
                }
            }

            let endLatLng = await geocodeAddress(returnText);
            if (endLatLng) {
                L.marker(endLatLng, {
                    icon: L.divIcon({ html:"🏁", className:'fs-4 border-0 bg-transparent', iconSize:[24,24], iconAnchor:[12,12] })
                }).addTo(map).bindPopup("<b>Фініш:</b><br>" + returnText);
                allPoints.push(endLatLng);
            }

            let fullPath = [];
            if (startLatLng) fullPath.push(startLatLng);
            fullPath = fullPath.concat(routePoints);
            if (endLatLng) fullPath.push(endLatLng);

            if (fullPath.length > 1) {
                L.polyline(fullPath, { color:'#6366f1', weight:3, opacity:.8, dashArray:'8,8' }).addTo(map);
            }

            var accommodations = [
                @foreach (var a in Model.Accommodations)
                {
                        <text>{ name: '@Html.Raw(a.Name)', address: '@Html.Raw(a.Address)' },</text>
                }
            ];

            for (let acc of accommodations) {
                let latlng = await geocodeAddress(acc.address || acc.name);
                if (latlng) {
                    L.marker(latlng, {
                        icon: L.divIcon({
                            className: 'custom-div-icon',
                            html: "<div style='background:#10b981;color:white;border-radius:50%;width:30px;height:30px;display:flex;align-items:center;justify-content:center;border:2px solid white;box-shadow:0 2px 5px rgba(0,0,0,.3);'>🏠</div>",
                            iconSize:[30,30], iconAnchor:[15,30]
                        })
                    }).addTo(map).bindPopup("<b>" + acc.name + "</b><br>" + acc.address);
                    allPoints.push(latlng);
                }
            }

            if (allPoints.length > 0) {
                map.fitBounds(new L.LatLngBounds(allPoints), { padding:[30,30] });
            }
        }

        buildFullRoute();
    </script>
}
