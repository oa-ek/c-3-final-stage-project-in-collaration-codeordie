@model TravelManager.UI.Models.ViewModels.ExpenseFormViewModel

@{
    ViewData["Title"] = "Додати витрату";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Нова витрата</h4>
        </div>
        <div class="card-body">
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
            }

            <form asp-action="Create" method="post">
                <div class="form-group mb-3">
                    <label asp-for="TripId" class="form-label fw-bold">Поїздка</label>
                    <select asp-for="TripId" asp-items="Model.TripList" class="form-select border-primary" onchange="window.location.href = '/Expenses/Create?tripId=' + this.value;">
                        <option disabled selected>-- Оберіть поїздку --</option>
                    </select>
                    <span asp-validation-for="TripId" class="text-danger small"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Description" class="form-label">Що купили? (Назва)</label>
                        <input asp-for="Description" class="form-control" placeholder="Наприклад: Вечеря в ресторані" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="CategoryId" class="form-label">Категорія</label>
                        <select asp-for="CategoryId" asp-items="Model.CategoryList" class="form-select">
                            <option disabled selected>-- Оберіть категорію --</option>
                        </select>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-3">
                        <label asp-for="TotalAmount" class="form-label">Загальна сума</label>
                        <input asp-for="TotalAmount" class="form-control" id="TotalAmountInput" type="number" step="0.01" />
                        <span asp-validation-for="TotalAmount" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Currency" class="form-label">Валюта</label>
                        <select asp-for="Currency" asp-items="Model.CurrencyList" class="form-select"></select>
                    </div>
                    <div class="col-md-4 mb-3">
                        <label asp-for="Date" class="form-label">Дата</label>
                        <input asp-for="Date" class="form-control" type="date" />
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="PayerId" class="form-label">Хто заплатив?</label>
                        <select asp-for="PayerId" asp-items="Model.PayerList" class="form-select">
                            <option disabled selected>-- Оберіть платника --</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label asp-for="ReceiptImageUrl" class="form-label">Посилання на чек (необов'язково)</label>
                        <input asp-for="ReceiptImageUrl" class="form-control" placeholder="https://..." />
                        <span asp-validation-for="ReceiptImageUrl" class="text-danger"></span>
                    </div>
                </div>

                <div class="card bg-light border-0 mb-4 p-3 rounded">
                    <h6 class="text-muted mb-3"><i class="bi bi-link-45deg"></i> Прив'язати витрату (необов'язково)</h6>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="TransitId" class="form-label small">Транспорт</label>
                            <select asp-for="TransitId" asp-items="Model.TransitList" class="form-select form-select-sm">
                                <option value="">-- Немає --</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="AccommodationId" class="form-label small">Житло</label>
                            <select asp-for="AccommodationId" asp-items="Model.AccommodationList" class="form-select form-select-sm">
                                <option value="">-- Немає --</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="TripActivityId" class="form-label small">Активність</label>
                            <select asp-for="TripActivityId" asp-items="Model.ActivityList" class="form-select form-select-sm">
                                <option value="">-- Немає --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />


                <h5 class="mb-3 d-flex justify-content-between align-items-center">
                    Розподіл витрат (Хто скільки винен)
                    <button type="button" class="btn btn-sm btn-outline-success" id="btnSplitEqually">
                        <i class="bi bi-calculator"></i> Поділити порівну
                    </button>
                </h5>

                <div id="splitsContainer">
                    @for (int i = 0; i < Model.Splits.Count; i++)
                    {
                        <div class="row mb-2 align-items-center split-row">
                            <input type="hidden" asp-for="Splits[i].UserId" />
                            <input type="hidden" asp-for="Splits[i].UserName" />

                            <div class="col-md-6">
                                <strong>@Model.Splits[i].UserName</strong>
                            </div>
                            <div class="col-md-6">
                                <div class="input-group">
                                    <input asp-for="Splits[i].OwedAmount" class="form-control owed-amount-input" type="number" step="0.01" min="0" />
                                    <span class="input-group-text currency-addon">UAH</span>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Зберегти витрату</button>
                    <a asp-controller="Trips" asp-action="Details" asp-route-id="@Model.TripId" class="btn btn-secondary">Скасувати</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const totalInput = document.getElementById('TotalAmountInput');
            const currencySelect = document.getElementById('Currency');
            const splitInputs = document.querySelectorAll('.owed-amount-input');
            const currencyAddons = document.querySelectorAll('.currency-addon');
            const btnSplitEqually = document.getElementById('btnSplitEqually');

            // Оновлення тексту валюти біля полів вводу боргів
            currencySelect.addEventListener('change', function() {
                currencyAddons.forEach(addon => addon.textContent = this.value);
            });

            // Логіка кнопки "Поділити порівну"
            btnSplitEqually.addEventListener('click', function() {
                const total = parseFloat(totalInput.value);
                if (isNaN(total) || total <= 0) {
                    alert("Спочатку введіть загальну суму!");
                    return;
                }

                const count = splitInputs.length;
                if (count === 0) return;

                // Ділимо порівну і округлюємо до 2 знаків після коми
                const splitAmount = Math.floor((total / count) * 100) / 100;
                let remainder = total - (splitAmount * count);

                splitInputs.forEach((input, index) => {
                    let amount = splitAmount;
                    // Додаємо залишок (копійки) до першої людини, щоб сума ідеально зійшлася
                    if (index === 0) {
                        amount += remainder;
                    }
                    input.value = amount.toFixed(2);
                });
            });
        });
    </script>
}
