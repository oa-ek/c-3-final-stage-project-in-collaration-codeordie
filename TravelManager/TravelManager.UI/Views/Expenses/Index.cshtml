@model IEnumerable<TravelManager.UI.Models.ViewModels.ExpenseListViewModel>

@{
    ViewData["Title"] = "Витрати";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="display-6">Витрати</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">Додати витрату</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Поїздка</th>
                    <th>Категорія</th>
                    <th>Опис</th>
                    <th>Сума</th>
                    <th>Дата</th>
                    <th class="text-end pe-4">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.TripTitle</td>
                        <td><span class="badge bg-secondary">@item.CategoryName</span></td>
                        <td>@item.Description</td>
                        <td class="fw-bold text-success">@item.Amount @item.Currency</td>
                        <td>@item.Date.ToShortDateString()</td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning text-dark">Редагувати</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Ви впевнені?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger ms-1">Видалити</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>