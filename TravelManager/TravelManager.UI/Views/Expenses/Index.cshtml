@model IEnumerable<TravelManager.UI.Models.ViewModels.ExpenseListViewModel>

@{
    ViewData["Title"] = "Витрати";
    var totalAmount = Model.Sum(x => x.Amount);
    var mainCurrency = Model.FirstOrDefault()?.Currency ?? "UAH";
}

<style>
    @@keyframes fadeSlideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes shimmer {
        0% {
            transform: translateX(-150%) skewX(-15deg);
        }

        100% {
            transform: translateX(150%) skewX(-15deg);
        }
    }

    .stagger-item {
        animation: fadeSlideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }
</style>

<div class="relative w-full max-w-7xl mx-auto min-h-[75vh] py-10 z-10 px-4">

    <div class="absolute top-10 left-10 w-[30rem] h-[30rem] bg-amber-400/20 rounded-full blur-[120px] animate-pulse pointer-events-none"></div>
    <div class="absolute bottom-10 right-10 w-[35rem] h-[35rem] bg-rose-400/10 rounded-full blur-[100px] animate-pulse pointer-events-none" style="animation-delay: 2s;"></div>

    <div class="relative z-20 flex flex-col md:flex-row justify-between items-start md:items-end mb-14 stagger-item" style="animation-delay: 0.1s;">
        <div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur-md border border-white shadow-sm mb-4">
                <i class="bi bi-wallet2 text-amber-500 text-sm"></i>
                <span class="text-xs font-black text-slate-500 uppercase tracking-widest">Фінанси</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-black text-slate-800 tracking-tighter drop-shadow-sm leading-none">
                Витрати
            </h1>
        </div>

        <a asp-action="Create" class="mt-8 md:mt-0 group relative inline-flex items-center justify-center px-8 py-4 font-black text-white transition-all duration-500 bg-gradient-to-r from-amber-500 to-orange-500 rounded-full shadow-[0_10px_20px_-5px_rgba(245,158,11,0.4)] hover:shadow-[0_15px_30px_-5px_rgba(245,158,11,0.6)] hover:-translate-y-1 uppercase tracking-widest text-xs overflow-hidden">
            <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/40 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
            <span class="relative flex items-center gap-3">
                Нова транзакція
                <i class="bi bi-plus-lg text-lg group-hover:rotate-90 transition-transform duration-500"></i>
            </span>
        </a>
    </div>

    <div class="relative z-20 grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12 stagger-item" style="animation-delay: 0.2s;">

        <div class="lg:col-span-2 bg-white/60 backdrop-blur-3xl border border-white/80 rounded-[3rem] p-10 shadow-[0_10px_40px_-10px_rgba(0,0,0,0.05)] flex flex-col md:flex-row items-center justify-between gap-6 hover:shadow-[0_20px_50px_-10px_rgba(245,158,11,0.15)] transition-all duration-500 group">
            <div>
                <p class="text-[12px] font-black uppercase tracking-widest text-slate-400 mb-2">Загальна сума витрат</p>
                <p class="text-6xl md:text-7xl font-black text-slate-800 tracking-tighter group-hover:bg-gradient-to-r group-hover:from-amber-500 group-hover:to-orange-500 group-hover:bg-clip-text group-hover:text-transparent transition-all duration-500">
                    @totalAmount.ToString("N2") <span class="text-3xl text-slate-400 font-bold tracking-normal">@mainCurrency</span>
                </p>
            </div>
            <div class="w-24 h-24 rounded-[2.5rem] bg-amber-50 flex items-center justify-center border border-amber-100 shadow-inner group-hover:scale-110 transition-transform duration-500">
                <i class="bi bi-safe2 text-5xl text-amber-400"></i>
            </div>
        </div>

        <a asp-controller="ExpenseSplits" asp-action="Index" class="bg-white/60 backdrop-blur-3xl border border-white/80 rounded-[3rem] p-10 shadow-[0_10px_40px_-10px_rgba(0,0,0,0.05)] hover:shadow-[0_20px_50px_-10px_rgba(16,185,129,0.15)] transition-all duration-500 hover:-translate-y-2 flex flex-col justify-center group relative overflow-hidden">
            <div class="absolute -right-10 -top-10 w-32 h-32 bg-emerald-400/10 rounded-full blur-2xl group-hover:bg-emerald-400/20 transition-all duration-500"></div>
            <div class="w-16 h-16 rounded-2xl bg-emerald-50 flex items-center justify-center border border-emerald-100 shadow-inner mb-6 group-hover:scale-110 transition-transform duration-500">
                <i class="bi bi-people-fill text-3xl text-emerald-500"></i>
            </div>
            <h3 class="text-2xl font-black text-slate-800 mb-2 tracking-tight">Спільні борги</h3>
            <p class="text-sm font-bold text-emerald-600 flex items-center gap-2">
                Перейти до розподілу <i class="bi bi-arrow-right group-hover:translate-x-2 transition-transform duration-300"></i>
            </p>
        </a>
    </div>

    <div class="relative z-20 space-y-5">
        @if (!Model.Any())
        {
            <div class="bg-white/40 backdrop-blur-3xl border border-white/80 rounded-[3rem] p-16 text-center shadow-sm stagger-item max-w-2xl mx-auto" style="animation-delay: 0.3s;">
                <div class="w-24 h-24 bg-white rounded-[2rem] flex items-center justify-center mx-auto mb-6 border border-amber-100 shadow-sm">
                    <i class="bi bi-receipt text-5xl text-amber-300"></i>
                </div>
                <h3 class="text-3xl font-black text-slate-700 tracking-tight mb-2">Транзакцій немає</h3>
                <p class="text-slate-500 text-lg font-medium">Ваш гаманець поки що відпочиває.</p>
            </div>
        }
        else
        {
            var delay = 0.3m;
            foreach (var item in Model)
            {
                <div class="group bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2rem] p-6 shadow-[0_8px_30px_-10px_rgba(0,0,0,0.04)] hover:shadow-[0_15px_40px_-10px_rgba(245,158,11,0.12)] hover:bg-white/80 transition-all duration-300 hover:-translate-y-1 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 stagger-item" style="animation-delay: @(delay.ToString(System.Globalization.CultureInfo.InvariantCulture))s;">

                    <div class="flex items-center gap-6 w-full md:w-auto">
                        <div class="w-16 h-16 shrink-0 bg-gradient-to-br from-white to-slate-50 rounded-[1.5rem] border border-white flex items-center justify-center shadow-md group-hover:scale-110 transition-transform duration-500">
                            @{
                                string iconClass = item.CategoryName switch
                                {
                                    "Food" => "bi-cup-hot-fill text-orange-400",
                                    "Transport" => "bi-car-front-fill text-blue-400",
                                    "Accommodation" => "bi-house-fill text-indigo-400",
                                    "Entertainment" => "bi-controller text-purple-400",
                                    "Shopping" => "bi-bag-fill text-pink-400",
                                    _ => "bi-tag-fill text-slate-400"
                                };
                            }
                            <i class="bi @iconClass text-2xl drop-shadow-sm"></i>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-xl font-black text-slate-800 tracking-tight leading-tight mb-1.5 group-hover:text-amber-600 transition-colors">@item.Description</span>
                            <div class="flex flex-wrap items-center gap-3 text-xs font-bold text-slate-400">
                                <span class="bg-white px-3 py-1 rounded-lg border border-slate-100 shadow-sm text-slate-500">@item.CategoryName</span>
                                <span class="flex items-center gap-1.5"><i class="bi bi-airplane-engines text-blue-400"></i> @item.TripTitle</span>
                                <span class="flex items-center gap-1.5"><i class="bi bi-calendar3 text-emerald-400"></i> @item.Date.ToShortDateString()</span>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center justify-between md:justify-end w-full md:w-auto gap-8 mt-2 md:mt-0 pt-4 md:pt-0 border-t md:border-t-0 border-slate-200/50">
                        <div class="flex flex-col items-start md:items-end">
                            <span class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1">Списано</span>
                            <span class="text-2xl font-black text-slate-800 tracking-tight">
                                -@item.Amount.ToString("N2") <span class="text-sm font-bold text-slate-400">@item.Currency</span>
                            </span>
                        </div>

                        <div class="flex items-center gap-2 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-300">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="w-11 h-11 rounded-xl bg-white border border-slate-100 flex items-center justify-center text-slate-400 hover:text-amber-600 hover:bg-amber-50 hover:border-amber-200 transition-all shadow-sm hover:scale-105" title="Редагувати">
                                <i class="bi bi-pencil-fill text-sm"></i>
                            </a>
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0" onsubmit="return confirm('Ви впевнені, що хочете видалити цю транзакцію?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="w-11 h-11 rounded-xl bg-white border border-slate-100 flex items-center justify-center text-slate-400 hover:text-rose-600 hover:bg-rose-50 hover:border-rose-200 transition-all shadow-sm hover:scale-105" title="Видалити">
                                    <i class="bi bi-trash3-fill text-sm"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
                delay += 0.1m;
            }
        }
    </div>
</div>