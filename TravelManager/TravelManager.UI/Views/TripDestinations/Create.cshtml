@model TravelManager.UI.Models.ViewModels.TripDestinationFormViewModel

@{
    ViewData["Title"] = "Додати місто";
}

<div class="container py-4">
    <h2 class="mb-4">Додати місто до маршруту</h2>
    <hr />

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="TripId" class="form-label fw-bold"></label>
                            <select asp-for="TripId" asp-items="Model.TripList" class="form-select">
                                <option disabled selected>-- Оберіть поїздку --</option>
                            </select>
                            <span asp-validation-for="TripId" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="CityName" class="form-label fw-bold"></label>
                                <input asp-for="CityName" class="form-control" id="cityNameInput" autocomplete="off" />
                                <span asp-validation-for="CityName" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label asp-for="Country" class="form-label fw-bold"></label>
                                <input asp-for="Country" class="form-control" id="countryInput" autocomplete="off" />
                                <span asp-validation-for="Country" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="ArrivalDate" class="form-label fw-bold"></label>
                                <input asp-for="ArrivalDate" class="form-control" />
                                <span asp-validation-for="ArrivalDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label asp-for="DepartureDate" class="form-label fw-bold"></label>
                                <input asp-for="DepartureDate" class="form-control" />
                                <span asp-validation-for="DepartureDate" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="Latitude" class="form-label fw-bold"></label>
                                <input asp-for="Latitude" class="form-control" type="number" step="0.000001" id="latInput" />
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label asp-for="Longitude" class="form-label fw-bold"></label>
                                <input asp-for="Longitude" class="form-control" type="number" step="0.000001" id="lngInput" />
                            </div>
                        </div>

                        <!-- Статус автогеокодування -->
                        <div id="geocodeStatus" class="mb-3" style="display:none; font-size:.85rem; font-weight:600; padding:.5rem .8rem; border-radius:.5rem;"></div>

                        <div class="form-group d-flex justify-content-between">
                            <button type="submit" class="btn btn-success px-5 shadow-sm">Зберегти</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        const cityInput   = document.getElementById('cityNameInput');
        const countryInput = document.getElementById('countryInput');
        const latInput    = document.getElementById('latInput');
        const lngInput    = document.getElementById('lngInput');
        const statusEl    = document.getElementById('geocodeStatus');

        let geocodeTimer = null;

        function showStatus(msg, type) {
            statusEl.textContent = msg;
            statusEl.style.display = 'block';
            statusEl.style.background = type === 'ok'
                ? 'rgba(25,135,84,.12)' : type === 'err'
                ? 'rgba(220,53,69,.10)' : 'rgba(13,110,253,.08)';
            statusEl.style.color = type === 'ok' ? '#145c32' : type === 'err' ? '#842029' : '#084298';
        }

        async function tryGeocode() {
            const city    = cityInput.value.trim();
            const country = countryInput.value.trim();
            if (!city) return;

            const query = country ? `${city}, ${country}` : city;
            showStatus('⏳ Визначаємо координати...', 'info');

            try {
                const url = `https://nominatim.openstreetmap.org/search?format=json&limit=1&accept-language=uk&q=${encodeURIComponent(query)}`;
                const res  = await fetch(url, { headers: { 'Accept': 'application/json' } });
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const data = await res.json();
                if (data && data.length > 0) {
                    latInput.value = parseFloat(data[0].lat).toFixed(6);
                    lngInput.value = parseFloat(data[0].lon).toFixed(6);
                    showStatus(`✅ Знайдено: ${data[0].display_name.split(',').slice(0,2).join(',')}`, 'ok');
                } else {
                    showStatus('⚠️ Місто не знайдено — введіть координати вручну', 'err');
                }
            } catch (e) {
                showStatus('⚠️ Помилка геокодування — введіть координати вручну', 'err');
            }
        }

        function scheduleGeocode() {
            clearTimeout(geocodeTimer);
            // Запускаємо геокодування через 800мс після останнього введення
            geocodeTimer = setTimeout(tryGeocode, 800);
        }

        cityInput.addEventListener('blur', tryGeocode);
        countryInput.addEventListener('blur', tryGeocode);
        cityInput.addEventListener('input', scheduleGeocode);
        countryInput.addEventListener('input', scheduleGeocode);
    </script>
}
