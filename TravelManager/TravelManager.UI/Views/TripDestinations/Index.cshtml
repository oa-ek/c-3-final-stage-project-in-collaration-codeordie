@using TravelManager.Domain.Entities
@model IEnumerable<TravelManager.UI.Models.ViewModels.TripDestinationListViewModel>

@{
    ViewData["Title"] = "Маршрут";
    var totalCities = Model.Count();
    var totalDays = Model.Any()
        ? Model.Sum(x => Math.Max(1, (x.DepartureDate - x.ArrivalDate).Days))
        : 0;
    var withCoords = Model.Where(d => d.Latitude.HasValue && d.Longitude.HasValue).ToList();

    // Отримуємо транзити, передані з контролера через ViewBag
    var allTransits = ViewBag.Transits as IEnumerable<Transit>;
}

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
    .dest-root {
        font-family: 'DM Sans', sans-serif;
        padding: 2rem 0 4rem;
        position: relative;
    }

        .dest-root::before {
            content: '';
            position: fixed;
            inset: 0;
            background: radial-gradient(ellipse 70% 50% at 0% 0%, rgba(59,130,246,0.10) 0%, transparent 55%), radial-gradient(ellipse 60% 60% at 100% 100%, rgba(16,185,129,0.09) 0%, transparent 55%);
            z-index: -1;
        }

    .page-title {
        font-family: 'Syne',sans-serif;
        font-size: clamp(2rem,5vw,3.5rem);
        font-weight: 900;
        color: #0f172a;
        line-height: 1;
        letter-spacing: -0.03em;
    }

        .page-title span {
            background: linear-gradient(135deg,#3b82f6,#10b981);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

    .add-btn {
        background: linear-gradient(135deg,#3b82f6,#6366f1);
        color: white;
        border: none;
        border-radius: 1.2rem;
        padding: 0.85rem 1.8rem;
        font-family: 'Syne',sans-serif;
        font-weight: 800;
        font-size: 0.9rem;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.35s;
        box-shadow: 0 4px 20px rgba(59,130,246,0.4);
    }

        .add-btn:hover {
            transform: translateY(-3px) scale(1.04);
            box-shadow: 0 10px 35px rgba(59,130,246,0.55);
            color: white;
        }

    .stat-card {
        background: rgba(255,255,255,0.58);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.88);
        border-radius: 1.5rem;
        padding: 1.2rem 1.5rem;
    }

    .map-card {
        background: rgba(255,255,255,0.60);
        backdrop-filter: blur(24px);
        border: 1px solid rgba(255,255,255,0.9);
        border-radius: 2rem;
        overflow: hidden;
        box-shadow: 0 8px 40px rgba(59,130,246,0.1);
    }

    #map {
        height: 550px;
        width: 100%;
        border-radius: 0;
    }

    .city-card {
        background: rgba(255,255,255,0.60);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.88);
        border-radius: 1.8rem;
        display: flex;
        flex-direction: column;
        transition: 0.3s;
    }

        .city-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.08);
        }

    .city-num {
        width: 36px;
        height: 36px;
        border-radius: 0.75rem;
        background: #3b82f6;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 900;
    }

    .transport-warning {
        background: rgba(245, 158, 11, 0.1);
        border: 1px solid rgba(245, 158, 11, 0.3);
        border-radius: 0.6rem;
        padding: 0.5rem;
        margin-top: 0.6rem;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }
</style>

<div class="dest-root">
    <div style="max-width:1200px; margin:0 auto; padding:0 1rem;">

        <div style="display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:1rem; margin-bottom:2rem;">
            <div>
                <h1 class="page-title">Мій <span>маршрут</span></h1>
                <p style="color:#64748b; font-weight:500;">Мапа переїздів та деталі точок</p>
            </div>
            <a asp-action="Create" asp-route-tripId="@ViewBag.CurrentTripId" class="add-btn">+ Додати місто</a>
        </div>

        @if (Model.Any())
        {
            <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:1rem; margin-bottom:2rem;">
                <div class="stat-card">
                    <div style="font-family:'Syne',sans-serif; font-size:2.2rem; font-weight:900; color:#3b82f6;">@totalCities</div>
                    <div style="font-size:0.7rem; font-weight:700; color:#94a3b8; text-transform:uppercase;">МІСТ У МАРШРУТІ</div>
                </div>
                <div class="stat-card">
                    <div style="font-family:'Syne',sans-serif; font-size:2.2rem; font-weight:900; color:#10b981;">@totalDays</div>
                    <div style="font-size:0.7rem; font-weight:700; color:#94a3b8; text-transform:uppercase;">ДНІВ ПОДОРОЖІ</div>
                </div>
            </div>

            <div class="map-card" style="margin-bottom:2rem;">
                <div id="map"></div>
            </div>

            <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(340px,1fr)); gap:1.2rem;">
                @{
                    int cityIdx = 0;
                    // МАГІЯ: Якщо перше місто, беремо точку з налаштувань самої поїздки (якщо вона там є)
                    string previousCity = "";
                }
                @foreach (var item in Model)
                {
                    cityIdx++;
                    bool hasTransport = allTransits != null && allTransits.Any(t =>
                    !string.IsNullOrEmpty(t.ArrivalLocation) &&
                    t.ArrivalLocation.Equals(item.CityName, StringComparison.OrdinalIgnoreCase));

                    <div class="city-card">
                        <div style="padding:1.4rem 1.5rem 1rem; border-bottom:1px solid rgba(226,232,240,0.5);">
                            <div style="display:flex; align-items:flex-start; gap:0.8rem;">
                                <div class="city-num">@cityIdx</div>
                                <div style="flex:1;">
                                    <div style="font-weight:900; font-size:1.3rem; color:#0f172a;">@item.CityName</div>
                                    @if (!hasTransport)
                                    {
                                        <div class="transport-warning">
                                            <div style="display:flex; align-items:center; gap:0.4rem;">
                                                <i class="bi bi-exclamation-triangle-fill" style="color: #d97706; font-size: 0.8rem;"></i>
                                                <span style="font-size: 0.65rem; font-weight: 800; color: #b45309; text-transform: uppercase;">Потрібен квиток</span>
                                            </div>
                                            <a asp-controller="Transits" asp-action="Create"
                                               asp-route-tripId="@item.TripId"
                                               asp-route-arrivalLocation="@item.CityName"
                                               asp-route-departureLocation="@(string.IsNullOrEmpty(previousCity) ? "Старт" : previousCity)"
                                               asp-route-arrivalDate="@item.ArrivalDate.ToString("yyyy-MM-dd")"
                                               style="font-size: 0.7rem; font-weight: 800; color: #2563eb; text-decoration: none; background: white; padding: 0.2rem 0.5rem; border-radius: 4px; text-align:center; border: 1px solid rgba(37,99,235,0.2);">
                                                + Додати з @(string.IsNullOrEmpty(previousCity) ? "початку" : previousCity)
                                            </a>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div style="padding:1rem 1.5rem; display:flex; justify-content:space-between; font-weight:700; color:#64748b; font-size:0.85rem;">
                            <span>📅 @item.ArrivalDate.ToString("dd.MM")</span>
                            <span>🏁 @item.DepartureDate.ToString("dd.MM")</span>
                        </div>
                    </div>
                    previousCity = item.CityName;
                }
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Ініціалізація карти
        const map = L.map('map', { attributionControl: false });
        L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);

        const markers = {};
        const allPoints = [];

        // ВАЖЛИВО: Використовуємо маленькі літери для властивостей (camelCase)
        const destinations = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(withCoords.Select((d, i) => new { index = i + 1, cityName = d.CityName, lat = d.Latitude, lng = d.Longitude })));
        const transits = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allTransits?.Select(t => new { departure = t.DepartureLocation, arrival = t.ArrivalLocation, type = t.TransitType?.Name })));

        function makeIcon(num, isFirst, isLast) {
            const color = isFirst ? '#10b981' : isLast ? '#ef4444' : '#3b82f6';
            const svg = `<svg xmlns="http://www.w3.org/2000/svg" width="36" height="44" viewBox="0 0 36 44"><ellipse cx="18" cy="42" rx="8" ry="3" fill="rgba(0,0,0,0.15)"/><path d="M18 2C10.268 2 4 8.268 4 16c0 10 14 26 14 26S32 26 32 16C32 8.268 25.732 2 18 2z" fill="${color}"/><circle cx="18" cy="16" r="9" fill="white"/><text x="18" y="20" text-anchor="middle" fill="${color}" font-size="11" font-weight="900" font-family="sans-serif">${num}</text></svg>`;
            return L.divIcon({ html: svg, className: '', iconSize: [36, 44], iconAnchor: [18, 44], popupAnchor: [0, -46] });
        }

        // 1. Малюємо маркери
        destinations.forEach((d, i) => {
            const icon = makeIcon(d.index, i === 0, i === destinations.length - 1);
            L.marker([d.lat, d.lng], { icon }).addTo(map).bindPopup(`<b>${d.cityName}</b>`);
            markers[d.cityName.toLowerCase()] = [d.lat, d.lng];
            allPoints.push([d.lat, d.lng]);
        });

        // 2. Функція для дуги (Bezier)
        function drawCurve(start, end, label) {
            const lat1 = start[0], lng1 = start[1], lat2 = end[0], lng2 = end[1];
            const mLat = (lat1 + lat2) / 2, mLng = (lng1 + lng2) / 2;
            const bend = 0.2;
            const cLat = mLat - (lng2 - lng1) * bend, cLng = mLng + (lat2 - lat1) * bend;
            const pts = [];
            for (let t = 0; t <= 1; t += 0.05) {
                pts.push([ (1-t)**2*lat1 + 2*(1-t)*t*cLat + t**2*lat2, (1-t)**2*lng1 + 2*(1-t)*t*cLng + t**2*lng2 ]);
            }
            L.polyline(pts, { color: '#2563eb', weight: 4, opacity: 0.7, dashArray: '10, 10' })
             .addTo(map)
             .bindTooltip(label || 'Переїзд', { sticky: true });
        }

        // 3. Малюємо дуги там, де є квитки
        if (transits) {
            transits.forEach(t => {
                const s = markers[t.departure?.toLowerCase()];
                const e = markers[t.arrival?.toLowerCase()];
                if (s && e) drawCurve(s, e, t.type);
            });
        }

        if (allPoints.length > 0) map.fitBounds(allPoints, { padding: [50, 50] });
    </script>
}