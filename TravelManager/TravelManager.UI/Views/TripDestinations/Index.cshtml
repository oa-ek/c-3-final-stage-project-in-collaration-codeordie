@model IEnumerable<TravelManager.UI.Models.ViewModels.TripDestinationListViewModel>

@{
    ViewData["Title"] = "Маршрут";
    var totalCities = Model.Count();
    var totalDays = Model.Any() ? Model.Sum(x => (x.DepartureDate - x.ArrivalDate).Days == 0 ? 1 : (x.DepartureDate - x.ArrivalDate).Days) : 0;
}

<style>
    @@keyframes fadeSlideUp { from { opacity: 0; transform: translateY(30px) scale(0.98); } to { opacity: 1; transform: translateY(0) scale(1); } }
    @@keyframes shimmer { 0% { transform: translateX(-150%) skewX(-15deg); } 100% { transform: translateX(150%) skewX(-15deg); } }
    .stagger-item { animation: fadeSlideUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards; opacity: 0; }
    .ticket-divider { background-image: linear-gradient(to bottom, transparent 50%, rgba(255,255,255,0.8) 50%); background-size: 100% 12px; }
</style>

<div class="relative w-full max-w-7xl mx-auto min-h-[75vh] py-10 z-10 px-4">
    
    <div class="absolute top-0 left-1/3 w-[45rem] h-[45rem] bg-blue-500/10 rounded-full blur-[120px] animate-pulse pointer-events-none -translate-x-1/2"></div>
    <div class="absolute bottom-0 right-1/4 w-[35rem] h-[35rem] bg-emerald-400/10 rounded-full blur-[100px] animate-pulse pointer-events-none translate-x-1/4"></div>

    <div class="relative z-20 flex flex-col md:flex-row justify-between items-start md:items-end mb-10 stagger-item" style="animation-delay: 0.1s;">
        <div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur-md border border-white shadow-sm mb-4">
                <i class="bi bi-geo-alt-fill text-blue-500 text-sm"></i>
                <span class="text-xs font-black text-slate-500 uppercase tracking-widest">Деталі подорожі</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-black text-slate-800 tracking-tighter drop-shadow-sm leading-none">
                Маршрут
            </h1>
        </div>
        
        <div class="flex gap-4 mt-8 md:mt-0">
            <a asp-controller="Trips" asp-action="Index" class="group relative inline-flex items-center justify-center px-8 py-5 font-black text-slate-600 transition-all duration-300 bg-white/60 backdrop-blur-md border border-white rounded-full shadow-sm hover:shadow-md hover:-translate-y-1 uppercase tracking-widest text-xs">
                <i class="bi bi-arrow-left mr-2 group-hover:-translate-x-1 transition-transform"></i> До поїздок
            </a>

            <a asp-action="Create" asp-route-tripId="@ViewBag.CurrentTripId" class="group relative inline-flex items-center justify-center px-10 py-5 font-black text-white transition-all duration-500 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-full shadow-[0_10px_30px_-5px_rgba(59,130,246,0.4)] hover:shadow-[0_20px_40px_-5px_rgba(59,130,246,0.6)] hover:-translate-y-1 uppercase tracking-widest text-sm overflow-hidden">
                <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/40 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
                <span class="relative flex items-center gap-3">
                    Додати місто
                    <i class="bi bi-plus-lg text-xl group-hover:rotate-90 transition-transform duration-500"></i>
                </span>
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="relative z-20 grid grid-cols-2 md:grid-cols-4 lg:grid-cols-4 gap-6 mb-12 stagger-item" style="animation-delay: 0.2s;">
            <div class="bg-white/50 backdrop-blur-xl border border-white/80 rounded-[2rem] p-6 flex items-center gap-4 shadow-sm">
                <div class="w-12 h-12 rounded-2xl bg-blue-100 flex items-center justify-center text-blue-600 text-xl"><i class="bi bi-map-fill"></i></div>
                <div>
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Міст</p>
                    <p class="text-3xl font-black text-slate-800 leading-none">@totalCities</p>
                </div>
            </div>
            <div class="bg-white/50 backdrop-blur-xl border border-white/80 rounded-[2rem] p-6 flex items-center gap-4 shadow-sm">
                <div class="w-12 h-12 rounded-2xl bg-emerald-100 flex items-center justify-center text-emerald-600 text-xl"><i class="bi bi-calendar-check"></i></div>
                <div>
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Днів</p>
                    <p class="text-3xl font-black text-slate-800 leading-none">@totalDays</p>
                </div>
            </div>
            <div class="bg-white/50 backdrop-blur-xl border border-white/80 rounded-[2rem] p-6 flex items-center gap-4 shadow-sm">
                <div class="w-12 h-12 rounded-2xl bg-amber-100 flex items-center justify-center text-amber-600 text-xl"><i class="bi bi-cash-stack"></i></div>
                <div>
                    <p class="text-[10px] font-black uppercase tracking-widest text-slate-400">Витрати</p>
                    <p class="text-3xl font-black text-slate-800 leading-none">0</p>
                </div>
            </div>
        </div>
    }

    <div class="relative z-20 space-y-6">
        @if (!Model.Any())
        {
            <div class="bg-white/40 backdrop-blur-3xl border border-white/80 rounded-[3rem] p-16 text-center shadow-sm stagger-item max-w-2xl mx-auto">
                <div class="w-24 h-24 bg-blue-50 rounded-[2rem] flex items-center justify-center mx-auto mb-6 border border-white">
                    <i class="bi bi-geo-alt text-5xl text-blue-300"></i>
                </div>
                <h3 class="text-3xl font-black text-slate-700 tracking-tight mb-2">Міст не знайдено</h3>
                <p class="text-slate-500 text-lg font-medium">Натисніть "Додати місто", щоб розпочати наповнення цієї подорожі.</p>
            </div>
        }
        else
        {
            var delay = 0.3m;
            foreach (var item in Model)
            {
                <div class="group relative bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2.5rem] shadow-[0_10px_40px_-10px_rgba(0,0,0,0.05)] hover:shadow-[0_20px_50px_-10px_rgba(59,130,246,0.15)] hover:bg-white/80 transition-all duration-500 hover:-translate-y-1 stagger-item flex flex-col md:flex-row overflow-hidden" style="animation-delay: @(delay.ToString(System.Globalization.CultureInfo.InvariantCulture))s;">
                    
                    <div class="flex-1 p-8 md:p-10 flex flex-col justify-center relative z-10">
                        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl bg-slate-900/5 border border-white text-[10px] font-black text-slate-600 uppercase tracking-widest mb-4 w-fit">
                            <i class="bi bi-airplane-engines-fill text-blue-500"></i> @item.TripName
                        </span>
                        <h2 class="text-4xl md:text-5xl font-black text-slate-800 tracking-tighter leading-none mb-3 group-hover:text-blue-600 transition-colors">
                            @item.CityName
                        </h2>
                        <p class="text-slate-500 font-bold flex items-center gap-2 text-lg">
                            <i class="bi bi-globe-europe-africa text-blue-400"></i> @item.Country
                        </p>
                    </div>

                    <div class="hidden md:flex w-8 relative z-10">
                        <div class="absolute inset-y-4 left-1/2 w-[2px] -translate-x-1/2 ticket-divider opacity-50 group-hover:opacity-100"></div>
                        <div class="absolute -top-4 left-1/2 w-8 h-8 bg-white/40 backdrop-blur-3xl border-b border-white/80 rounded-full -translate-x-1/2"></div>
                        <div class="absolute -bottom-4 left-1/2 w-8 h-8 bg-white/40 backdrop-blur-3xl border-t border-white/80 rounded-full -translate-x-1/2"></div>
                    </div>

                    <div class="w-full md:w-[450px] bg-slate-50/50 p-8 md:p-10 flex flex-col justify-center relative z-10 border-t md:border-t-0 md:border-l border-white/50">
                        
                        <div class="flex items-center justify-between mb-8">
                            <div>
                                <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Прибуття</p>
                                <p class="text-2xl font-black text-slate-800">@item.ArrivalDate.ToString("dd MMM", new System.Globalization.CultureInfo("uk-UA"))</p>
                            </div>
                            <div class="flex-1 px-6 relative flex items-center justify-center">
                                <div class="w-full border-t-2 border-dashed border-slate-300"></div>
                                <div class="absolute w-10 h-10 bg-white rounded-full border border-blue-100 flex items-center justify-center shadow-sm text-blue-500">
                                    <i class="bi bi-airplane-fill"></i>
                                </div>
                            </div>
                            <div class="text-right">
                                <p class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-2">Відбуття</p>
                                <p class="text-2xl font-black text-slate-800">@item.DepartureDate.ToString("dd MMM", new System.Globalization.CultureInfo("uk-UA"))</p>
                            </div>
                        </div>

                        <div class="flex items-center justify-between mt-auto pt-6 border-t border-slate-200/50">
                            @{ var itemDays = (item.DepartureDate - item.ArrivalDate).Days == 0 ? 1 : (item.DepartureDate - item.ArrivalDate).Days; }
                            <span class="bg-white px-4 py-2 rounded-xl text-xs font-black text-blue-600 border border-slate-100 shadow-sm">
                                <i class="bi bi-clock"></i> @itemDays днів
                            </span>

                            <div class="flex gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="w-10 h-10 rounded-xl bg-white border border-slate-100 flex items-center justify-center text-slate-400 hover:text-blue-600 transition-all shadow-sm hover:scale-105">
                                    <i class="bi bi-pencil-fill text-sm"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Видалити?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="w-10 h-10 rounded-xl bg-white border border-slate-100 flex items-center justify-center text-slate-400 hover:text-rose-600 transition-all shadow-sm hover:scale-105">
                                        <i class="bi bi-trash3-fill text-sm"></i>
                                    </button>
                                </form>
                            </div>
                        </div>

                    </div>
                </div>
                delay += 0.1m;
            }
        }
    </div>
</div>