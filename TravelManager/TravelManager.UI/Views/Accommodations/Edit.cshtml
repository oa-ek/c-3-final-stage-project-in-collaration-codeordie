@model TravelManager.UI.Models.ViewModels.AccommodationFormViewModel

@{
    ViewData["Title"] = "Редагувати житло";
}

<div class="container py-4">
    <h2 class="mb-4">Редагувати житло</h2>
    <hr />

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="Id" />

                        <div class="form-group mb-3">
                            <label asp-for="TripId" class="form-label fw-bold">Прив'язати до поїздки</label>
                            <select asp-for="TripId" asp-items="Model.TripList" class="form-select">
                                <option disabled selected>-- Оберіть поїздку --</option>
                            </select>
                            <span asp-validation-for="TripId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Name" class="form-label fw-bold">Назва</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="Address" class="form-label fw-bold">Адреса</label>
                            <input asp-for="Address" class="form-control" />
                            <span asp-validation-for="Address" class="text-danger small"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="CheckInTime" class="form-label fw-bold">Час заїзду</label>
                                <input asp-for="CheckInTime" class="form-control" type="datetime-local" />
                                <span asp-validation-for="CheckInTime" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 mt-3 mt-md-0">
                                <label asp-for="CheckOutTime" class="form-label fw-bold">Час виїзду</label>
                                <input asp-for="CheckOutTime" class="form-control" type="datetime-local" />
                                <span asp-validation-for="CheckOutTime" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="BookingReference" class="form-label fw-bold">Номер бронювання (необов'язково)</label>
                            <input asp-for="BookingReference" class="form-control" />
                        </div>

                        <div class="form-group d-flex justify-content-between">
                            <button type="submit" class="btn btn-primary px-5 shadow-sm">Оновити</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}