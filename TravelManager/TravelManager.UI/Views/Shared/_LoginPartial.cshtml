@using Microsoft.AspNetCore.Identity
@using TravelManager.Domain.Entities
@inject SignInManager<User> SignInManager
@inject UserManager<User> UserManager

<div class="flex items-center gap-2">
    @if (SignInManager.IsSignedIn(User))
    {
        var currentUser = await UserManager.GetUserAsync(User);
        var displayName = currentUser?.FirstName ?? User.Identity?.Name;

        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="AdminDashboard" class="flex items-center justify-center w-10 h-10 rounded-full bg-rose-100 text-rose-600 hover:bg-rose-200 hover:scale-105 transition-all" title="Адмін Панель">
                <i class="bi bi-shield-lock-fill text-lg"></i>
            </a>
        }

        <a asp-controller="Account" asp-action="Profile" class="flex items-center gap-2 pr-3 pl-1 py-1 rounded-full hover:bg-slate-100/50 transition-colors">
            @if (currentUser?.ProfilePicture != null)
            {
                var base64 = Convert.ToBase64String(currentUser.ProfilePicture);
                var imgSrc = $"data:image/jpeg;base64,{base64}";
                <img src="@imgSrc" alt="Avatar" class="w-9 h-9 rounded-full object-cover shadow-sm border border-white/50" />
            }
            else
            {
                <div class="w-9 h-9 rounded-full bg-gradient-to-tr from-indigo-500 to-purple-500 flex items-center justify-center text-white font-bold text-sm shadow-sm border border-white/50">
                    @(displayName?.Substring(0, 1).ToUpper() ?? "U")
                </div>
            }
            <span class="text-sm font-bold text-slate-700 hidden sm:block">@displayName</span>
        </a>

        <form class="m-0 p-0" asp-controller="Account" asp-action="Logout" method="post">
            <button type="submit" class="flex items-center justify-center w-10 h-10 rounded-full hover:bg-rose-50 hover:text-rose-600 text-slate-500 transition-colors" title="Вийти">
                <i class="bi bi-box-arrow-right text-lg"></i>
            </button>
        </form>
    }
    else
    {
        <a asp-controller="Account" asp-action="Login" class="text-sm font-bold text-slate-600 hover:text-indigo-600 transition-colors px-3 py-2">
            Увійти
        </a>
        <a asp-controller="Account" asp-action="Register" class="text-sm font-bold bg-slate-900 text-white px-5 py-2.5 rounded-full hover:bg-indigo-600 transition-all shadow-md hover:shadow-lg transform hover:-translate-y-0.5">
            Реєстрація
        </a>
    }
</div>