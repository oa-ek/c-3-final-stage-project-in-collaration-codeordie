@using Microsoft.AspNetCore.Identity
@using TravelManager.Domain.Entities
@inject UserManager<User> UserManager

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TravelManager</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            background-color: #f8fafc;
            background-image: radial-gradient(at 0% 0%, hsla(217,100%,94%,1) 0, transparent 50%), radial-gradient(at 100% 0%, hsla(253,100%,94%,1) 0, transparent 50%), radial-gradient(at 100% 100%, hsla(160,100%,94%,1) 0, transparent 50%);
            background-attachment: fixed;
        }

        /* Контейнер-тригер для виклику меню */
        .dock-trigger-zone {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            height: 80px; /* Область чутливості миші */
            z-index: 100;
            display: flex;
            align-items: flex-end;
            justify-content: center;
            padding-bottom: 24px;
        }

        .glass-dock {
            background: rgba(255, 255, 255, 0.7);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.8);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
            border-radius: 24px;
            padding: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
            /* Початковий прихований стан */
            transform: translateY(120%);
            opacity: 0;
            transition: all 0.45s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        /* Поява при наведенні на тригер-зону */
        .dock-trigger-zone:hover .glass-dock {
            transform: translateY(0);
            opacity: 1;
        }

        .dock-item {
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 3.5rem;
            height: 3.5rem;
            border-radius: 16px;
            color: #64748b;
            text-decoration: none;
            transition: all 0.3s ease;
        }

            .dock-item:hover {
                color: #4f46e5;
                background: rgba(255, 255, 255, 0.9);
                transform: scale(1.15);
                box-shadow: 0 10px 20px -5px rgba(79, 70, 229, 0.15);
            }

        .dock-tooltip {
            position: absolute;
            top: -45px;
            background: #0f172a;
            color: white;
            font-size: 0.7rem;
            font-weight: 800;
            padding: 6px 12px;
            border-radius: 8px;
            opacity: 0;
            pointer-events: none;
            transform: translateY(10px);
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .dock-item:hover .dock-tooltip {
            opacity: 1;
            transform: translateY(0);
        }

        .scrollbar-hide::-webkit-scrollbar {
            display: none;
        }

        .scrollbar-hide {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>

<body class="flex flex-col min-h-screen font-sans text-slate-800 antialiased selection:bg-indigo-200">

    <header class="fixed top-0 left-0 right-0 z-50 p-4 sm:p-6 flex justify-between items-start pointer-events-none">

        <a class="pointer-events-auto flex items-center gap-3 group bg-white/40 backdrop-blur-md border border-white/50 p-2 pr-5 rounded-full shadow-sm hover:bg-white/70 transition-all duration-300 text-decoration-none" asp-area="" asp-controller="Home" asp-action="Index">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-indigo-600 to-indigo-800 flex items-center justify-center text-white shadow-md group-hover:rotate-12 transition-transform duration-300">
                <i class="bi bi-compass text-xl"></i>
            </div>
            <span class="font-black tracking-tight text-slate-800 text-lg hidden sm:block">
                TravelManager
            </span>
        </a>

        <div class="pointer-events-auto bg-white/40 backdrop-blur-md border border-white/50 p-1.5 rounded-full shadow-sm hover:bg-white/70 transition-all duration-300">
            <partial name="_LoginPartial" />
        </div>
    </header>

    <main role="main" class="flex-grow container mx-auto px-4 pt-24 pb-32 max-w-7xl relative z-0">
        @RenderBody()
    </main>

    @if (User.Identity!.IsAuthenticated)
    {
        @* Секретна зона, яка викликає док *@
        <div class="dock-trigger-zone">
            <nav class="glass-dock scrollbar-hide">

                <a asp-area="" asp-controller="Home" asp-action="Index" class="dock-item">
                    <span class="dock-tooltip">Головна</span>
                    <i class="bi bi-grid-1x2-fill text-2xl"></i>
                </a>

                <div class="w-px h-8 bg-slate-300/40 mx-1"></div>

                <a asp-controller="Trips" asp-action="Index" class="dock-item">
                    <span class="dock-tooltip">Поїздки</span>
                    <i class="bi bi-geo-alt-fill text-2xl"></i>
                </a>

                <a asp-controller="TripDestinations" asp-action="Index" class="dock-item">
                    <span class="dock-tooltip">Маршрути</span>
                    <i class="bi bi-signpost-split-fill text-2xl"></i>
                </a>

                <a asp-controller="Expenses" asp-action="Index" class="dock-item">
                    <span class="dock-tooltip">Фінанси</span>
                    <i class="bi bi-wallet2 text-2xl"></i>
                </a>

                <a asp-controller="Transits" asp-action="Index" class="dock-item">
                    <span class="dock-tooltip">Транспорт</span>
                    <i class="bi bi-ticket-detailed-fill text-2xl"></i>
                </a>

                <a asp-controller="Accommodations" asp-action="Index" class="dock-item">
                    <span class="dock-tooltip">Житло</span>
                    <i class="bi bi-building text-2xl"></i>
                </a>

                <a asp-controller="TripActivities" asp-action="Index" class="dock-item">
                    <span class="dock-tooltip">Активності</span>
                    <i class="bi bi-bicycle text-2xl"></i>
                </a>

                <a asp-controller="Checklists" asp-action="Index" class="dock-item">
                    <span class="dock-tooltip">Списки</span>
                    <i class="bi bi-ui-checks-grid text-2xl"></i>
                </a>
            </nav>
        </div>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>