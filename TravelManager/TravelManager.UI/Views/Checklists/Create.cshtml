@model TravelManager.UI.Models.ViewModels.ChecklistFormViewModel

@{
    ViewData["Title"] = "Створити список";
}

<div class="container py-4">
    <h2 class="mb-4">Створити новий список</h2>
    <hr />

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm">
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="form-group mb-3">
                            <label asp-for="TripId" class="form-label fw-bold"></label>
                            <select asp-for="TripId" asp-items="Model.TripList" class="form-select">
                                <option disabled selected>-- Оберіть поїздку --</option>
                            </select>
                            <span asp-validation-for="TripId" class="text-danger small"></span>
                        </div>

                        <div class="form-group mb-4">
                            <label asp-for="Title" class="form-label fw-bold"></label>
                            <input asp-for="Title" class="form-control" placeholder="Наприклад: Аптечка, Документи..." />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>

                        <div class="form-group d-flex justify-content-between">
                            <button type="submit" class="btn btn-success px-5 shadow-sm">Зберегти</button>
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">Скасувати</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}