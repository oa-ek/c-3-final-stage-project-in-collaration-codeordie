@model IEnumerable<TravelManager.UI.Models.ViewModels.ChecklistListViewModel>

@{
    ViewData["Title"] = "Списки речей";
}

<style>
    @@keyframes fadeSlideUp {
        0% {
            opacity: 0;
            transform: translateY(30px) scale(0.95);
        }

        100% {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .stagger-item {
        animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }

    @@keyframes blob {
        0% {
            transform: translate(0px, 0px) scale(1);
        }

        33% {
            transform: translate(30px, -50px) scale(1.1);
        }

        66% {
            transform: translate(-20px, 20px) scale(0.9);
        }

        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    .animate-blob {
        animation: blob 8s infinite alternate;
    }

    .animation-delay-2000 {
        animation-delay: 2s;
    }

    @@keyframes shimmer {
        0% {
            transform: translateX(-100%) skewX(-15deg);
        }

        100% {
            transform: translateX(200%) skewX(-15deg);
        }
    }
</style>

<div class="relative w-full max-w-6xl mx-auto min-h-[85vh] py-12 z-10 px-4">

    <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-0">
        <div class="absolute top-10 right-20 w-[25rem] h-[25rem] bg-cyan-400/20 rounded-full mix-blend-multiply filter blur-[100px] animate-blob"></div>
        <div class="absolute bottom-10 left-10 w-[30rem] h-[30rem] bg-blue-400/15 rounded-full mix-blend-multiply filter blur-[120px] animate-blob animation-delay-2000"></div>
    </div>

    <div class="relative z-20 flex flex-col md:flex-row justify-between items-start md:items-end mb-12 stagger-item" style="animation-delay: 0.1s;">
        <div>
            <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-white/60 backdrop-blur-md border border-white shadow-sm mb-4">
                <i class="bi bi-backpack4-fill text-cyan-500 text-sm"></i>
                <span class="text-xs font-black text-slate-500 uppercase tracking-widest">Пакуємо валізи</span>
            </div>
            <h1 class="text-5xl md:text-7xl font-black text-slate-800 tracking-tighter drop-shadow-sm leading-none">
                Списки речей
            </h1>
        </div>

        <a asp-action="Create" class="mt-8 md:mt-0 group relative inline-flex items-center justify-center px-8 py-4 font-black text-white transition-all duration-300 bg-gradient-to-r from-cyan-500 to-blue-600 rounded-full shadow-[0_10px_20px_-5px_rgba(6,182,212,0.4)] hover:shadow-[0_15px_30px_-5px_rgba(6,182,212,0.6)] hover:-translate-y-1 uppercase tracking-widest text-xs overflow-hidden">
            <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
            <span class="relative flex items-center gap-3">
                Новий список <i class="bi bi-plus-lg text-lg group-hover:rotate-90 transition-transform duration-300"></i>
            </span>
        </a>
    </div>

    <div class="relative z-20 space-y-4">
        @if (!Model.Any())
        {
            <div class="bg-white/40 backdrop-blur-3xl border border-white/80 rounded-[3rem] p-16 text-center shadow-sm stagger-item max-w-2xl mx-auto" style="animation-delay: 0.2s;">
                <div class="w-24 h-24 bg-cyan-50 rounded-[2rem] flex items-center justify-center mx-auto mb-6 border border-cyan-100 shadow-inner">
                    <i class="bi bi-luggage text-5xl text-cyan-400"></i>
                </div>
                <h3 class="text-3xl font-black text-slate-700 tracking-tight mb-2">Валіза порожня!</h3>
                <p class="text-slate-500 text-lg font-medium">Створіть свій перший список речей, щоб нічого не забути.</p>
            </div>
        }
        else
        {
            var delay = 0.2m;
            foreach (var item in Model)
            {
                <div class="group bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2rem] p-5 shadow-[0_8px_30px_-10px_rgba(0,0,0,0.04)] hover:shadow-[0_15px_40px_-10px_rgba(6,182,212,0.15)] hover:bg-white/80 transition-all duration-300 hover:-translate-y-1 flex flex-col md:flex-row items-start md:items-center justify-between gap-6 stagger-item" style="animation-delay: @(delay.ToString(System.Globalization.CultureInfo.InvariantCulture))s;">

                    <div class="flex items-center gap-5 w-full md:w-auto">
                        <div class="w-16 h-16 shrink-0 bg-gradient-to-br from-cyan-50 to-blue-50 rounded-2xl border border-white flex items-center justify-center shadow-md group-hover:scale-110 transition-transform duration-500">
                            <i class="bi bi-list-check text-3xl text-cyan-500 drop-shadow-sm"></i>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-[10px] font-black uppercase tracking-widest text-slate-400 mb-1 flex items-center gap-1.5">
                                <i class="bi bi-airplane-engines text-blue-400"></i> @item.TripName
                            </span>
                            <span class="text-2xl font-black text-slate-800 tracking-tight leading-none group-hover:text-cyan-600 transition-colors">@item.Title</span>
                        </div>
                    </div>

                    <div class="flex items-center w-full md:w-auto gap-3 mt-4 md:mt-0 pt-4 md:pt-0 border-t md:border-t-0 border-slate-200/50 justify-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="px-6 py-3 rounded-xl font-black text-cyan-700 bg-cyan-100/50 hover:bg-cyan-100 border border-cyan-200/50 transition-all shadow-sm flex items-center gap-2">
                            <i class="bi bi-ui-checks"></i> <span class="text-xs uppercase tracking-widest">Пакувати</span>
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="w-11 h-11 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-blue-600 hover:bg-blue-50 transition-all shadow-sm hover:scale-105">
                            <i class="bi bi-pencil-fill text-sm"></i>
                        </a>
                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="m-0" onsubmit="return confirm('Видалити цей список речей?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="w-11 h-11 rounded-xl bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-rose-600 hover:bg-rose-50 transition-all shadow-sm hover:scale-105">
                                <i class="bi bi-trash3-fill text-sm"></i>
                            </button>
                        </form>
                    </div>
                </div>
                delay += 0.1m;
            }
        }
    </div>
</div>