@model IEnumerable<TravelManager.UI.Models.ViewModels.ChecklistListViewModel>

@{
    ViewData["Title"] = "Списки речей";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="display-6">Списки речей</h2>
    <a asp-action="Create" class="btn btn-primary shadow-sm">Додати список</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Поїздка</th>
                    <th>Назва списку</th>
                    <th class="text-end pe-4">Дії</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-bold">@item.TripName</td>
                        <td>@item.Title</td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info text-dark">Деталі</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning text-dark ms-1">Редагувати</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline ms-1" onsubmit="return confirm('Ви впевнені?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>