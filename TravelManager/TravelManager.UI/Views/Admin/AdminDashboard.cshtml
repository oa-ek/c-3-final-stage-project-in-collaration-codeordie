@model TravelManager.UI.Models.ViewModels.Admin.DashboardViewModel
@{
    ViewData["Title"] = "Адмін Панель";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    @@keyframes slideUpFade {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .animate-slide-up {
        animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    .stagger-1 {
        animation-delay: 0.1s;
        opacity: 0;
    }

    .stagger-2 {
        animation-delay: 0.2s;
        opacity: 0;
    }

    .stagger-3 {
        animation-delay: 0.3s;
        opacity: 0;
    }
</style>

<div class="relative w-full min-h-screen py-10 z-10 overflow-hidden">
    <div class="absolute top-0 left-0 w-[40rem] h-[40rem] bg-blue-500/10 rounded-full blur-[120px] animate-pulse pointer-events-none -translate-x-1/2 -translate-y-1/4"></div>
    <div class="absolute bottom-0 right-0 w-[40rem] h-[40rem] bg-indigo-400/10 rounded-full blur-[120px] animate-pulse pointer-events-none translate-x-1/3 translate-y-1/4" style="animation-delay: 2s;"></div>

    <div class="max-w-7xl mx-auto px-4 z-20 relative">

        <div class="flex items-center gap-4 mb-8 animate-slide-up">
            <div class="w-14 h-14 bg-gradient-to-br from-indigo-100 to-white rounded-2xl border border-indigo-100 flex items-center justify-center shadow-sm">
                <i class="bi bi-speedometer2 text-3xl text-indigo-600 drop-shadow-sm"></i>
            </div>
            <div>
                <h2 class="text-4xl font-black text-slate-800 tracking-tight m-0">Панель Адміністратора</h2>
                <p class="text-slate-500 font-medium m-0 mt-1">Огляд та керування системою</p>
            </div>
        </div>

        <!-- Верхній ряд: Картки статистики -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">

            <!-- Користувачів -->
            <div class="animate-slide-up stagger-1 group bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2rem] p-6 shadow-[0_10px_30px_-10px_rgba(0,0,0,0.05)] hover:shadow-[0_15px_35px_-10px_rgba(59,130,246,0.15)] transition-all duration-500 hover:-translate-y-1 relative overflow-hidden flex flex-col justify-between">
                <div class="absolute -right-6 -top-6 w-24 h-24 bg-blue-400/10 rounded-full blur-xl group-hover:bg-blue-400/20 transition-colors"></div>
                <div>
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="w-12 h-12 bg-blue-100/50 rounded-xl flex items-center justify-center text-blue-600 border border-blue-200/50">
                            <i class="bi bi-people-fill text-xl"></i>
                        </div>
                        <span class="bg-blue-100 text-blue-700 text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">Клієнти</span>
                    </div>
                    <h5 class="text-slate-500 text-sm font-bold mb-1 uppercase tracking-wide">Користувачів</h5>
                    <h1 class="text-5xl font-black text-slate-800 tracking-tighter m-0">@Model.TotalUsers</h1>
                </div>
                <div class="mt-6 pt-4 border-t border-slate-200/50">
                    <a asp-action="UserList" class="inline-flex items-center text-sm font-bold text-blue-600 hover:text-blue-800 transition-colors group/link">
                        Керувати користувачами <i class="bi bi-arrow-right ml-2 group-hover/link:translate-x-1 transition-transform"></i>
                    </a>
                </div>
            </div>

            <!-- Адміністраторів -->
            <div class="animate-slide-up stagger-2 group bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2rem] p-6 shadow-[0_10px_30px_-10px_rgba(0,0,0,0.05)] hover:shadow-[0_15px_35px_-10px_rgba(244,63,94,0.15)] transition-all duration-500 hover:-translate-y-1 relative overflow-hidden flex flex-col justify-between">
                <div class="absolute -right-6 -top-6 w-24 h-24 bg-rose-400/10 rounded-full blur-xl group-hover:bg-rose-400/20 transition-colors"></div>
                <div>
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="w-12 h-12 bg-rose-100/50 rounded-xl flex items-center justify-center text-rose-600 border border-rose-200/50">
                            <i class="bi bi-shield-lock-fill text-xl"></i>
                        </div>
                        <span class="bg-rose-100 text-rose-700 text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">Персонал</span>
                    </div>
                    <h5 class="text-slate-500 text-sm font-bold mb-1 uppercase tracking-wide">Адміністраторів</h5>
                    <h1 class="text-5xl font-black text-slate-800 tracking-tighter m-0">@Model.TotalAdmins</h1>
                </div>
            </div>

            <!-- Всього поїздок -->
            <div class="animate-slide-up stagger-3 group bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2rem] p-6 shadow-[0_10px_30px_-10px_rgba(0,0,0,0.05)] hover:shadow-[0_15px_35px_-10px_rgba(16,185,129,0.15)] transition-all duration-500 hover:-translate-y-1 relative overflow-hidden flex flex-col justify-between">
                <div class="absolute -right-6 -top-6 w-24 h-24 bg-emerald-400/10 rounded-full blur-xl group-hover:bg-emerald-400/20 transition-colors"></div>
                <div>
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="w-12 h-12 bg-emerald-100/50 rounded-xl flex items-center justify-center text-emerald-600 border border-emerald-200/50">
                            <i class="bi bi-airplane-fill text-xl"></i>
                        </div>
                        <span class="bg-emerald-100 text-emerald-700 text-[10px] font-bold px-2.5 py-1 rounded-full uppercase tracking-wider">Активність</span>
                    </div>
                    <h5 class="text-slate-500 text-sm font-bold mb-1 uppercase tracking-wide">Всього поїздок</h5>
                    <h1 class="text-5xl font-black text-slate-800 tracking-tighter m-0">@Model.TotalTrips</h1>
                </div>
            </div>

        </div>

        <!-- Нижній ряд: Графіки та Форма -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 animate-slide-up stagger-3">

            <!-- Лінійний графік -->
            <div class="lg:col-span-2">
                <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2.5rem] p-6 shadow-[0_15px_40px_-10px_rgba(0,0,0,0.05)] h-full">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 bg-indigo-100/50 rounded-lg flex items-center justify-center text-indigo-600 border border-indigo-200/50">
                            <i class="bi bi-graph-up text-lg"></i>
                        </div>
                        <h3 class="text-xl font-black text-slate-800 m-0">Динаміка реєстрацій</h3>
                    </div>
                    <div class="relative w-full h-[300px]">
                        <canvas id="registrationsChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Панель масової розсилки -->
            <div>
                <div class="bg-white/60 backdrop-blur-2xl border border-white/80 rounded-[2.5rem] p-6 shadow-[0_15px_40px_-10px_rgba(0,0,0,0.05)] h-full flex flex-col">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 bg-amber-100/50 rounded-lg flex items-center justify-center text-amber-600 border border-amber-200/50">
                            <i class="bi bi-envelope-paper-fill text-lg"></i>
                        </div>
                        <h3 class="text-xl font-black text-slate-800 m-0">Масова розсилка</h3>
                    </div>

                    <form asp-action="BroadcastEmail" method="post" class="flex flex-col flex-grow">

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="text-emerald-600 mb-4 p-3 bg-emerald-50/80 backdrop-blur-sm rounded-xl text-sm font-medium border border-emerald-100">
                                <i class="bi bi-check-circle-fill me-1"></i> @TempData["SuccessMessage"]
                            </div>
                        }
                        @if (TempData["ErrorMessage"] != null)
                        {
                            <div class="text-rose-500 mb-4 p-3 bg-rose-50/80 backdrop-blur-sm rounded-xl text-sm font-medium border border-rose-100">
                                <i class="bi bi-exclamation-triangle-fill me-1"></i> @TempData["ErrorMessage"]
                            </div>
                        }

                        <div class="mb-4">
                            <label class="block text-xs font-bold text-slate-700 mb-2 pl-1 uppercase tracking-wider">Кому відправити:</label>
                            <select name="targetGroup" class="w-full bg-white/70 border border-slate-200 text-slate-800 text-sm rounded-xl focus:ring-4 focus:ring-amber-500/20 focus:border-amber-500 block px-3 py-2.5 transition-all outline-none shadow-sm cursor-pointer">
                                <option value="All">Всім користувачам (@Model.TotalUsers)</option>
                                <option value="Users">Тільки звичайним користувачам (@Model.NormalUsersCount)</option>
                                <option value="Admins">Тільки адміністраторам (@Model.TotalAdmins)</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="block text-xs font-bold text-slate-700 mb-2 pl-1 uppercase tracking-wider">Тема листа:</label>
                            <input type="text" name="subject" class="w-full bg-white/70 border border-slate-200 text-slate-800 text-sm rounded-xl focus:ring-4 focus:ring-amber-500/20 focus:border-amber-500 block px-3 py-2.5 transition-all outline-none shadow-sm placeholder:text-slate-400" placeholder="Наприклад: Оновлення сайту" required />
                        </div>

                        <div class="mb-6 flex-grow">
                            <label class="block text-xs font-bold text-slate-700 mb-2 pl-1 uppercase tracking-wider">Текст повідомлення:</label>
                            <textarea name="message" class="w-full h-[120px] bg-white/70 border border-slate-200 text-slate-800 text-sm rounded-xl focus:ring-4 focus:ring-amber-500/20 focus:border-amber-500 block px-3 py-2.5 transition-all outline-none shadow-sm placeholder:text-slate-400 resize-none" placeholder="Напишіть ваше повідомлення тут..." required></textarea>
                        </div>

                        <div class="mt-auto">
                            <button type="submit" class="w-full group relative inline-flex items-center justify-center px-6 py-3.5 font-black text-white transition-all duration-500 bg-gradient-to-r from-amber-500 to-orange-500 rounded-xl shadow-[0_10px_20px_-10px_rgba(245,158,11,0.5)] hover:shadow-[0_15px_25px_-10px_rgba(245,158,11,0.6)] hover:-translate-y-0.5 uppercase tracking-widest text-xs overflow-hidden" onclick="return confirm('Ви впевнені, що хочете розпочати масову розсилку?');">
                                <span class="absolute inset-0 w-[200%] bg-gradient-to-r from-transparent via-white/30 to-transparent -translate-x-[150%] group-hover:animate-[shimmer_1.5s_infinite]"></span>
                                <span class="relative flex items-center gap-2">
                                    <i class="bi bi-send-fill"></i> Відправити листи
                                </span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const monthsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RegistrationMonths));
        const countsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RegistrationsCount));

        const ctxLine = document.getElementById('registrationsChart').getContext('2d');

        let gradient = ctxLine.createLinearGradient(0, 0, 0, 400);
        gradient.addColorStop(0, 'rgba(79, 70, 229, 0.4)'); 
        gradient.addColorStop(1, 'rgba(79, 70, 229, 0.0)');

        new Chart(ctxLine, {
            type: 'line',
            data: {
                labels: monthsData,
                datasets: [{
                    label: 'Нових користувачів',
                    data: countsData,
                    borderColor: '#4f46e5', 
                    backgroundColor: gradient,
                    borderWidth: 3,
                    tension: 0.4,
                    fill: true,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: '#4f46e5',
                    pointBorderWidth: 2,
                    pointRadius: 5,
                    pointHoverRadius: 7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        titleFont: { size: 13, family: "'Inter', sans-serif" },
                        bodyFont: { size: 14, weight: 'bold', family: "'Inter', sans-serif" },
                        padding: 12,
                        cornerRadius: 8,
                        displayColors: false
                    }
                },
                scales: {
                    x: {
                        grid: { display: false, drawBorder: false },
                        ticks: { font: { family: "'Inter', sans-serif", size: 12 }, color: '#64748b' }
                    },
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(226, 232, 240, 0.5)', borderDash: [5, 5], drawBorder: false },
                        ticks: { stepSize: 1, font: { family: "'Inter', sans-serif", size: 12 }, color: '#64748b' }
                    }
                }
            }
        });
    </script>
}