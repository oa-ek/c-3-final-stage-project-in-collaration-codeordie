@model IEnumerable<TravelManager.UI.Models.ViewModels.Admin.UserListViewModel>
@{
    ViewData["Title"] = "Керування користувачами";
}

<div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2><i class="bi bi-people"></i> Керування користувачами</h2>
            <a asp-action="AdminDashboard" class="btn btn-outline-secondary">Назад до Дашборду</a>
        </div>

    <!-- Сповіщення (Успіх/Помилка) -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Ім'я</th>
                        <th>Email</th>
                        <th>Дата реєстрації</th>
                        <th>Роль</th>
                        <th class="text-end">Дії</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        var isAdmin = user.Roles.Contains("Admin");
                        <tr>
                            <td class="align-middle">@user.FullName</td>
                            <td class="align-middle">@user.Email</td>
                            <td class="align-middle">@user.CreatedAt.ToString("dd.MM.yyyy")</td>
                            <td class="align-middle">
                                @if (isAdmin)
                                {
                                    <span class="badge bg-danger">Admin</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">User</span>
                                }
                            </td>
                            <td class="text-end align-middle">
                                <!-- Форма зміни ролі -->
                                <form asp-action="ToggleAdminRole" method="post" class="d-inline">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm @(isAdmin ? "btn-outline-secondary" : "btn-outline-success") me-1" title="@(isAdmin ? "Забрати права Адміна" : "Зробити Адміном")">
                                        <i class="bi @(isAdmin ? "bi-arrow-down-circle" : "bi-arrow-up-circle")"></i>
                                    </button>
                                </form>

                                <!-- Форма видалення -->
                                <form asp-action="DeleteUser" method="post" class="d-inline" onsubmit="return confirm('Ви впевнені, що хочете видалити цього користувача? Це незворотно!');">
                                    <input type="hidden" name="id" value="@user.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Видалити користувача">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>